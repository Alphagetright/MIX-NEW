      "原文": "山雨尊仍在，沙沈榻未移。"
    },
    {
      "诗行编号": "P090_L02",
      "原文": "犬迎曾宿客，鸦护落巢儿。"
    },
    {
      "诗行编号": "P090_L03",
      "原文": "云薄翠微寺，天清黄子陂。"
    },
    {
      "诗行编号": "P090_L04",
      "原文": "向来幽兴极，步屣过东篱。"
    }
