    {
      "诗行编号": "P902_L01",
      "原文": "白露团甘子，清晨散马蹄。"
    },
    {
      "诗行编号": "P902_L02",
      "原文": "圃开连石树，船渡入江溪。"
    },
    {
      "诗行编号": "P902_L03",
      "原文": "凭几看鱼乐，回鞭急鸟栖。"
    },
    {
      "诗行编号": "P902_L04",
      "原文": "凭几看鱼乐，回鞭急鳥栖。"
    },
    {
      "诗行编号": "P902_L05",
      "原文": "渐知秋实美，幽径恐多蹊。"
    }
