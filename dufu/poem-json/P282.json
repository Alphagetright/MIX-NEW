  "诗行": [
    {
      "诗行编号": "P282_L01",
      "原文": "朝行青泥上，暮在青泥中。"
    },
    {
      "诗行编号": "P282_L02",
      "原文": "泥泞非一时，版筑劳人功。"
    },
    {
      "诗行编号": "P282_L03",
      "原文": "不畏道途永，乃将汨没同。"
    },
    {
      "诗行编号": "P282_L04",
      "原文": "白马为铁骊，小儿成老翁。"
    },
    {
      "诗行编号": "P282_L05",
      "原文": "哀猿透却坠，死鹿力所穷。"
    },
    {
      "诗行编号": "P282_L06",
      "原文": "寄语北来人，后来莫悤悤。"
    }
  ],
