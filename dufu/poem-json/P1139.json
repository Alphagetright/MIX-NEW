  "诗行": [
    {
      "诗行编号": "P1139_L01",
      "原文": "歌哭俱在晓，行迈有期程。"
    },
    {
      "诗行编号": "P1139_L02",
      "原文": "孤舟似昨日，闻见同一声。"
    },
    {
      "诗行编号": "P1139_L03",
      "原文": "飞鸟数求食，潜鱼亦独惊。"
    },
    {
      "诗行编号": "P1139_L04",
      "原文": "前王作网罟，设法害生成。"
    },
    {
      "诗行编号": "P1139_L05",
      "原文": "碧藻非不茂，高帆终日征。"
    },
    {
      "诗行编号": "P1139_L06",
      "原文": "干戈未揖让，崩迫开其情。"
    }
  ],
