  "诗行": [
    {
      "诗行编号": "P1099_L01",
      "原文": "神仙中人不易得，颜氏之子才孤标。"
    },
    {
      "诗行编号": "P1099_L02",
      "原文": "天马长鸣待驾驭，秋鹰整翮当云霄。"
    },
    {
      "诗行编号": "P1099_L03",
      "原文": "君不见东吴顾文学，君不见西汉杜陵老。"
    },
    {
      "诗行编号": "P1099_L04",
      "原文": "诗家笔势君不嫌，词翰升堂为君埽。"
    },
    {
      "诗行编号": "P1099_L05",
      "原文": "诗家笔势君不嫌，词翰升堂为君域。"
    },
    {
      "诗行编号": "P1099_L06",
      "原文": "是日霜风冻七泽，乌蛮落照衔赤壁。"
    },
    {
      "诗行编号": "P1099_L07",
      "原文": "酒酣耳热忘头白，感君意气无所惜，一为歌行歌主客。"
    }
  ],
