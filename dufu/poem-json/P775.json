  "诗行": [
    {
      "诗行编号": "P775_L01",
      "原文": "汝性不茹荤，清静仆夫内。"
    },
    {
      "诗行编号": "P775_L02",
      "原文": "秉心识本源，于事少滞碍。"
    },
    {
      "诗行编号": "P775_L03",
      "原文": "云端水筒坼，林表山石碎。"
    },
    {
      "诗行编号": "P775_L04",
      "原文": "触热藉子修，通流与厨会。"
    },
    {
      "诗行编号": "P775_L05",
      "原文": "往来四十里，荒险崖谷大。"
    },
    {
      "诗行编号": "P775_L06",
      "原文": "日熏惊未餐，貌赤愧相对。"
    },
    {
      "诗行编号": "P775_L07",
      "原文": "浮瓜供老病，裂饼尝所爱。"
    },
    {
      "诗行编号": "P775_L08",
      "原文": "于斯荅恭谨，足以殊殿最。"
    },
    {
      "诗行编号": "P775_L09",
      "原文": "讵要方士符，何假将军盖。"
    },
    {
      "诗行编号": "P775_L10",
      "原文": "行诸直如笔，用意崎岖外。"
    }
  ],
