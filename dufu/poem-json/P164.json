  "诗行": [
    {
      "诗行编号": "P164_L01",
      "原文": "苍山入百里，崖断如杵臼。"
    },
    {
      "诗行编号": "P164_L02",
      "原文": "曾宫凭风回，岌嶪土囊口。"
    },
    {
      "诗行编号": "P164_L03",
      "原文": "立神扶栋梁，凿翠开户牖。"
    },
    {
      "诗行编号": "P164_L04",
      "原文": "其阳产灵芝，其阴宿牛斗。"
    },
    {
      "诗行编号": "P164_L05",
      "原文": "纷披长松倒，揭屼怪石走。"
    },
    {
      "诗行编号": "P164_L06",
      "原文": "哀猿啼一声，客泪迸林薮。"
    },
    {
      "诗行编号": "P164_L07",
      "原文": "荒哉隋家帝，制此今颓朽。"
    },
    {
      "诗行编号": "P164_L08",
      "原文": "向使国不亡，焉为巨唐有。"
    },
    {
      "诗行编号": "P164_L09",
      "原文": "虽无新增修，尚置官居守。"
    },
    {
      "诗行编号": "P164_L10",
      "原文": "巡非瑶水远，迹是雕墙后。"
    },
    {
      "诗行编号": "P164_L11",
      "原文": "我行属时危，仰望嗟叹久。"
    },
    {
      "诗行编号": "P164_L12",
      "原文": "天王守太白，驻马更搔首。"
    }
  ],
