  "诗行": [
    {
      "诗行编号": "P623_L01",
      "原文": "得归茅屋赴成都，直为文翁再剖符。"
    },
    {
      "诗行编号": "P623_L02",
      "原文": "但使闾阎还揖让，敢论松竹久荒芜。"
    },
    {
      "诗行编号": "P623_L03",
      "原文": "鱼知丙穴由来美，酒忆郫筒不用酤。"
    },
    {
      "诗行编号": "P623_L04",
      "原文": "五马旧曾谙小径，几回书札待潜夫。"
    }
  ],
