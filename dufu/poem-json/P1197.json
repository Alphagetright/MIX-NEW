  "诗行": [
    {
      "诗行编号": "P1197_L01",
      "原文": "湖南为客动经春，"
    },
    {
      "诗行编号": "P1197_L02",
      "原文": "燕子衔泥两度新。"
    },
    {
      "诗行编号": "P1197_L03",
      "原文": "旧入故园常识主，"
    },
    {
      "诗行编号": "P1197_L04",
      "原文": "如今社日远看人。"
    },
    {
      "诗行编号": "P1197_L05",
      "原文": "可怜处处巢君室，"
    },
    {
      "诗行编号": "P1197_L06",
      "原文": "何异飘飘托此身。"
    },
    {
      "诗行编号": "P1197_L07",
      "原文": "暂语船樯还起去，"
    },
    {
      "诗行编号": "P1197_L08",
      "原文": "穿花落水益沾巾。"
    }
  ],
