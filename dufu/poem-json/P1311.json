  "诗行": [
    {
      "诗行编号": "P1311_L01",
      "原文": "南极老人自有星，北山移文谁勒铭。"
    },
    {
      "诗行编号": "P1311_L02",
      "原文": "徵君已去独松菊，哀壑无光留户庭。"
    },
    {
      "诗行编号": "P1311_L03",
      "原文": "予见乱离不得已，子知出处必须经。"
    },
    {
      "诗行编号": "P1311_L04",
      "原文": "高车驷马带倾覆，怅望秋天虚翠屏。"
    },
    {
      "诗行编号": "P1311_L05",
      "原文": "高车驷马带傾覆，怅望秋天虚翠屏。"
