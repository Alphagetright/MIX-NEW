  "诗行": [
    {
      "诗行编号": "P1032_L01",
      "原文": "高唐暮冬雪壮哉"
    },
    {
      "诗行编号": "P1032_L02",
      "原文": "旧瘴无复似尘埃"
    },
    {
      "诗行编号": "P1032_L03",
      "原文": "崖沈谷没白皑皑"
    },
    {
      "诗行编号": "P1032_L04",
      "原文": "江石缺裂青枫摧"
    },
    {
      "诗行编号": "P1032_L05",
      "原文": "南天三旬苦雾开"
    },
    {
      "诗行编号": "P1032_L06",
      "原文": "赤日照耀从西来"
    },
    {
      "诗行编号": "P1032_L07",
      "原文": "六龙寒急光裴回"
    },
    {
      "诗行编号": "P1032_L08",
      "原文": "照我衰颜忽落地"
    },
    {
      "诗行编号": "P1032_L09",
      "原文": "口虽吟咏心中哀"
    },
    {
      "诗行编号": "P1032_L10",
      "原文": "未怪及时少年子"
    },
    {
      "诗行编号": "P1032_L11",
      "原文": "扬眉结义黄金台"
    },
    {
      "诗行编号": "P1032_L12",
      "原文": "洎乎吾生何飘零"
    },
    {
      "诗行编号": "P1032_L13",
      "原文": "支离委绝同死灰"
    }
  ],
