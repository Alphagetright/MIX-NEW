  "诗行": [
    {
      "诗行编号": "P1146_L01",
      "原文": "午辞空灵岑，夕得花石戍。"
    },
    {
      "诗行编号": "P1146_L02",
      "原文": "岸疏开辟水，木杂今古树。"
    },
    {
      "诗行编号": "P1146_L03",
      "原文": "地蒸南风盛，春热西日暮。"
    },
    {
      "诗行编号": "P1146_L04",
      "原文": "四序本平分，气候何回互。"
    },
    {
      "诗行编号": "P1146_L05",
      "原文": "茫茫天造间，理乱岂恒数。"
    },
    {
      "诗行编号": "P1146_L06",
      "原文": "系舟盘藤轮，策杖古樵路。"
    },
    {
      "诗行编号": "P1146_L07",
      "原文": "罢人不在村，野圃泉自注。"
    },
    {
      "诗行编号": "P1146_L08",
      "原文": "柴扉虽芜没，农器尚牢固。"
    },
    {
      "诗行编号": "P1146_L09",
      "原文": "山东残逆气，吴楚守王度。"
    },
    {
      "诗行编号": "P1146_L10",
      "原文": "谁能扣君门，下令减征赋。"
    }
  ],
