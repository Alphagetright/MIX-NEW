  "诗行": [
    {
      "诗行编号": "P1158_L01",
      "原文": "自罢千秋节，频伤八月来。"
    },
    {
      "诗行编号": "P1158_L02",
      "原文": "先朝常宴会，壮观已尘埃。"
    },
    {
      "诗行编号": "P1158_L03",
      "原文": "凤纪编生日，龙池堑劫灰。"
    },
    {
      "诗行编号": "P1158_L04",
      "原文": "湘川新涕泪，秦树远楼台。"
    },
    {
      "诗行编号": "P1158_L05",
      "原文": "宝镜群臣得，金吾万国回。"
    },
    {
      "诗行编号": "P1158_L06",
      "原文": "衢尊不重饮，白首独馀哀。"
    }
  ],
