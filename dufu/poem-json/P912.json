      "原文": "丈夫盖棺事始定"
    },
    {
      "诗行编号": "P912_L06",
      "原文": "君今幸未成老翁"
    },
    {
      "诗行编号": "P912_L07",
      "原文": "何恨憔悴在山中"
    },
