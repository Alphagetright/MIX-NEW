  "诗行": [
    {
      "诗行编号": "P1067_L01",
      "原文": "郊扉俗远长幽寂"
    },
    {
      "诗行编号": "P1067_L02",
      "原文": "野水春来更接连"
    },
    {
      "诗行编号": "P1067_L03",
      "原文": "锦席淹留还出浦"
    },
    {
      "诗行编号": "P1067_L04",
      "原文": "葛巾欹侧未回船"
    },
    {
      "诗行编号": "P1067_L05",
      "原文": "尊当霞绮轻初散"
    },
    {
      "诗行编号": "P1067_L06",
      "原文": "棹拂荷珠碎却圆"
    },
    {
      "诗行编号": "P1067_L07",
      "原文": "尊当霞綺轻初散"
    },
    {
      "诗行编号": "P1067_L08",
      "原文": "棹拂荷珠碎却圆"
    },
    {
