  "诗行": [
    {
      "诗行编号": "P1159_L01",
      "原文": "御气云楼敞，含风?仗高。"
    },
    {
      "诗行编号": "P1159_L02",
      "原文": "仙人张内乐，王母献宫桃。"
    },
    {
      "诗行编号": "P1159_L03",
      "原文": "罗袜红蕖艳，金羁白雪毛。"
    },
    {
      "诗行编号": "P1159_L04",
      "原文": "舞阶衔寿酒，走索背秋毫。"
    },
    {
      "诗行编号": "P1159_L05",
      "原文": "圣主他年贵，边心此日劳。"
    },
    {
      "诗行编号": "P1159_L06",
      "原文": "桂江流向北，满眼送波涛。"
    }
  ],
