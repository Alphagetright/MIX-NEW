  "诗行": [
    {
      "诗行编号": "P283_L01",
      "原文": "亭亭凤凰台，北对西康州。"
    },
    {
      "诗行编号": "P283_L02",
      "原文": "西伯今寂寞，凰声亦悠悠。"
    },
    {
      "诗行编号": "P283_L03",
      "原文": "山峻路绝踪，石林气高浮。"
    },
    {
      "诗行编号": "P283_L04",
      "原文": "安得万丈梯，为君上上头。"
    },
    {
      "诗行编号": "P283_L05",
      "原文": "恐有无母雏，饥寒日啾啾。"
    },
    {
      "诗行编号": "P283_L06",
      "原文": "我能剖心出，饮啄慰孤愁。"
    },
    {
      "诗行编号": "P283_L07",
      "原文": "心以当竹实，炯然无外求。"
    },
    {
      "诗行编号": "P283_L08",
      "原文": "血以当醴泉，岂徒比清流。"
    },
    {
      "诗行编号": "P283_L09",
      "原文": "所贵王者瑞，敢辞微命休。"
    },
    {
      "诗行编号": "P283_L10",
      "原文": "坐看飞翮长，举意八极周。"
    },
    {
      "诗行编号": "P283_L11",
      "原文": "自天衔瑞图，飞下十二楼。"
    },
    {
      "诗行编号": "P283_L12",
      "原文": "图以奉至尊，凤以垂鸿猷。"
    },
    {
      "诗行编号": "P283_L13",
      "原文": "再光中兴业，一洗苍生忧。"
    },
    {
      "诗行编号": "P283_L14",
      "原文": "深衷正为此，群盗何淹留。"
    }
  ],
