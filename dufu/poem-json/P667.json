  "诗行": [
    {
      "诗行编号": "P667_L01",
      "原文": "闻道君牙帐"
    },
    {
      "诗行编号": "P667_L02",
      "原文": "防秋近赤霄"
    },
    {
      "诗行编号": "P667_L03",
      "原文": "下临千雪岭"
    },
    {
      "诗行编号": "P667_L04",
      "原文": "却背五绳桥"
    },
    {
      "诗行编号": "P667_L05",
      "原文": "海内久戎服"
    },
    {
      "诗行编号": "P667_L06",
      "原文": "京师今晏朝"
    },
    {
      "诗行编号": "P667_L07",
      "原文": "犬羊曾烂熳"
    },
    {
      "诗行编号": "P667_L08",
      "原文": "宫阙尚萧条"
    },
    {
      "诗行编号": "P667_L09",
      "原文": "猛将宜尝胆"
    },
    {
      "诗行编号": "P667_L10",
      "原文": "龙泉必在腰"
    },
    {
      "诗行编号": "P667_L11",
      "原文": "黄图遭污辱"
    },
    {
      "诗行编号": "P667_L12",
      "原文": "月窟可焚烧"
    },
    {
      "诗行编号": "P667_L13",
      "原文": "会取干戈利"
    },
    {
      "诗行编号": "P667_L14",
      "原文": "无令斥候骄"
    },
    {
      "诗行编号": "P667_L15",
      "原文": "居然双捕虏"
    },
    {
      "诗行编号": "P667_L16",
      "原文": "自是一嫖姚"
    },
    {
      "诗行编号": "P667_L17",
      "原文": "落日思轻骑"
    },
    {
      "诗行编号": "P667_L18",
      "原文": "高天忆射雕"
    },
    {
      "诗行编号": "P667_L19",
      "原文": "云台画形像"
    },
    {
      "诗行编号": "P667_L20",
      "原文": "皆为扫氛妖"
    }
  ],
