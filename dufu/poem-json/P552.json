      "诗行编号": "P552_L01",
      "原文": "子弟犹深入，关城未解围。"
    },
    {
      "诗行编号": "P552_L02",
      "原文": "蚕崖铁马瘦，灌口米船稀。"
    },
    {
      "诗行编号": "P552_L03",
      "原文": "辩士安边策，元戎决胜威。"
    },
    {
      "诗行编号": "P552_L04",
      "原文": "今朝乌鹊喜，欲报凯歌归。"
    }
