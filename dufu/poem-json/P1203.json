  "诗行": [
    {
      "诗行编号": "P1203_L01",
      "原文": "五十头白翁，南北逃世难。"
    },
    {
      "诗行编号": "P1203_L02",
      "原文": "疏布缠枯骨，奔走苦不暖。"
    },
    {
      "诗行编号": "P1203_L03",
      "原文": "已衰病方入，四海一涂炭。"
    },
    {
      "诗行编号": "P1203_L04",
      "原文": "乾坤万里内，莫见容身畔。"
    },
    {
      "诗行编号": "P1203_L05",
      "原文": "妻孥复随我，回首共悲欢。"
    },
    {
      "诗行编号": "P1203_L06",
      "原文": "故国莽丘墟，邻里各分散。"
    },
    {
      "诗行编号": "P1203_L07",
      "原文": "归路从此迷，涕尽湘江岸。"
    }
  ],
