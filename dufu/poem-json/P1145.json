  "诗行": [
    {
      "诗行编号": "P1145_L01",
      "原文": "沄沄逆素浪，落落展清眺。"
    },
    {
      "诗行编号": "P1145_L02",
      "原文": "幸有舟楫迟，得尽所历妙。"
    },
    {
      "诗行编号": "P1145_L03",
      "原文": "空灵霞石峻，枫栝隐奔峭。"
    },
    {
      "诗行编号": "P1145_L04",
      "原文": "青春犹无私，白日亦偏照。"
    },
    {
      "诗行编号": "P1145_L05",
      "原文": "可使营吾居，终焉托长啸。"
    },
    {
      "诗行编号": "P1145_L06",
      "原文": "毒瘴未足忧，兵戈满边徼。"
    },
    {
      "诗行编号": "P1145_L07",
      "原文": "向者留遗恨，耻为达人诮。"
    },
    {
      "诗行编号": "P1145_L08",
      "原文": "回帆凯赏延，佳处领其要。"
    }
  ],
