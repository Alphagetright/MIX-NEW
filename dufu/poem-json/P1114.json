  "诗行": [
    {
      "诗行编号": "P1114_L01",
      "原文": "岁云暮矣多北风，潇湘洞庭白雪中。"
    },
    {
      "诗行编号": "P1114_L02",
      "原文": "渔父天寒网罟冻，莫徭射雁鸣桑弓。"
    },
    {
      "诗行编号": "P1114_L03",
      "原文": "去年米贵阙军食，今年米贱大伤农。"
    },
    {
      "诗行编号": "P1114_L04",
      "原文": "高马达官厌酒肉，此辈杼轴茅茨空。"
    },
    {
      "诗行编号": "P1114_L05",
      "原文": "楚人重鱼不重鸟，汝休枉杀南飞鸿。"
    },
    {
      "诗行编号": "P1114_L06",
      "原文": "况闻处处鬻男女，割慈忍爱还租庸。"
    },
    {
      "诗行编号": "P1114_L07",
      "原文": "往日用钱捉私铸，今许铅锡和青铜。"
    },
    {
      "诗行编号": "P1114_L08",
      "原文": "刻泥为之最易得，好恶不合长相蒙。"
    },
    {
      "诗行编号": "P1114_L09",
      "原文": "万国城头吹画角，此曲哀怨何时终。"
    }
  ],
