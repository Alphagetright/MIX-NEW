  "诗行": [
    {
      "诗行编号": "P530_L01",
      "原文": "中军待上客，令肃事有恒。"
    },
    {
      "诗行编号": "P530_L02",
      "原文": "前驱入宝地，祖帐飘金绳。"
    },
    {
      "诗行编号": "P530_L03",
      "原文": "南陌既留欢，兹山亦深登。"
    },
    {
      "诗行编号": "P530_L04",
      "原文": "清闻树杪磬，远谒云端僧。"
    },
    {
      "诗行编号": "P530_L05",
      "原文": "回策匪新岸，所攀仍旧藤。"
    },
    {
      "诗行编号": "P530_L06",
      "原文": "耳激洞门飙，目存寒谷冰。"
    },
    {
      "诗行编号": "P530_L07",
      "原文": "出尘閟轨躅，毕景遗炎蒸。"
    },
    {
      "诗行编号": "P530_L08",
      "原文": "永愿坐长夏，将衰栖大乘。"
    },
    {
      "诗行编号": "P530_L09",
      "原文": "羁旅惜宴会，艰难怀友朋。"
    },
    {
      "诗行编号": "P530_L10",
      "原文": "劳生共几何，离恨兼相仍。"
    }
  ],
