  "诗行": [
    {
      "诗行编号": "P524_L01",
      "原文": "市人日中集，于利竞锥刀。"
    },
    {
      "诗行编号": "P524_L02",
      "原文": "置膏烈火上，哀哀自煎熬。"
    },
    {
      "诗行编号": "P524_L03",
      "原文": "农人望岁稔，相率除蓬蒿。"
    },
    {
      "诗行编号": "P524_L04",
      "原文": "所务谷为本，邪赢无乃劳。"
    },
    {
      "诗行编号": "P524_L05",
      "原文": "舜举十六相，身尊道何高。"
    },
    {
      "诗行编号": "P524_L06",
      "原文": "秦时任商鞅，法令如牛毛。"
    }
  ],
