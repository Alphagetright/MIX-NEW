  "诗行": [
    {
      "诗行编号": "P638_L01",
      "原文": "花近高楼伤客心，万方多难此登临。"
    },
    {
      "诗行编号": "P638_L02",
      "原文": "锦江春色来天地，玉垒浮云变古今。"
    },
    {
      "诗行编号": "P638_L03",
      "原文": "北极朝廷终不改，西山寇盗莫相侵。"
    },
    {
      "诗行编号": "P638_L04",
      "原文": "可怜后主还祠庙，日暮聊为梁甫吟。"
    }
  ],
