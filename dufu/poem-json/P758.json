  "诗行": [
    {
      "诗行编号": "P758_L01",
      "原文": "江城含变态，一上一回新。"
    },
    {
      "诗行编号": "P758_L02",
      "原文": "天欲今朝雨，山归万古春。"
    },
    {
      "诗行编号": "P758_L03",
      "原文": "英雄馀事业，衰迈久风尘。"
    },
    {
      "诗行编号": "P758_L04",
      "原文": "取醉他乡客，相逢故国人。"
    },
    {
      "诗行编号": "P758_L05",
      "原文": "兵戈犹拥蜀，赋敛强输秦。"
    },
    {
      "诗行编号": "P758_L06",
      "原文": "不是烦形胜，深惭畏损神。"
    }
  ],
