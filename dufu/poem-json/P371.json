    {
      "诗行编号": "P371_L01",
      "原文": "南京久客耕南亩，北望伤神坐北窗。"
    },
    {
      "诗行编号": "P371_L02",
      "原文": "昼引老妻乘小艇，晴看稚子浴清江。"
    },
    {
      "诗行编号": "P371_L03",
      "原文": "俱飞蛱蝶元相逐，并蒂芙蓉本自双。"
    },
    {
      "诗行编号": "P371_L04",
      "原文": "茗饮蔗浆携所有，瓷罂无谢玉为缸。"
    }
