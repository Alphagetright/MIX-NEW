  "诗行": [
    {
      "诗行编号": "P1081_L01",
      "原文": "西北楼成雄楚都"
    },
    {
      "诗行编号": "P1081_L02",
      "原文": "远开山岳散江湖"
    },
    {
      "诗行编号": "P1081_L03",
      "原文": "二仪清浊还高下"
    },
    {
      "诗行编号": "P1081_L04",
      "原文": "三伏炎蒸定有无"
    },
    {
      "诗行编号": "P1081_L05",
      "原文": "推毂几年唯镇静"
    },
    {
      "诗行编号": "P1081_L06",
      "原文": "曳裾终日盛文儒"
    },
    {
      "诗行编号": "P1081_L07",
      "原文": "白头授简焉能赋"
    },
    {
      "诗行编号": "P1081_L08",
      "原文": "愧似相如为大夫"
    }
  ],
