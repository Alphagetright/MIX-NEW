  "诗行": [
    {
      "诗行编号": "P1183_L01",
      "原文": "天下郡国向万城，无有一城无甲兵。"
    },
    {
      "诗行编号": "P1183_L02",
      "原文": "焉得铸甲作农器，一寸荒田牛得耕。"
    },
    {
      "诗行编号": "P1183_L03",
      "原文": "牛尽耕，蚕亦成。"
    },
    {
      "诗行编号": "P1183_L04",
      "原文": "不劳烈士泪滂沱，男谷女丝行复歌。"
    }
  ],
