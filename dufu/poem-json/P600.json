    {
      "诗行编号": "P600_L01",
      "原文": "阆州城中灵山白，阆州城北玉台碧。"
    },
    {
      "诗行编号": "P600_L02",
      "原文": "松浮欲尽不尽云，江动将崩未崩石。"
    },
    {
      "诗行编号": "P600_L03",
      "原文": "那知根无鬼神会，已觉气与嵩华敌。"
    },
    {
      "诗行编号": "P600_L04",
      "原文": "中原格斗且未归，应结茅斋看青壁。"
    }
