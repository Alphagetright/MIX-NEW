  "诗行": [
    {
      "诗行编号": "P278_L01",
      "原文": "塞外苦厌山，南行道弥恶。"
    },
    {
      "诗行编号": "P278_L02",
      "原文": "冈峦相经亘，云水气参错。"
    },
    {
      "诗行编号": "P278_L03",
      "原文": "林迥硖角来，天窄壁面削。"
    },
    {
      "诗行编号": "P278_L04",
      "原文": "溪西五里石，奋怒向我落。"
    },
    {
      "诗行编号": "P278_L05",
      "原文": "仰看日车侧，俯恐坤轴弱。"
    },
    {
      "诗行编号": "P278_L06",
      "原文": "魑魅啸有风，霜霰浩漠漠。"
    },
    {
      "诗行编号": "P278_L07",
      "原文": "昨忆踰陇坂，高秋视吴岳。"
    },
    {
      "诗行编号": "P278_L08",
      "原文": "东笑莲华卑，北知崆峒薄。"
    },
    {
      "诗行编号": "P278_L09",
      "原文": "超然侔壮观，已谓殷寥廓。"
    },
    {
      "诗行编号": "P278_L10",
      "原文": "突兀犹趁人，及兹叹冥莫。"
    }
  ],
