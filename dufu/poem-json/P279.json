  "诗行": [
    {
      "诗行编号": "P279_L01",
      "原文": "细泉兼轻冰，沮洳栈道湿。"
    },
    {
      "诗行编号": "P279_L02",
      "原文": "不辞辛苦行，迫此短景急。"
    },
    {
      "诗行编号": "P279_L03",
      "原文": "石门雪云隘，古镇峰峦集。"
    },
    {
      "诗行编号": "P279_L04",
      "原文": "旌竿暮惨澹，风水白刃涩。"
    },
    {
      "诗行编号": "P279_L05",
      "原文": "胡马屯成皋，防虞此何及。"
    },
    {
      "诗行编号": "P279_L06",
      "原文": "嗟尔远戍人，山寒夜中泣。"
    }
  ],
