  "诗行": [
    {
      "诗行编号": "P1235_L01",
      "原文": "国有乾坤大，王今叔父尊。"
    },
    {
      "诗行编号": "P1235_L02",
      "原文": "剖符来蜀道，归盖取荆门。"
    },
    {
      "诗行编号": "P1235_L03",
      "原文": "峡险通舟过，江长注海奔。"
    },
    {
      "诗行编号": "P1235_L04",
      "原文": "主人留上客，避暑得名园。"
    },
    {
      "诗行编号": "P1235_L05",
      "原文": "前后缄书报，分明馔玉恩。"
    },
    {
      "诗行编号": "P1235_L06",
      "原文": "天云浮绝壁，风竹在华轩。"
    },
    {
      "诗行编号": "P1235_L07",
      "原文": "已觉良宵永，何看骇浪翻。"
    },
    {
      "诗行编号": "P1235_L08",
      "原文": "入期朱邸雪，朝傍紫微垣。"
    },
    {
      "诗行编号": "P1235_L09",
      "原文": "枚乘文章老，河间礼乐存。"
    },
    {
      "诗行编号": "P1235_L10",
      "原文": "悲秋宋玉宅，失路武陵源。"
    },
    {
      "诗行编号": "P1235_L11",
      "原文": "淹薄俱崖口，东西异石根。"
    },
    {
      "诗行编号": "P1235_L12",
      "原文": "夷音迷咫尺，鬼物傍黄昏。"
    },
    {
      "诗行编号": "P1235_L13",
      "原文": "犬马诚为恋，狐狸不足论。"
    },
    {
      "诗行编号": "P1235_L14",
      "原文": "从容草奏罢，宿昔奉清樽。"
    }
  ],
