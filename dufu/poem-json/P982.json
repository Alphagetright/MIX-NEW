  "诗行": [
    {
      "诗行编号": "P982_L01",
      "原文": "高栋曾轩已自凉，秋风此日洒衣裳。"
    },
    {
      "诗行编号": "P982_L02",
      "原文": "翛然欲下阴山雪，不去非无汉署香。"
    },
    {
      "诗行编号": "P982_L03",
      "原文": "绝壁过云开锦绣，疏松夹水奏笙簧。"
    },
    {
      "诗行编号": "P982_L04",
      "原文": "看君宜著王乔履，真赐还疑出尚方。"
    }
  ],
