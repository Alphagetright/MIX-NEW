  "诗行": [
    {
      "诗行编号": "P219_L01",
      "原文": "士卒何草草，筑城潼关道。"
    },
    {
      "诗行编号": "P219_L02",
      "原文": "大城铁不如，小城万丈馀。"
    },
    {
      "诗行编号": "P219_L03",
      "原文": "借问潼关吏，修关还备胡。"
    },
    {
      "诗行编号": "P219_L04",
      "原文": "要我下马行，为我指山隅。"
    },
    {
      "诗行编号": "P219_L05",
      "原文": "连云列战格，飞鸟不能踰。"
    },
    {
      "诗行编号": "P219_L06",
      "原文": "胡来但自守，岂复忧西都。"
    },
    {
      "诗行编号": "P219_L07",
      "原文": "丈人视要处，窄狭容单车。"
    },
    {
      "诗行编号": "P219_L08",
      "原文": "艰难奋长戟，万古用一夫。"
    },
    {
      "诗行编号": "P219_L09",
      "原文": "哀哉桃林战，百万化为鱼。"
    },
    {
      "诗行编号": "P219_L10",
      "原文": "请嘱防关将，慎勿学哥舒。"
    }
  ],
