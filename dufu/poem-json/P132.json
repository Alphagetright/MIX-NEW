  "诗行": [
    {
      "诗行编号": "P132_L01",
      "原文": "鸡鸣风雨交，久旱云亦好。"
    },
    {
      "诗行编号": "P132_L02",
      "原文": "杖藜入春泥，无食起我早。"
    },
    {
      "诗行编号": "P132_L03",
      "原文": "诸家忆所历，一饭迹便埽。"
    },
    {
      "诗行编号": "P132_L04",
      "原文": "诸家憶所历，一饭迹便埽。"
    },
    {
      "诗行编号": "P132_L05",
      "原文": "苏侯得数过，欢喜每倾倒。"
    },
    {
      "诗行编号": "P132_L06",
      "原文": "也复可怜人，呼儿具梨枣。"
    },
    {
      "诗行编号": "P132_L07",
      "原文": "浊醪必在眼，尽醉摅怀抱。"
    },
    {
      "诗行编号": "P132_L08",
      "原文": "红稠屋角花，碧委墙隅草。"
    },
    {
      "诗行编号": "P132_L09",
      "原文": "亲宾纵谈谑，喧闹畏衰老。"
    },
    {
      "诗行编号": "P132_L10",
      "原文": "况蒙霈泽垂，粮粒或自保。"
    },
    {
      "诗行编号": "P132_L11",
      "原文": "妻孥隔军垒，拨弃不拟道。"
    }
  ],
