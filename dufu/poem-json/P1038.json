  "诗行": [
    {
      "诗行编号": "P1038_L01",
      "原文": "觅句新知律，摊书解满床。"
    },
    {
      "诗行编号": "P1038_L02",
      "原文": "试吟青玉案，莫羡紫罗囊。"
    },
    {
      "诗行编号": "P1038_L03",
      "原文": "假日从时饮，明年共我长。"
    },
    {
      "诗行编号": "P1038_L04",
      "原文": "应须饱经术，已似爱文章。"
    },
    {
      "诗行编号": "P1038_L05",
      "原文": "十五男儿志，三千弟子行。"
    },
    {
      "诗行编号": "P1038_L06",
      "原文": "曾参与游夏，达者得升堂。"
    }
  ],
