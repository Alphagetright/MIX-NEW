  "诗行": [
    {
      "诗行编号": "P966_L01",
      "原文": "清晨蒙菜把，常荷地主恩。"
    },
    {
      "诗行编号": "P966_L02",
      "原文": "守者愆实数，略有其名存。"
    },
    {
      "诗行编号": "P966_L03",
      "原文": "苦苣刺如针，马齿叶亦繁。"
    },
    {
      "诗行编号": "P966_L04",
      "原文": "青青嘉蔬色，埋没在中园。"
    },
    {
      "诗行编号": "P966_L05",
      "原文": "园吏未足怪，世事固堪论。"
    },
    {
      "诗行编号": "P966_L06",
      "原文": "呜呼战伐久，荆棘暗长原。"
    },
    {
      "诗行编号": "P966_L07",
      "原文": "乃知苦苣辈，倾夺蕙草根。"
    },
    {
      "诗行编号": "P966_L08",
      "原文": "小人塞道路，为态何喧喧。"
    },
    {
      "诗行编号": "P966_L09",
      "原文": "又如马齿盛，气拥葵荏昏。"
    },
    {
      "诗行编号": "P966_L10",
      "原文": "点染不易虞，丝麻杂罗纨。"
    },
    {
      "诗行编号": "P966_L11",
      "原文": "一经器物内，永挂粗刺痕。"
    },
    {
      "诗行编号": "P966_L12",
      "原文": "志士采紫芝，放歌避戎轩。"
    },
    {
      "诗行编号": "P966_L13",
      "原文": "畦丁负笼至，感动百虑端。"
    }
  ],
