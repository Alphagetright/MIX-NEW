  "诗行": [
    {
      "诗行编号": "P1053_L01",
      "原文": "苔竹素所好，"
    },
    {
      "诗行编号": "P1053_L02",
      "原文": "萍蓬无定居。"
    },
    {
      "诗行编号": "P1053_L03",
      "原文": "远游长儿子，"
    },
    {
      "诗行编号": "P1053_L04",
      "原文": "几地别林庐。"
    },
    {
      "诗行编号": "P1053_L05",
      "原文": "杂蕊红相对，"
    },
    {
      "诗行编号": "P1053_L06",
      "原文": "他时锦不如。"
    },
    {
      "诗行编号": "P1053_L07",
      "原文": "具舟将出峡，"
    },
    {
      "诗行编号": "P1053_L08",
      "原文": "巡圃念携锄。"
    },
    {
      "诗行编号": "P1053_L09",
      "原文": "正月喧莺末，"
    },
    {
      "诗行编号": "P1053_L10",
      "原文": "兹辰放鹢初。"
    },
    {
      "诗行编号": "P1053_L11",
      "原文": "雪篱梅可折，"
    },
    {
      "诗行编号": "P1053_L12",
      "原文": "风榭柳微舒。"
    },
    {
      "诗行编号": "P1053_L13",
      "原文": "托赠卿家有，"
    },
    {
      "诗行编号": "P1053_L14",
      "原文": "因歌野兴疏。"
    },
    {
      "诗行编号": "P1053_L15",
      "原文": "残生逗江汉，"
    },
    {
      "诗行编号": "P1053_L16",
      "原文": "何处狎樵渔。"
    }
  ],
