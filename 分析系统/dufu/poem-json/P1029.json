    {
      "诗行编号": "P1029_L01",
      "原文": "去年白帝雪在山，今年白帝雪在地。"
    },
    {
      "诗行编号": "P1029_L02",
      "原文": "冻埋蛟龙南浦缩，寒刮肌肤北风利。"
    },
    {
      "诗行编号": "P1029_L03",
      "原文": "楚人四时皆麻衣，楚天万里无晶辉。"
    },
    {
      "诗行编号": "P1029_L04",
      "原文": "三足之乌足恐断，羲和送将何所归。"
    },
    {
      "诗行编号": "P1029_L05",
      "原文": "三足之乌足恐断，羲和送将何所歸。"
    }
