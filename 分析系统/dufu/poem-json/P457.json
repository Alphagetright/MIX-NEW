  "诗行": [
    {
      "诗行编号": "P457_L01",
      "原文": "姚公美政谁与俦，不减昔时陈太丘。"
    },
    {
      "诗行编号": "P457_L02",
      "原文": "邑中上客有柱史，多暇日陪骢马游。"
    },
    {
      "诗行编号": "P457_L03",
      "原文": "东山高顶罗珍羞，下顾城郭销我忧。"
    },
    {
      "诗行编号": "P457_L04",
      "原文": "清江白日落欲尽，复携美人登䌽舟。"
    },
    {
      "诗行编号": "P457_L05",
      "原文": "笛声愤怨哀中流，妙舞逶迤夜未休。"
    },
    {
      "诗行编号": "P457_L06",
      "原文": "灯前往往大鱼出，听曲低昂如有求。"
    },
    {
      "诗行编号": "P457_L07",
      "原文": "灯前往往大魚出，听曲低昂如有求。"
    },
    {
      "诗行编号": "P457_L08",
      "原文": "三更风起寒浪涌，取乐喧呼觉船重。"
    },
    {
      "诗行编号": "P457_L09",
      "原文": "满空星河光破碎，四座宾客色不动。"
    },
    {
      "诗行编号": "P457_L10",
      "原文": "请公临深莫相违，回船罢酒上马归。"
    },
    {
      "诗行编号": "P457_L11",
      "原文": "人生欢会岂有极，无使霜过沾人衣。"
