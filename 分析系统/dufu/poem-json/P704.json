  "诗行": [
    {
      "诗行编号": "P704_L01",
      "原文": "我有阴江竹，能令朱夏寒。"
    },
    {
      "诗行编号": "P704_L02",
      "原文": "阴通积水内，高入浮云端。"
    },
    {
      "诗行编号": "P704_L03",
      "原文": "甚疑鬼物凭，不顾剪伐残。"
    },
    {
      "诗行编号": "P704_L04",
      "原文": "东偏若面势，户牖永可安。"
    },
    {
      "诗行编号": "P704_L05",
      "原文": "爱惜已六载，兹晨去千竿。"
    },
    {
      "诗行编号": "P704_L06",
      "原文": "萧萧见白日，汹汹开奔湍。"
    },
    {
      "诗行编号": "P704_L07",
      "原文": "度堂匪华丽，养拙异考槃。"
    },
    {
      "诗行编号": "P704_L08",
      "原文": "草茅虽薙葺，衰疾方少宽。"
    },
    {
      "诗行编号": "P704_L09",
      "原文": "洗然顺所适，此足代加餐。"
    },
    {
      "诗行编号": "P704_L10",
      "原文": "寂无斤斧响，庶遂憩息欢。"
    }
  ],
  "意象关系": [
