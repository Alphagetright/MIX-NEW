    {
      "诗行编号": "P1218_L01",
      "原文": "昔在洛阳时，亲友相追攀。"
    },
    {
      "诗行编号": "P1218_L02",
      "原文": "送客东郊道，遨游宿南山。"
    },
    {
      "诗行编号": "P1218_L03",
      "原文": "烟尘阻长河，树羽成皋间。"
    },
    {
      "诗行编号": "P1218_L04",
      "原文": "回首载酒地，岂无一日还？"
    },
    {
      "诗行编号": "P1218_L05",
      "原文": "丈夫贵壮健，惨戚非朱颜。"
    }
