  "诗行": [
    {
      "诗行编号": "P1073_L01",
      "原文": "爱客尚书贵，之官宅相贤。"
    },
    {
      "诗行编号": "P1073_L02",
      "原文": "酒香倾坐侧，帆影驻江边。"
    },
    {
      "诗行编号": "P1073_L03",
      "原文": "翟表郎官瑞，凫看令宰仙。"
    },
    {
      "诗行编号": "P1073_L04",
      "原文": "雨稀云叶断，夜久烛花偏。"
    },
    {
      "诗行编号": "P1073_L05",
      "原文": "数语敧纱帽，高文掷彩笺。"
    },
    {
      "诗行编号": "P1073_L06",
      "原文": "兴饶行处乐，离惜醉中眠。"
    },
    {
      "诗行编号": "P1073_L07",
      "原文": "单父长多暇，河阳实少年。"
    },
    {
      "诗行编号": "P1073_L08",
      "原文": "客居逢自出，为别几悽然。"
    }
  ],
