  "诗行": [
    {
      "诗行编号": "P1137_L01",
      "原文": "此身飘泊苦西东，右臂偏枯半耳聋。"
    },
    {
      "诗行编号": "P1137_L02",
      "原文": "寂寂系舟双下泪，悠悠伏枕左书空。"
    },
    {
      "诗行编号": "P1137_L03",
      "原文": "十年蹴鞠将雏远，万里鞦韆习俗同。"
    },
    {
      "诗行编号": "P1137_L04",
      "原文": "十年蹴鞠将雏远，万里鞦韆習俗同。"
    },
    {
      "诗行编号": "P1137_L05",
      "原文": "旅雁上云归紫塞，家人钻火用青枫。"
    },
    {
      "诗行编号": "P1137_L06",
      "原文": "秦城楼阁烟花里，汉主山河锦绣中。"
    },
    {
      "诗行编号": "P1137_L07",
      "原文": "风水春来洞庭阔，白蘋愁杀白头翁。"
    }
  ],
