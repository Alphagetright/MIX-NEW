  "诗行": [
    {
      "诗行编号": "P1149_L01",
      "原文": "南岳配朱鸟，秩礼自百王。"
    },
    {
      "诗行编号": "P1149_L02",
      "原文": "歘吸领地灵，鸿洞半炎方。"
    },
    {
      "诗行编号": "P1149_L03",
      "原文": "邦家用祀典，在德非馨香。"
    },
    {
      "诗行编号": "P1149_L04",
      "原文": "巡守何寂寥，有虞今则亡。"
    },
    {
      "诗行编号": "P1149_L05",
      "原文": "洎吾隘世网，行迈越潇湘。"
    },
    {
      "诗行编号": "P1149_L06",
      "原文": "渴日绝壁出，漾舟清光旁。"
    },
    {
      "诗行编号": "P1149_L07",
      "原文": "祝融五峰尊，峰峰次低昂。"
    },
    {
      "诗行编号": "P1149_L08",
      "原文": "紫盖独不朝，争长嶪相望。"
    },
    {
      "诗行编号": "P1149_L09",
      "原文": "恭闻魏夫人，群仙夹翱翔。"
    },
    {
      "诗行编号": "P1149_L10",
      "原文": "有时五峰气，散风如飞霜。"
    },
    {
      "诗行编号": "P1149_L11",
      "原文": "牵迫限修途，未暇杖崇冈。"
    },
    {
      "诗行编号": "P1149_L12",
      "原文": "归来觊命驾，沐浴休玉堂。"
    },
    {
      "诗行编号": "P1149_L13",
      "原文": "三叹问府主，曷以赞我皇。"
    },
    {
      "诗行编号": "P1149_L14",
      "原文": "牲璧忍衰俗，神其思降祥。"
    }
  ],
