  "诗行": [
    {
      "诗行编号": "P422_L01",
      "原文": "汲黯匡君切，廉颇出将频。"
    },
    {
      "诗行编号": "P422_L02",
      "原文": "直词才不世，雄略动如神。"
    },
    {
      "诗行编号": "P422_L03",
      "原文": "政简移风速，诗清立意新。"
    },
    {
      "诗行编号": "P422_L04",
      "原文": "层城临暇景，绝域望馀春。"
    },
    {
      "诗行编号": "P422_L05",
      "原文": "旗尾蛟龙会，楼头燕雀驯。"
    },
    {
      "诗行编号": "P422_L06",
      "原文": "地平江动蜀，天阔树浮秦。"
    },
    {
      "诗行编号": "P422_L07",
      "原文": "帝念深分阃，军须远算缗。"
    },
    {
      "诗行编号": "P422_L08",
      "原文": "花罗封蛱蝶，瑞锦送麒麟。"
    },
    {
      "诗行编号": "P422_L09",
      "原文": "辞第输高义，观图忆古人。"
    },
    {
      "诗行编号": "P422_L10",
      "原文": "征南多兴绪，事业闇相亲。"
    }
  ],
