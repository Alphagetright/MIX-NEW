  "诗行": [
    {
      "诗行编号": "P1239_L01",
      "原文": "孤月当楼满，寒江动夜扉。"
    },
    {
      "诗行编号": "P1239_L02",
      "原文": "委波金不定，照席绮逾依。"
    },
    {
      "诗行编号": "P1239_L03",
      "原文": "未缺空山静，高悬列宿稀。"
    },
    {
      "诗行编号": "P1239_L04",
      "原文": "故园松桂发，万里共清辉。"
    }
  ],
