  "诗行": [
    {
      "诗行编号": "P276_L01",
      "原文": "行迈日悄悄"
    },
    {
      "诗行编号": "P276_L02",
      "原文": "山谷势多端"
    },
    {
      "诗行编号": "P276_L03",
      "原文": "云门转绝岸"
    },
    {
      "诗行编号": "P276_L04",
      "原文": "积阻霾天寒"
    },
    {
      "诗行编号": "P276_L05",
      "原文": "云门转绝岸寒硖不可度"
    },
    {
      "诗行编号": "P276_L06",
      "原文": "我实衣裳单"
    },
    {
      "诗行编号": "P276_L07",
      "原文": "况当仲冬交"
    },
    {
      "诗行编号": "P276_L08",
      "原文": "溯沿增波澜"
    },
    {
      "诗行编号": "P276_L09",
      "原文": "野人寻烟语"
    },
    {
      "诗行编号": "P276_L10",
      "原文": "行子傍水餐"
    },
    {
      "诗行编号": "P276_L11",
      "原文": "此生免荷殳"
    },
    {
      "诗行编号": "P276_L12",
      "原文": "未敢辞路难"
    }
  ],
