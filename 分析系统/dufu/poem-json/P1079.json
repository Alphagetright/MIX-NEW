      "原文": "风餐江柳下，雨卧驿楼边。"
    },
    {
      "诗行编号": "P1079_L02",
      "原文": "结缆排鱼网，连樯并米船。"
    },
    {
      "诗行编号": "P1079_L03",
      "原文": "今朝云细薄，昨夜月清圆。"
    },
    {
      "诗行编号": "P1079_L04",
      "原文": "飘泊南庭老，祗应学水仙。"
    }
