  "诗行": [
    {
      "诗行编号": "P305_L01",
      "原文": "君不见益州城西门，陌上石笋双高蹲。"
    },
    {
      "诗行编号": "P305_L02",
      "原文": "古来相传是海眼，苔藓蚀尽波涛痕。"
    },
    {
      "诗行编号": "P305_L03",
      "原文": "雨多往往得瑟瑟，此事恍惚难明论。"
    },
    {
      "诗行编号": "P305_L04",
      "原文": "恐是昔时卿相墓，立石为表今仍存。"
    },
    {
      "诗行编号": "P305_L05",
      "原文": "惜哉俗态好蒙蔽，亦如小臣媚至尊。"
    },
    {
      "诗行编号": "P305_L06",
      "原文": "政化错迕失大体，坐看倾危受厚恩。"
    },
    {
      "诗行编号": "P305_L07",
      "原文": "嗟尔石笋擅虚名，后来未识犹骏奔。"
    },
    {
      "诗行编号": "P305_L08",
      "原文": "安得壮士掷天外，使人不疑见本根。"
    }
  ],
