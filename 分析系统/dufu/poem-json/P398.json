  "诗行": [
    {
      "诗行编号": "P398_L01",
      "原文": "老夫卧稳朝慵起，白屋寒多暖始开。"
    },
    {
      "诗行编号": "P398_L02",
      "原文": "江鹳巧当幽径浴，邻鸡还过短墙来。"
    },
    {
      "诗行编号": "P398_L03",
      "原文": "绣衣屡许携家酝，皂盖能忘折野梅。"
    },
    {
      "诗行编号": "P398_L04",
      "原文": "戏假霜威促山简，须成一醉习池回。"
    }
  ],
