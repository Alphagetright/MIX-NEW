      "诗行编号": "P06_L01",
      "原文": "秋水清无底，萧然静客心。"
    },
    {
      "诗行编号": "P06_L02",
      "原文": "掾曹乘逸兴，鞍马去相寻。"
    },
    {
      "诗行编号": "P06_L03",
      "原文": "能吏逢联璧，华筵直一金。"
    },
    {
      "诗行编号": "P06_L04",
      "原文": "晚来横吹好，泓下亦龙吟。"
