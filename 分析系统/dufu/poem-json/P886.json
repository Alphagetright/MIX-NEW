  "诗行": [
    {
      "诗行编号": "P886_L01",
      "原文": "青青高槐叶，采掇付中厨。"
    },
    {
      "诗行编号": "P886_L02",
      "原文": "新面来近市，汁滓宛相俱。"
    },
    {
      "诗行编号": "P886_L03",
      "原文": "入鼎资过熟，加餐愁欲无。"
    },
    {
      "诗行编号": "P886_L04",
      "原文": "碧鲜俱照箸，香饭兼苞芦。"
    },
    {
      "诗行编号": "P886_L05",
      "原文": "经齿冷于雪，劝人投此珠。"
    },
    {
      "诗行编号": "P886_L06",
      "原文": "愿随金騕袅，走置锦屠苏。"
    },
    {
      "诗行编号": "P886_L07",
      "原文": "路远思恐泥，兴深终不渝。"
    },
    {
      "诗行编号": "P886_L08",
      "原文": "献芹则小小，荐藻明区区。"
    },
    {
      "诗行编号": "P886_L09",
      "原文": "万里露寒殿，开冰清玉壶。"
    },
    {
      "诗行编号": "P886_L10",
      "原文": "君王纳凉晚，此味亦时须。"
    }
  ],
