  "诗行": [
    {
      "诗行编号": "P522_L01",
      "原文": "赤骥顿长缨，非无万里姿。"
    },
    {
      "诗行编号": "P522_L02",
      "原文": "悲鸣泪至地，为问驭者谁。"
    },
    {
      "诗行编号": "P522_L03",
      "原文": "凤凰从东来，何意复高飞。"
    },
    {
      "诗行编号": "P522_L04",
      "原文": "竹花不结实，念子忍朝饥。"
    },
    {
      "诗行编号": "P522_L05",
      "原文": "古时君臣合，可以物理推。"
    },
    {
      "诗行编号": "P522_L06",
      "原文": "贤人识定分，进退固其宜。"
    }
  ],
