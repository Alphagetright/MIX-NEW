  "诗行": [
    {
      "诗行编号": "P1112_L01",
      "原文": "穷冬急风水，逆浪开帆难。"
    },
    {
      "诗行编号": "P1112_L02",
      "原文": "士子甘旨阙，不知道里寒。"
    },
    {
      "诗行编号": "P1112_L03",
      "原文": "有求彼乐土，南适小长安。"
    },
    {
      "诗行编号": "P1112_L04",
      "原文": "到我舟楫去，觉君衣裳单。"
    },
    {
      "诗行编号": "P1112_L05",
      "原文": "素闻赵公节，兼尽宾主欢。"
    },
    {
      "诗行编号": "P1112_L06",
      "原文": "已结门庐望，无令霜雪残。"
    },
    {
      "诗行编号": "P1112_L07",
      "原文": "老夫缆亦解，脱粟朝未餐。"
    },
    {
      "诗行编号": "P1112_L08",
      "原文": "飘荡兵甲际，几时怀抱宽。"
    },
    {
      "诗行编号": "P1112_L09",
      "原文": "汉阳颇宁静，岘首试考槃。"
    },
    {
      "诗行编号": "P1112_L10",
      "原文": "当念著白帽，采薇青云端。"
    }
  ],
