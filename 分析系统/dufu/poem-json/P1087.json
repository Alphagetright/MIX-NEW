    {
      "诗行编号": "P1087_L01",
      "原文": "霜黄碧梧白鹤栖，城上击柝复乌啼。"
    },
    {
      "诗行编号": "P1087_L02",
      "原文": "客子入门月皎皎，谁家捣练风凄凄。"
    },
    {
      "诗行编号": "P1087_L03",
      "原文": "南渡桂水阙舟楫，北归秦川多鼓鞞。"
    },
    {
      "诗行编号": "P1087_L04",
      "原文": "年过半百不称意，明日看云还杖藜。"
    }
  ],
