  "诗行": [
    {
      "诗行编号": "P382_L01",
      "原文": "倚江楠树草堂前，故老相传二百年。"
    },
    {
      "诗行编号": "P382_L02",
      "原文": "诛茅卜居总为此，五月髣髴闻寒蝉。"
    },
    {
      "诗行编号": "P382_L03",
      "原文": "东南飘风动地至，江翻石走流云气。"
    },
    {
      "诗行编号": "P382_L04",
      "原文": "干排雷雨犹力争，根断泉源岂天意。"
    },
    {
      "诗行编号": "P382_L05",
      "原文": "沧波老树性所爱，浦上童童一青盖。"
    },
    {
      "诗行编号": "P382_L06",
      "原文": "野客频留惧雪霜，行人不过听竽籁。"
    },
    {
      "诗行编号": "P382_L07",
      "原文": "虎倒龙颠委榛棘，泪痕血点垂胸臆。"
    },
    {
      "诗行编号": "P382_L08",
      "原文": "我有新诗何处吟，草堂自此无颜色。"
    }
  ],
