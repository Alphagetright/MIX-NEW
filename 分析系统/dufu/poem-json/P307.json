  "诗行": [
    {
      "诗行编号": "P307_L01",
      "原文": "十日画一水，五日画一石。"
    },
    {
      "诗行编号": "P307_L02",
      "原文": "能事不受相促迫，王宰始肯留真迹。"
    },
    {
      "诗行编号": "P307_L03",
      "原文": "壮哉昆崙方壶图，挂君高堂之素壁。"
    },
    {
      "诗行编号": "P307_L04",
      "原文": "巴陵洞庭日本东，赤岸水与银河通。"
    },
    {
      "诗行编号": "P307_L05",
      "原文": "中有云气随飞龙，舟人渔子入浦溆。"
    },
    {
      "诗行编号": "P307_L06",
      "原文": "山木尽亚洪涛风，尤工远势古莫比。"
    },
    {
      "诗行编号": "P307_L07",
      "原文": "咫尺应须论万里，焉得并州快剪刀。"
    },
    {
      "诗行编号": "P307_L08",
      "原文": "剪取吴松半江水。"
    }
  ],
