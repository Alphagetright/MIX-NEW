  "诗行": [
    {
      "诗行编号": "P1111_L01",
      "原文": "挂帆早发刘郎浦，疾风飒飒昏亭午。"
    },
    {
      "诗行编号": "P1111_L02",
      "原文": "舟中无日不沙尘，岸上空村尽豺虎。"
    },
    {
      "诗行编号": "P1111_L03",
      "原文": "十日北风风未回，客行岁晚晚相催。"
    },
    {
      "诗行编号": "P1111_L04",
      "原文": "白头厌伴渔人宿，黄帽青鞋归去来。"
    }
  ],
