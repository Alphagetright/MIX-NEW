  "诗行": [
    {
      "诗行编号": "P172_L01",
      "原文": "群鸡正乱叫，客至鸡斗争。"
    },
    {
      "诗行编号": "P172_L02",
      "原文": "驱鸡上树木，始闻叩柴荆。"
    },
    {
      "诗行编号": "P172_L03",
      "原文": "父老四五人，问我久远行。"
    },
    {
      "诗行编号": "P172_L04",
      "原文": "手中各有携，倾榼浊复清。"
    },
    {
      "诗行编号": "P172_L05",
      "原文": "苦辞酒味薄，黍地无人耕。"
    },
    {
      "诗行编号": "P172_L06",
      "原文": "兵革既未息，儿童尽东征。"
    },
    {
      "诗行编号": "P172_L07",
      "原文": "请为父老歌，艰难愧深情。"
    },
    {
      "诗行编号": "P172_L08",
      "原文": "歌罢仰天叹，四座泪纵横。"
    }
