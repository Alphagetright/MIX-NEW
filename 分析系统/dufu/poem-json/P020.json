  "诗行": [
    {
      "诗行编号": "P020_L01",
      "原文": "龙门横野断，驿树出城来。"
    },
    {
      "诗行编号": "P020_L02",
      "原文": "气色皇居近，金银佛寺开。"
    },
    {
      "诗行编号": "P020_L03",
      "原文": "往还时屡改，川水日悠哉。"
    },
    {
      "诗行编号": "P020_L04",
      "原文": "相阅征途上，生涯尽几回。"
    }
