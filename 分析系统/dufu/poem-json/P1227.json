    {
      "诗行编号": "P1227_L01",
      "原文": "佳人绝代歌"
    },
    {
      "诗行编号": "P1227_L02",
      "原文": "独立发皓齿"
    },
    {
      "诗行编号": "P1227_L03",
      "原文": "满堂惨不乐"
    },
    {
      "诗行编号": "P1227_L04",
      "原文": "响下清虚里"
    },
    {
      "诗行编号": "P1227_L05",
      "原文": "江城带素月"
    },
    {
      "诗行编号": "P1227_L06",
      "原文": "况乃清夜起"
    },
    {
      "诗行编号": "P1227_L07",
      "原文": "老夫悲暮年"
    },
    {
      "诗行编号": "P1227_L08",
      "原文": "壮士泪如水"
    },
    {
      "诗行编号": "P1227_L09",
      "原文": "玉杯久寂寞"
    },
    {
      "诗行编号": "P1227_L10",
      "原文": "金管迷宫徵"
    },
    {
      "诗行编号": "P1227_L11",
      "原文": "勿云听者疲"
    },
    {
      "诗行编号": "P1227_L12",
      "原文": "愚智心尽死"
    },
    {
      "诗行编号": "P1227_L13",
      "原文": "古来杰出士"
    },
    {
      "诗行编号": "P1227_L14",
      "原文": "岂待一知己"
    },
    {
      "诗行编号": "P1227_L15",
      "原文": "吾闻昔秦青"
    },
    {
      "诗行编号": "P1227_L16",
      "原文": "倾侧天下耳"
    }
