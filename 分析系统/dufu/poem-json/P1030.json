  "诗行": [
    {
      "诗行编号": "P1030_L01",
      "原文": "南纪巫庐瘴不绝，太古以来无尺雪。"
    },
    {
      "诗行编号": "P1030_L02",
      "原文": "蛮夷长老怨苦寒，昆仑天关冻应折。"
    },
    {
      "诗行编号": "P1030_L03",
      "原文": "玄猿口噤不能啸，白鹄翅垂眼流血。"
    },
    {
      "诗行编号": "P1030_L04",
      "原文": "安得春泥补地裂。"
    }
  ],
