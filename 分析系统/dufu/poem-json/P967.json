  "诗行": [
    {
      "诗行编号": "P967_L01",
      "原文": "江间虽炎瘴，瓜熟亦不早。"
    },
    {
      "诗行编号": "P967_L02",
      "原文": "柏公镇夔国，滞务兹一埽。"
    },
    {
      "诗行编号": "P967_L03",
      "原文": "食新先战士，共少及溪老。"
    },
    {
      "诗行编号": "P967_L04",
      "原文": "倾筐蒲鸽青，满眼颜色好。"
    },
    {
      "诗行编号": "P967_L05",
      "原文": "竹竿接嵌窦，引注来鸟道。"
    },
    {
      "诗行编号": "P967_L06",
      "原文": "沈浮乱水玉，爱惜如芝草。"
    },
    {
      "诗行编号": "P967_L07",
      "原文": "落刃嚼冰霜，开怀慰枯槁。"
    },
    {
      "诗行编号": "P967_L08",
      "原文": "许以秋蒂除，仍看小童抱。"
    },
    {
      "诗行编号": "P967_L09",
      "原文": "东陵迹芜绝，楚汉休征讨。"
    },
    {
      "诗行编号": "P967_L10",
      "原文": "园人非故侯，种此何草草。"
    }
  ],
