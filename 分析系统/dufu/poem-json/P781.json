  "诗行": [
    {
      "诗行编号": "P781_L01",
      "原文": "近时冯绍正，能画鸷鸟样。"
    },
    {
      "诗行编号": "P781_L02",
      "原文": "明公出此图，无乃传其状。"
    },
    {
      "诗行编号": "P781_L03",
      "原文": "殊姿各独立，清绝心有向。"
    },
    {
      "诗行编号": "P781_L04",
      "原文": "疾禁千里马，气敌万人将。"
    },
    {
      "诗行编号": "P781_L05",
      "原文": "忆昔骊山宫，冬移含元仗。"
    },
    {
      "诗行编号": "P781_L06",
      "原文": "天寒大羽猎，此物神俱王。"
    },
    {
      "诗行编号": "P781_L07",
      "原文": "当时无凡材，百中皆用壮。"
    },
    {
      "诗行编号": "P781_L08",
      "原文": "粉墨形似间，识者一惆怅。"
    },
    {
      "诗行编号": "P781_L09",
      "原文": "干戈少暇日，真骨老崖嶂。"
    },
    {
      "诗行编号": "P781_L10",
      "原文": "为君除狡兔，会是翻鞲上。"
    }
  ],
