  "诗行": [
    {
      "诗行编号": "P379_L01",
      "原文": "成都猛将有花卿，学语小儿知姓名。"
    },
    {
      "诗行编号": "P379_L02",
      "原文": "用如快鹘风火生，见贼唯多身始轻。"
    },
    {
      "诗行编号": "P379_L03",
      "原文": "绵州副使著柘黄，我卿埽除即日平。"
    },
    {
      "诗行编号": "P379_L04",
      "原文": "子章髑髅血模糊，手提掷还崔大夫。"
    },
    {
      "诗行编号": "P379_L05",
      "原文": "李侯重有此节度，人道我卿绝世无。"
    },
    {
      "诗行编号": "P379_L06",
      "原文": "既称绝世无，天子何不唤取守京都。"
    }
  ],
