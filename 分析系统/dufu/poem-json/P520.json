  "诗行": [
    {
      "诗行编号": "P520_L01",
      "原文": "我生性放诞，雅欲逃自然。"
    },
    {
      "诗行编号": "P520_L02",
      "原文": "嗜酒爱风竹，卜居必林泉。"
    },
    {
      "诗行编号": "P520_L03",
      "原文": "遭乱到蜀江，卧疴遣所便。"
    },
    {
      "诗行编号": "P520_L04",
      "原文": "诛茅初一亩，广地方连延。"
    },
    {
      "诗行编号": "P520_L05",
      "原文": "经营上元始，断手宝应年。"
    },
    {
      "诗行编号": "P520_L06",
      "原文": "敢谋土木丽，自觉面势坚。"
    },
    {
      "诗行编号": "P520_L07",
      "原文": "台亭随高下，敞豁当清川。"
    },
    {
      "诗行编号": "P520_L08",
      "原文": "虽有会心侣，数能同钓船。"
    },
    {
      "诗行编号": "P520_L09",
      "原文": "干戈未偃息，安得酣歌眠。"
    },
    {
      "诗行编号": "P520_L10",
      "原文": "蛟龙无定窟，黄鹄摩苍天。"
    },
    {
      "诗行编号": "P520_L11",
      "原文": "古来达士志，宁受外物牵。"
    },
    {
      "诗行编号": "P520_L12",
      "原文": "顾惟鲁钝姿，岂识悔吝先。"
    },
    {
      "诗行编号": "P520_L13",
      "原文": "偶携老妻去，惨澹凌风烟。"
    },
    {
      "诗行编号": "P520_L14",
