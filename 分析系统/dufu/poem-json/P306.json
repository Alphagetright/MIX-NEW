  "诗行": [
    {
      "诗行编号": "P306_L01",
      "原文": "君不见秦时蜀太守，刻石立作三犀牛。"
    },
    {
      "诗行编号": "P306_L02",
      "原文": "自古虽有厌胜法，天生江水向东流。"
    },
    {
      "诗行编号": "P306_L03",
      "原文": "蜀人矜誇一千载，汎溢不近张仪楼。"
    },
    {
      "诗行编号": "P306_L04",
      "原文": "今年灌口损户口，此事或恐为神羞。"
    },
    {
      "诗行编号": "P306_L05",
      "原文": "终藉堤防出众力，高拥木石当清秋。"
    },
    {
      "诗行编号": "P306_L06",
      "原文": "先王作法皆正道，鬼怪何得参人谋。"
    },
    {
      "诗行编号": "P306_L07",
      "原文": "嗟尔三犀不经济，缺讹只与长川逝。"
    },
    {
      "诗行编号": "P306_L08",
      "原文": "但见元气常调和，自免洪涛恣凋瘵。"
    },
    {
      "诗行编号": "P306_L09",
      "原文": "安得壮士提天纲，再平水土犀奔茫。"
    }
  ],
