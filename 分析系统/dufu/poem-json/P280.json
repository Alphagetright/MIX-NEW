  "诗行": [
    {
      "诗行编号": "P280_L01",
      "原文": "熊罴哮我东，虎豹号我西。"
    },
    {
      "诗行编号": "P280_L02",
      "原文": "我后鬼长啸，我前狨又啼。"
    },
    {
      "诗行编号": "P280_L03",
      "原文": "天寒昏无日，山远道路迷。"
    },
    {
      "诗行编号": "P280_L04",
      "原文": "驱车石龛下，仲冬见虹蜺。"
    },
    {
      "诗行编号": "P280_L05",
      "原文": "伐竹者谁子，悲歌上云梯。"
    },
    {
      "诗行编号": "P280_L06",
      "原文": "为官采美箭，五岁供梁齐。"
    },
    {
      "诗行编号": "P280_L07",
      "原文": "苦云直簳尽，无以充提携。"
    },
    {
      "诗行编号": "P280_L08",
      "原文": "奈何渔阳骑，飒飒惊烝黎。"
    },
    {
      "诗行编号": "P280_L09",
      "原文": "奈何漁陽騎，颯颯驚烝黎。"
    }
  ],
