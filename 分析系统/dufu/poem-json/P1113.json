  "诗行": [
    {
      "诗行编号": "P1113_L01",
      "原文": "夜闻觱篥沧江上，衰年侧耳情所向。"
    },
    {
      "诗行编号": "P1113_L02",
      "原文": "邻舟一听多感伤，塞曲三更歘悲壮。"
    },
    {
      "诗行编号": "P1113_L03",
      "原文": "积雪飞霜此夜寒，孤灯急管复风湍。"
    },
    {
      "诗行编号": "P1113_L04",
      "原文": "君知天地干戈满，不见江湖行路难。"
    }
  ],
