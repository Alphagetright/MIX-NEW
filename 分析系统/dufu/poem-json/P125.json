  "诗行": [
    {
      "诗行编号": "P125_L01",
      "原文": "我军青坂在东门，天寒饮马太白窟。"
    },
    {
      "诗行编号": "P125_L02",
      "原文": "黄头奚儿日向西，数骑弯弓敢驰突。"
    },
    {
      "诗行编号": "P125_L03",
      "原文": "山雪河冰野萧飋，青是烽烟白人骨。"
    },
    {
      "诗行编号": "P125_L04",
      "原文": "焉得附书与我军，忍待明年莫仓卒。"
    }
  ],
