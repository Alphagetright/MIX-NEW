  "诗行": [
    {
      "诗行编号": "P021_L01",
      "原文": "二年客东都，所历厌机巧。"
    },
    {
      "诗行编号": "P021_L02",
      "原文": "野人对膻腥，蔬食常不饱。"
    },
    {
      "诗行编号": "P021_L03",
      "原文": "岂无青精饭，使我颜色好。"
    },
    {
      "诗行编号": "P021_L04",
      "原文": "苦乏大药资，山林迹如扫。"
    },
    {
      "诗行编号": "P021_L05",
      "原文": "李侯金闺彦，脱身事幽讨。"
    },
    {
      "诗行编号": "P021_L06",
      "原文": "亦有梁宋游，方期拾瑶草。"
    }
  ],
