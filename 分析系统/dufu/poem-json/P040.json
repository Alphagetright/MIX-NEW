  "诗行": [
    {
      "诗行编号": "P040_L01",
      "原文": "舞剑过人绝，鸣弓射兽能。"
    },
    {
      "诗行编号": "P040_L02",
      "原文": "铦锋行惬顺，猛噬失蹻腾。"
    },
    {
      "诗行编号": "P040_L03",
      "原文": "赤羽千夫膳，黄河十月冰。"
    },
    {
      "诗行编号": "P040_L04",
      "原文": "横行沙漠外，神速至今称。"
    }
  ],
