  "诗行": [
    {
      "诗行编号": "P774_L01",
      "原文": "大暑运金气，荆扬不知秋。"
    },
    {
      "诗行编号": "P774_L02",
      "原文": "林下有塌翼，水中无行舟。"
    },
    {
      "诗行编号": "P774_L03",
      "原文": "千室但埽地，闭关人事休。"
    },
    {
      "诗行编号": "P774_L04",
      "原文": "老夫转不乐，旅次兼百忧。"
    },
    {
      "诗行编号": "P774_L05",
      "原文": "蝮蛇暮偃蹇，空床难暗投。"
    },
    {
      "诗行编号": "P774_L06",
      "原文": "炎宵恶明烛，况乃怀旧丘。"
    },
    {
      "诗行编号": "P774_L07",
      "原文": "开襟仰内弟，执热露白头。"
    },
    {
      "诗行编号": "P774_L08",
      "原文": "束带负芒刺，接居成阻修。"
    },
    {
      "诗行编号": "P774_L09",
      "原文": "何当清霜飞，会子临江楼。"
    },
    {
      "诗行编号": "P774_L10",
      "原文": "载闻大易义，讽兴诗家流。"
    },
    {
      "诗行编号": "P774_L11",
      "原文": "蕴藉异时辈，检身非苟求。"
    },
    {
      "诗行编号": "P774_L12",
      "原文": "皇皇使臣体，信是德业优。"
    },
    {
      "诗行编号": "P774_L13",
      "原文": "楚材择杞梓，汉苑归骅骝。"
    },
    {
      "诗行编号": "P774_L14",
      "原文": "短章达我心，理为识者筹。"
    }
  ],
