  "诗行": [
    {
      "诗行编号": "P389_L01",
      "原文": "楩楠枯峥嵘，乡党皆莫记。"
    },
    {
      "诗行编号": "P389_L02",
      "原文": "不知几百岁，惨惨无生意。"
    },
    {
      "诗行编号": "P389_L03",
      "原文": "上枝摩皇天，下根蟠厚地。"
    },
    {
      "诗行编号": "P389_L04",
      "原文": "巨围雷霆坼，万孔虫蚁萃。"
    },
    {
      "诗行编号": "P389_L05",
      "原文": "冻雨落流胶，冲风夺佳气。"
    },
    {
      "诗行编号": "P389_L06",
      "原文": "白鹄遂不来，天鸡为愁思。"
    },
    {
      "诗行编号": "P389_L07",
      "原文": "犹含栋梁具，无复霄汉志。"
    },
    {
      "诗行编号": "P389_L08",
      "原文": "良工古昔少，识者出涕泪。"
    },
    {
      "诗行编号": "P389_L09",
      "原文": "种榆水中央，成长何容易。"
    },
    {
      "诗行编号": "P389_L10",
      "原文": "截承金露盘，袅袅不自畏。"
    }
  ],
