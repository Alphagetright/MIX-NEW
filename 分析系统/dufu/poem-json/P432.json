  "诗行": [
    {
      "诗行编号": "P432_L01",
      "原文": "苍江鱼子清晨集，设网提纲万鱼急。"
    },
    {
      "诗行编号": "P432_L02",
      "原文": "能者操舟疾若风，撑突波涛挺叉入。"
    },
    {
      "诗行编号": "P432_L03",
      "原文": "小鱼脱漏不可记，半死半生犹戢戢。"
    },
    {
      "诗行编号": "P432_L04",
      "原文": "大鱼伤损皆垂头，屈强泥沙有时立。"
    },
    {
      "诗行编号": "P432_L05",
      "原文": "东津观鱼已再来，主人罢鲙还倾杯。"
    },
    {
      "诗行编号": "P432_L06",
      "原文": "日暮蛟龙改窟穴，山根鳣鲔随云雷。"
    },
    {
      "诗行编号": "P432_L07",
      "原文": "干戈兵革斗未止，凤凰麒麟安在哉。"
    },
    {
      "诗行编号": "P432_L08",
      "原文": "吾徒胡为纵此乐，暴殄天物圣所哀。"
    }
  ],
