  "诗行": [
    {
      "诗行编号": "P1315_L01",
      "原文": "自胡之反持干戈，天下学士亦奔波。"
    },
    {
      "诗行编号": "P1315_L02",
      "原文": "叹彼幽栖载典籍，萧然暴露依山阿。"
    },
    {
      "诗行编号": "P1315_L03",
      "原文": "青山万里静散地，白雨一洗空垂萝。"
    },
    {
      "诗行编号": "P1315_L04",
      "原文": "乱代飘零余到此，古人成败子如何。"
    },
    {
      "诗行编号": "P1315_L05",
      "原文": "荆扬春冬异风土，巫峡日夜多云雨。"
    },
    {
      "诗行编号": "P1315_L06",
      "原文": "赤叶枫林百舌鸣，黄泥野岸天鸡舞。"
    },
    {
      "诗行编号": "P1315_L07",
      "原文": "盗贼纵横甚密迩，形神寂莫甘辛苦。"
    },
    {
      "诗行编号": "P1315_L08",
      "原文": "几时高议排金门，各使苍生有环堵。"
    }
  ],
