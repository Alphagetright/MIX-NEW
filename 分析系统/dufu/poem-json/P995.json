  "诗行": [
    {
      "诗行编号": "P995_L01",
      "原文": "秋风淅淅吹我衣，东流之外西日微。"
    },
    {
      "诗行编号": "P995_L02",
      "原文": "天清小城捣练急，石古细路行人稀。"
    },
    {
      "诗行编号": "P995_L03",
      "原文": "天清小城捣练急，石古細路行人稀。"
    },
    {
      "诗行编号": "P995_L04",
      "原文": "不知明月为谁好，早晚孤帆他夜归。"
    },
    {
      "诗行编号": "P995_L05",
      "原文": "会将白发倚庭树，故园池台今是非。"
    }
