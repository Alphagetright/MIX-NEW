    },
    {
      "诗行编号": "P265_L02",
      "原文": "晒药能无妇，应门幸有儿。"
    },
    {
      "诗行编号": "P265_L03",
      "原文": "藏书闻禹穴，读记忆仇池。"
    },
    {
      "诗行编号": "P265_L04",
      "原文": "为报鸳行旧，鹪鹩在一枝。"
    }
  ],
