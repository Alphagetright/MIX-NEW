  "诗行": [
    {
      "诗行编号": "P431_L01",
      "原文": "绵州江水之东津"
    },
    {
      "诗行编号": "P431_L02",
      "原文": "鲂鱼鱍鱍色胜银"
    },
    {
      "诗行编号": "P431_L03",
      "原文": "渔人漾舟沈大网"
    },
    {
      "诗行编号": "P431_L04",
      "原文": "截江一拥数百鳞"
    },
    {
      "诗行编号": "P431_L05",
      "原文": "众鱼常才尽却弃"
    },
    {
      "诗行编号": "P431_L06",
      "原文": "赤鲤腾出如有神"
    },
    {
      "诗行编号": "P431_L07",
      "原文": "潜龙无声老蛟怒"
    },
    {
      "诗行编号": "P431_L08",
      "原文": "回风飒飒吹沙尘"
    },
    {
      "诗行编号": "P431_L09",
      "原文": "饔子左右挥双刀"
    },
    {
      "诗行编号": "P431_L10",
      "原文": "脍飞金盘白雪高"
    },
    {
      "诗行编号": "P431_L11",
      "原文": "徐州秃尾不足忆"
    },
    {
      "诗行编号": "P431_L12",
      "原文": "汉阴槎头远遁逃"
    },
    {
      "诗行编号": "P431_L13",
      "原文": "鲂鱼肥美知第一"
    },
    {
      "诗行编号": "P431_L14",
      "原文": "既饱欢娱亦萧瑟"
    },
    {
      "诗行编号": "P431_L15",
      "原文": "君不见朝来割素鬐"
    },
    {
      "诗行编号": "P431_L16",
      "原文": "咫尺波涛永相失"
    }
  ],
