  "诗行": [
    {
      "诗行编号": "P1042_L01",
      "原文": "楚岸行将老，巫山坐复春。"
    },
    {
      "诗行编号": "P1042_L02",
      "原文": "病多犹是客，谋拙竟何人。"
    },
    {
      "诗行编号": "P1042_L03",
      "原文": "阊阖开黄道，衣冠拜紫宸。"
    },
    {
      "诗行编号": "P1042_L04",
      "原文": "荣光悬日月，赐与出金银。"
    },
    {
      "诗行编号": "P1042_L05",
      "原文": "愁寂鸳行断，参差虎穴邻。"
    },
    {
      "诗行编号": "P1042_L06",
      "原文": "西江元下蜀，北斗故临秦。"
    },
    {
      "诗行编号": "P1042_L07",
      "原文": "散地逾高枕，生涯脱要津。"
    },
    {
      "诗行编号": "P1042_L08",
      "原文": "天边梅柳树，相见几回新。"
    }
  ],
