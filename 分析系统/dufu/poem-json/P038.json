  "诗行": [
    {
      "诗行编号": "P038_L01",
      "原文": "有美生人杰，由来积德门。"
    },
    {
      "诗行编号": "P038_L02",
      "原文": "汉朝丞相系，梁日帝王孙。"
    },
    {
      "诗行编号": "P038_L03",
      "原文": "蕴藉为郎久，魁梧秉哲尊。"
    },
    {
      "诗行编号": "P038_L04",
      "原文": "词华倾后辈，风雅蔼孤骞。"
    },
    {
      "诗行编号": "P038_L05",
      "原文": "词华傾后辈，风雅蔼孤骞。"
    },
    {
      "诗行编号": "P038_L06",
      "原文": "宅相荣姻戚，儿童惠讨论。"
    },
    {
      "诗行编号": "P038_L07",
      "原文": "见知真自幼，谋拙丑诸昆。"
    },
    {
      "诗行编号": "P038_L08",
      "原文": "漂荡云天阔，沈埋日月奔。"
    },
    {
      "诗行编号": "P038_L09",
      "原文": "致君时已晚，怀古意空存。"
    },
    {
      "诗行编号": "P038_L10",
      "原文": "中散山阳锻，愚公野谷村。"
    },
    {
      "诗行编号": "P038_L11",
      "原文": "宁纡长者辙，归老任乾坤。"
    }
  ],
