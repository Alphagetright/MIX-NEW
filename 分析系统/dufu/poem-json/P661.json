  "诗行": [
    {
      "诗行编号": "P661_L01",
      "原文": "忆昔先皇巡朔方，千乘万骑入咸阳。"
    },
    {
      "诗行编号": "P661_L02",
      "原文": "阴山骄子汗血马，长驱东胡胡走藏。"
    },
    {
      "诗行编号": "P661_L03",
      "原文": "邺城反覆不足怪，关中小儿坏纪纲。"
    },
    {
      "诗行编号": "P661_L04",
      "原文": "张后不乐上为忙，至今今上犹拨乱。"
    },
    {
      "诗行编号": "P661_L05",
      "原文": "劳身焦思补四方，我昔近侍叨奉引。"
    },
    {
      "诗行编号": "P661_L06",
      "原文": "出兵整肃不可当，为留猛士守未央。"
    },
    {
      "诗行编号": "P661_L07",
      "原文": "致使岐雍防西羌，犬戎直来坐御床。"
    },
    {
      "诗行编号": "P661_L08",
      "原文": "百官跣足随天王，愿见北地傅介子。"
    },
    {
      "诗行编号": "P661_L09",
      "原文": "老儒不用尚书郎。"
    }
  ],
