  "诗行": [
    {
      "诗行编号": "P1071_L01",
      "原文": "肃宗昔在灵武城，指挥猛将收咸京。"
    },
    {
      "诗行编号": "P1071_L02",
      "原文": "向公泣血洒行殿，佐佑卿相乾坤平。"
    },
    {
      "诗行编号": "P1071_L03",
      "原文": "逆胡冥寞随烟烬，卿家兄弟功名震。"
    },
    {
      "诗行编号": "P1071_L04",
      "原文": "麒麟图画鸿雁行，紫极出入黄金印。"
    },
    {
      "诗行编号": "P1071_L05",
      "原文": "尚书勋业超千古，雄镇荆州继吾祖。"
    },
    {
      "诗行编号": "P1071_L06",
      "原文": "裁缝云雾成御衣，拜跪题封向端午。"
    },
    {
      "诗行编号": "P1071_L07",
      "原文": "向卿将命寸心赤，青山落日江潮白。"
    },
    {
      "诗行编号": "P1071_L08",
      "原文": "卿到朝廷说老翁，漂零已是沧浪客。"
    }
  ],
