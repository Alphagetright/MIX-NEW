  "诗行": [
    {
      "诗行编号": "P1040_L01",
      "原文": "自汝到荆府，书来数唤吾。"
    },
    {
      "诗行编号": "P1040_L02",
      "原文": "颂椒添讽咏，禁火卜欢娱。"
    },
    {
      "诗行编号": "P1040_L03",
      "原文": "舟楫因人动，形骸用杖扶。"
    },
    {
      "诗行编号": "P1040_L04",
      "原文": "天旋夔子国，春近岳阳湖。"
    },
    {
      "诗行编号": "P1040_L05",
      "原文": "发日排南喜，伤神散北吁。"
    },
    {
      "诗行编号": "P1040_L06",
      "原文": "飞鸣还接翅，行序密衔芦。"
    },
    {
      "诗行编号": "P1040_L07",
      "原文": "俗薄江山好，时危草木苏。"
    },
    {
      "诗行编号": "P1040_L08",
      "原文": "冯唐虽晚达，终觊在皇都。"
    }
  ],
