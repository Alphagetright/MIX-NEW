  "诗行": [
    {
      "诗行编号": "P581_L01",
      "原文": "再有朝廷乱，难知消息真。"
    },
    {
      "诗行编号": "P581_L02",
      "原文": "近传王在洛，复道使归秦。"
    },
    {
      "诗行编号": "P581_L03",
      "原文": "夺马悲公主，登车泣贵嫔。"
    },
    {
      "诗行编号": "P581_L04",
      "原文": "萧关迷北上，沧海欲东巡。"
    },
    {
      "诗行编号": "P581_L05",
      "原文": "敢料安危体，犹多老大臣。"
    },
    {
      "诗行编号": "P581_L06",
      "原文": "岂无嵇绍血，沾洒属车尘。"
    }
  ],
