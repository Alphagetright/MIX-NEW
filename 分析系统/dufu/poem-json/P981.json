  "诗行": [
    {
      "诗行编号": "P981_L01",
      "原文": "东屯大江北，百顷平若案。"
    },
    {
      "诗行编号": "P981_L02",
      "原文": "六月青稻多，千畦碧泉乱。"
    },
    {
      "诗行编号": "P981_L03",
      "原文": "插秧适云已，引溜加溉灌。"
    },
    {
      "诗行编号": "P981_L04",
      "原文": "更仆往方塘，决渠当断岸。"
    },
    {
      "诗行编号": "P981_L05",
      "原文": "公私各地著，浸润无天旱。"
    },
    {
      "诗行编号": "P981_L06",
      "原文": "主守问家臣，分明见溪伴。"
    },
    {
      "诗行编号": "P981_L07",
      "原文": "芊芊炯翠羽，剡剡生银汉。"
    },
    {
      "诗行编号": "P981_L08",
      "原文": "鸥鸟镜里来，关山云边看。"
    },
    {
      "诗行编号": "P981_L09",
      "原文": "秋菰成黑米，精凿传白粲。"
    },
    {
      "诗行编号": "P981_L10",
      "原文": "玉粒足晨炊，红鲜任霞散。"
    },
    {
      "诗行编号": "P981_L11",
      "原文": "终然添旅食，作苦期壮观。"
    },
    {
      "诗行编号": "P981_L12",
      "原文": "遗穗及众多，我仓戒滋蔓。"
    }
  ],
