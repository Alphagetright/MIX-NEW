  "诗行": [
    {
      "诗行编号": "P914_L01",
      "原文": "故人有游子，弃掷傍天隅。"
    },
    {
      "诗行编号": "P914_L02",
      "原文": "他日怜才命，居然屈壮图。"
    },
    {
      "诗行编号": "P914_L03",
      "原文": "十年犹塌翼，绝倒为惊吁。"
    },
    {
      "诗行编号": "P914_L04",
      "原文": "消渴今如在，提携愧老夫。"
    },
    {
      "诗行编号": "P914_L05",
      "原文": "岂知台阁旧，先拂凤皇雏。"
    },
    {
      "诗行编号": "P914_L06",
      "原文": "得实翻苍竹，栖枝把翠梧。"
    },
    {
      "诗行编号": "P914_L07",
      "原文": "北辰当宇宙，南岳据江湖。"
    },
    {
      "诗行编号": "P914_L08",
      "原文": "国带风尘色，兵张虎豹符。"
    },
    {
      "诗行编号": "P914_L09",
      "原文": "数论封内事，挥发府中趋。"
    },
    {
      "诗行编号": "P914_L10",
      "原文": "赠尔秦人策，莫鞭辕下驹。"
    }
  ],
