  "诗行": [
    {
      "诗行编号": "P1165_L01",
      "原文": "分源豕韦派，别浦雁宾秋。"
    },
    {
      "诗行编号": "P1165_L02",
      "原文": "分源豕韋派，別浦雁賓秋。"
    },
    {
      "诗行编号": "P1165_L03",
      "原文": "年事推兄忝，人才觉弟优。"
    },
    {
      "诗行编号": "P1165_L04",
      "原文": "经过辨丰剑，意气逐吴钩。"
    },
    {
      "诗行编号": "P1165_L05",
      "原文": "垂翅徒衰老，先鞭不滞留。"
    },
    {
      "诗行编号": "P1165_L06",
      "原文": "本枝凌岁晚，高义豁穷愁。"
    },
    {
      "诗行编号": "P1165_L07",
      "原文": "他日临江待，长沙旧驿楼。"
    }
  ],
