  "诗行": [
    {
      "诗行编号": "P1308_L01",
      "原文": "重阳独酌杯中酒，抱病起登江上台。"
    },
    {
      "诗行编号": "P1308_L02",
      "原文": "竹叶于人既无分，菊花从此不须开。"
    },
    {
      "诗行编号": "P1308_L03",
      "原文": "殊方日落玄猿哭，旧国霜前白雁来。"
    },
    {
      "诗行编号": "P1308_L04",
      "原文": "弟妹萧条各何往，干戈衰谢两相催。"
    }
  ],
