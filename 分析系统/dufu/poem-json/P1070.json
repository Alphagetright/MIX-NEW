  "诗行": [
    {
      "诗行编号": "P1070_L01",
      "原文": "忆昔北寻小有洞，洪河怒涛过轻舸。"
    },
    {
      "诗行编号": "P1070_L02",
      "原文": "辛勤不见华盖君，艮岑青辉惨么么。"
    },
    {
      "诗行编号": "P1070_L03",
      "原文": "千崖无人万壑静，三步回头五步坐。"
    },
    {
      "诗行编号": "P1070_L04",
      "原文": "秋山眼冷魂未归，仙赏心违泪交堕。"
    },
    {
      "诗行编号": "P1070_L05",
      "原文": "弟子谁依白茅室，卢老独启青铜锁。"
    },
    {
      "诗行编号": "P1070_L06",
      "原文": "巾拂香馀捣药尘，阶除灰死烧丹火。"
    },
    {
      "诗行编号": "P1070_L07",
      "原文": "悬圃沧洲莽空阔，金节羽衣飘婀娜。"
    },
    {
      "诗行编号": "P1070_L08",
      "原文": "落日初霞闪馀映，倏忽东西无不可。"
    },
    {
      "诗行编号": "P1070_L09",
      "原文": "松风涧水声合时，青兕黄熊啼向我。"
    },
    {
      "诗行编号": "P1070_L10",
      "原文": "徒然咨嗟抚遗迹，至今梦想仍犹佐。"
    },
    {
      "诗行编号": "P1070_L11",
      "原文": "秘诀隐文须内教，晚岁何功使愿果。"
    },
    {
      "诗行编号": "P1070_L12",
      "原文": "更讨衡阳董鍊师，南浮早鼓潇湘柁。"
    }
  ],
