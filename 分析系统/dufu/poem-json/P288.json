  "诗行": [
    {
      "诗行编号": "P288_L01",
      "原文": "首路栗亭西，尚想凤皇村。"
    },
    {
      "诗行编号": "P288_L02",
      "原文": "季冬携童稚，辛苦赴蜀门。"
    },
    {
      "诗行编号": "P288_L03",
      "原文": "南登木皮岭，艰险不易论。"
    },
    {
      "诗行编号": "P288_L04",
      "原文": "汗流被我体，祁寒为之暄。"
    },
    {
      "诗行编号": "P288_L05",
      "原文": "远岫争辅佐，千岩自崩奔。"
    },
    {
      "诗行编号": "P288_L06",
      "原文": "始知五岳外，别有他山尊。"
    },
    {
      "诗行编号": "P288_L07",
      "原文": "仰干塞大明，俯入裂厚坤。"
    },
    {
      "诗行编号": "P288_L08",
      "原文": "再闻虎豹斗，屡跼风水昏。"
    },
    {
      "诗行编号": "P288_L09",
      "原文": "高有废阁道，摧折如短辕。"
    },
    {
      "诗行编号": "P288_L10",
      "原文": "下有冬青林，石上走长根。"
    },
    {
      "诗行编号": "P288_L11",
      "原文": "西崖特秀发，焕若灵芝繁。"
    },
    {
      "诗行编号": "P288_L12",
      "原文": "润聚金碧气，清无沙土痕。"
    },
    {
      "诗行编号": "P288_L13",
      "原文": "忆观昆崙图，目击悬圃存。"
    },
    {
      "诗行编号": "P288_L14",
      "原文": "对此欲何适，默伤垂老魂。"
    }
  ],
