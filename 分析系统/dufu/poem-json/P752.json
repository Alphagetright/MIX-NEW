  "诗行": [
    {
      "诗行编号": "P752_L01",
      "原文": "白水青山空复春，徵君晚节傍风尘。"
    },
    {
      "诗行编号": "P752_L02",
      "原文": "楚妃堂上色殊众，海鹤阶前鸣向人。"
    },
    {
      "诗行编号": "P752_L03",
      "原文": "万事纠纷犹绝粒，一官羁绊实藏身。"
    },
    {
      "诗行编号": "P752_L04",
      "原文": "开州入夏知凉冷，不似云安毒热新。"
    }
  ],
