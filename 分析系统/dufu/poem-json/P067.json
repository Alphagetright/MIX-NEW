  "诗行": [
    {
      "诗行编号": "P067_L01",
      "原文": "昭代将垂白，途穷乃叫阍。"
    },
    {
      "诗行编号": "P067_L02",
      "原文": "气冲星象表，词感帝王尊。"
    },
    {
      "诗行编号": "P067_L03",
      "原文": "天老书题目，春宫验讨论。"
    },
    {
      "诗行编号": "P067_L04",
      "原文": "倚风遗鹢路，随水到龙门。"
    },
    {
      "诗行编号": "P067_L05",
      "原文": "竟与蛟螭杂，空闻燕雀喧。"
    },
    {
      "诗行编号": "P067_L06",
      "原文": "青冥犹契阔，陵厉不飞翻。"
    },
    {
      "诗行编号": "P067_L07",
      "原文": "儒术诚难起，家声庶已存。"
    },
    {
      "诗行编号": "P067_L08",
      "原文": "故山多药物，胜概忆桃源。"
    },
    {
      "诗行编号": "P067_L09",
      "原文": "欲整还乡旆，长怀禁掖垣。"
    },
    {
      "诗行编号": "P067_L10",
      "原文": "欲整还乡憗，长怀禁掖垣。"
    },
    {
      "诗行编号": "P067_L11",
      "原文": "谬称三赋在，难述二公恩。"
    }
  ],
