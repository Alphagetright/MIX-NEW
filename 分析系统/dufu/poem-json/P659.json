  "诗行": [
    {
      "诗行编号": "P659_L01",
      "原文": "江雨飒长夏"
    },
    {
      "诗行编号": "P659_L02",
      "原文": "府中有馀清"
    },
    {
      "诗行编号": "P659_L03",
      "原文": "我公会宾客"
    },
    {
      "诗行编号": "P659_L04",
      "原文": "肃肃有异声"
    },
    {
      "诗行编号": "P659_L05",
      "原文": "初筵阅军装"
    },
    {
      "诗行编号": "P659_L06",
      "原文": "罗列照广庭"
    },
    {
      "诗行编号": "P659_L07",
      "原文": "庭空六马入"
    },
    {
      "诗行编号": "P659_L08",
      "原文": "駊騀扬旗旌"
    },
    {
      "诗行编号": "P659_L09",
      "原文": "回回偃飞盖"
    },
    {
      "诗行编号": "P659_L10",
      "原文": "熠熠迸流星"
    },
    {
      "诗行编号": "P659_L11",
      "原文": "来缠风飙急"
    },
    {
      "诗行编号": "P659_L12",
      "原文": "去擘山岳倾"
    },
    {
      "诗行编号": "P659_L13",
      "原文": "材归俯身尽"
    },
    {
      "诗行编号": "P659_L14",
      "原文": "妙取略地平"
    },
    {
      "诗行编号": "P659_L15",
      "原文": "虹霓就掌握"
    },
    {
      "诗行编号": "P659_L16",
      "原文": "舒卷随人轻"
    },
    {
      "诗行编号": "P659_L17",
      "原文": "三州陷犬戎"
    },
    {
      "诗行编号": "P659_L18",
      "原文": "但见西岭青"
    },
    {
      "诗行编号": "P659_L19",
      "原文": "公来练猛士"
    },
    {
      "诗行编号": "P659_L20",
      "原文": "欲夺天边城"
    },
    {
      "诗行编号": "P659_L21",
      "原文": "此堂不易升"
    },
    {
      "诗行编号": "P659_L22",
      "原文": "庸蜀日已宁"
    },
    {
      "诗行编号": "P659_L23",
      "原文": "吾徒且加餐"
    },
    {
      "诗行编号": "P659_L24",
      "原文": "休适蛮与荆"
    }
  ],
