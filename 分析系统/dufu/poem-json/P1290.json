    {
      "诗行编号": "P1290_L01",
      "原文": "有客乘舸自忠州，遣骑安置瀼西头。"
    },
    {
      "诗行编号": "P1290_L02",
      "原文": "古堂本买藉疏豁，借汝迁居停宴游。"
    },
    {
      "诗行编号": "P1290_L03",
      "原文": "云石荧荧高叶曙，风江飒飒乱帆秋。"
    },
    {
      "诗行编号": "P1290_L04",
      "原文": "却为姻娅过逢地，许坐曾轩数散愁。"
    }
  ],
