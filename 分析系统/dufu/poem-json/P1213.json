  "诗行": [
    {
      "诗行编号": "P1213_L01",
      "原文": "与子避地西康州，洞庭相逢十二秋。"
    },
    {
      "诗行编号": "P1213_L02",
      "原文": "远愧尚方曾赐履，竟非吾土倦登楼。"
    },
    {
      "诗行编号": "P1213_L03",
      "原文": "久存胶漆应难并，一辱泥涂遂晚收。"
    },
    {
      "诗行编号": "P1213_L04",
      "原文": "李杜齐名真忝窃，朔云寒菊倍离忧。"
    }
