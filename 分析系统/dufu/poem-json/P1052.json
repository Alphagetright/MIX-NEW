  "诗行": [
    {
      "诗行编号": "P1052_L01",
      "原文": "使君高义驱今古，"
    },
    {
      "诗行编号": "P1052_L02",
      "原文": "寥落三年坐剑州。"
    },
    {
      "诗行编号": "P1052_L03",
      "原文": "但见文翁能化俗，"
    },
    {
      "诗行编号": "P1052_L04",
      "原文": "焉知李广未封侯。"
    },
    {
      "诗行编号": "P1052_L05",
      "原文": "路经滟滪双蓬鬓，"
    },
    {
      "诗行编号": "P1052_L06",
      "原文": "天入沧浪一钓舟。"
    },
    {
      "诗行编号": "P1052_L07",
      "原文": "戎马相逢更何日，"
    },
    {
      "诗行编号": "P1052_L08",
      "原文": "春风回首仲宣楼。"
    }
  ],
