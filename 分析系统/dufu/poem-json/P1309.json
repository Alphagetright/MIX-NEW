  "诗行": [
    {
      "诗行编号": "P1309_L01",
      "原文": "故里樊川菊，登高素浐源。"
    },
    {
      "诗行编号": "P1309_L02",
      "原文": "他时一笑后，今日几人存。"
    },
    {
      "诗行编号": "P1309_L03",
      "原文": "巫峡蟠江路，终南对国门。"
    },
    {
      "诗行编号": "P1309_L04",
      "原文": "系舟身万里，伏枕泪双痕。"
    },
    {
      "诗行编号": "P1309_L05",
      "原文": "为客裁乌帽，从儿具绿尊。"
    },
    {
      "诗行编号": "P1309_L06",
      "原文": "佳辰对群盗，愁绝更谁论。"
    }
  ],
