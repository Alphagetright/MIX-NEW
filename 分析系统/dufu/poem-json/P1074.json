    {
      "诗行编号": "P1074_L01",
      "原文": "衰年正苦病侵凌，首夏何须气郁蒸。"
    },
    {
      "诗行编号": "P1074_L02",
      "原文": "大水淼茫炎海接，奇峰硉兀火云升。"
    },
    {
      "诗行编号": "P1074_L03",
      "原文": "思沾道暍黄梅雨，敢望宫恩玉井冰。"
    },
    {
      "诗行编号": "P1074_L04",
      "原文": "不是尚书期不顾，山阴野雪兴难乘。"
    }
