  "诗行": [
    {
      "诗行编号": "P1346_L01",
      "原文": "著处繁花务是日"
    },
    {
      "诗行编号": "P1346_L02",
      "原文": "长沙千人万人出"
    },
    {
      "诗行编号": "P1346_L03",
      "原文": "渡头翠柳艳明眉"
    },
    {
      "诗行编号": "P1346_L04",
      "原文": "争道朱蹄骄齧膝"
    },
    {
      "诗行编号": "P1346_L05",
      "原文": "渡头翠柳艳明眉"
    },
    {
      "诗行编号": "P1346_L06",
      "原文": "争道朱蹄驕齧膝"
    },
    {
      "诗行编号": "P1346_L07",
      "原文": "此都好游湘西寺"
    },
    {
      "诗行编号": "P1346_L08",
      "原文": "诸将亦自军中至"
    },
    {
      "诗行编号": "P1346_L09",
      "原文": "马援征行在眼前"
    },
    {
      "诗行编号": "P1346_L10",
      "原文": "葛强亲近同心事"
    },
    {
      "诗行编号": "P1346_L11",
      "原文": "金镫下山红粉晚"
    },
    {
      "诗行编号": "P1346_L12",
      "原文": "牙樯捩柁青楼远"
    },
    {
      "诗行编号": "P1346_L13",
      "原文": "古时丧乱皆可知"
    },
    {
      "诗行编号": "P1346_L14",
      "原文": "人世悲欢暂相遣"
    },
    {
      "诗行编号": "P1346_L15",
      "原文": "弟侄虽存不得书"
    },
    {
      "诗行编号": "P1346_L16",
      "原文": "干戈未息苦离居"
    },
    {
      "诗行编号": "P1346_L17",
      "原文": "逢迎少壮非吾道"
    },
    {
      "诗行编号": "P1346_L18",
      "原文": "况乃今朝更祓除"
    }
  ],
