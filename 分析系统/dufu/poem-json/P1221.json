  "诗行": [
    {
      "诗行编号": "P1221_L01",
      "原文": "支离东北风尘际，漂泊西南天地间。"
    },
    {
      "诗行编号": "P1221_L02",
      "原文": "三峡楼台淹日月，五溪衣服共云山。"
    },
    {
      "诗行编号": "P1221_L03",
      "原文": "羯胡事主终无赖，词客哀时且未还。"
    },
    {
      "诗行编号": "P1221_L04",
      "原文": "庾信平生最萧瑟，暮年诗赋动江关。"
    },
    {
      "诗行编号": "P1221_L05",
      "原文": "庾信平生最蕭瑟，暮年詩賦動江關。"
    }
  ],
