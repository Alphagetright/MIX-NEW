  "诗行": [
    {
      "诗行编号": "P266_L01",
      "原文": "招提凭高冈，疏散连草莽。"
    },
    {
      "诗行编号": "P266_L02",
      "原文": "出泉枯柳根，汲引岁月古。"
    },
    {
      "诗行编号": "P266_L03",
      "原文": "石间见海眼，天畔萦水府。"
    },
    {
      "诗行编号": "P266_L04",
      "原文": "广深丈尺间，宴息敢轻侮。"
    },
    {
      "诗行编号": "P266_L05",
      "原文": "青白二小蛇，幽姿可时睹。"
    },
    {
      "诗行编号": "P266_L06",
      "原文": "如丝气或上，烂熳为云雨。"
    },
    {
      "诗行编号": "P266_L07",
      "原文": "山头到山下，凿井不尽土。"
    },
    {
      "诗行编号": "P266_L08",
      "原文": "取供十方僧，香美胜牛乳。"
    },
    {
      "诗行编号": "P266_L09",
      "原文": "北风起寒文，弱藻舒翠缕。"
    },
    {
      "诗行编号": "P266_L10",
      "原文": "明涵客衣净，细荡林影趣。"
    },
    {
      "诗行编号": "P266_L11",
      "原文": "何当宅下流，馀润通药圃。"
    },
    {
      "诗行编号": "P266_L12",
      "原文": "三春湿黄精，一食生毛羽。"
    }
  ],
