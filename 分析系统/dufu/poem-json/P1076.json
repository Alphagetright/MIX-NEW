  "诗行": [
    {
      "诗行编号": "P1076_L01",
      "原文": "名参汉望苑，职述景题舆。"
    },
    {
      "诗行编号": "P1076_L02",
      "原文": "巫峡将之郡，荆门好附书。"
    },
    {
      "诗行编号": "P1076_L03",
      "原文": "远行无自苦，内热比何如。"
    },
    {
      "诗行编号": "P1076_L04",
      "原文": "正是炎天阔，那堪野馆疏。"
    },
    {
      "诗行编号": "P1076_L05",
      "原文": "黄牛平驾浪，画鹢上凌虚。"
    },
    {
      "诗行编号": "P1076_L06",
      "原文": "试待盘涡歇，方期解缆初。"
    },
    {
      "诗行编号": "P1076_L07",
      "原文": "闷能过小径，自为摘嘉蔬。"
    },
    {
      "诗行编号": "P1076_L08",
      "原文": "渚柳元幽僻，村花不扫除。"
    },
    {
      "诗行编号": "P1076_L09",
      "原文": "宿阴繁素柰，过雨乱红蕖。"
    },
    {
      "诗行编号": "P1076_L10",
      "原文": "寂寂夏先晚，泠泠风有馀。"
    },
    {
      "诗行编号": "P1076_L11",
      "原文": "江清心可莹，竹冷发堪梳。"
    },
    {
      "诗行编号": "P1076_L12",
      "原文": "直作移巾几，秋帆发弊庐。"
    }
  ],
