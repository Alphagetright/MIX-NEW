  "诗行": [
    {
      "诗行编号": "P1236_L01",
      "原文": "秋日萧韦逝，淮王报峡中。"
    },
    {
      "诗行编号": "P1236_L02",
      "原文": "少年疑柱史，多术怪仙公。"
    },
    {
      "诗行编号": "P1236_L03",
      "原文": "不但时人惜，祗应吾道穷。"
    },
    {
      "诗行编号": "P1236_L04",
      "原文": "一哀侵疾病，相识自儿童。"
    },
    {
      "诗行编号": "P1236_L05",
      "原文": "处处邻家笛，飘飘客子蓬。"
    },
    {
      "诗行编号": "P1236_L06",
      "原文": "强吟怀旧赋，已作白头翁。"
    }
  ],
