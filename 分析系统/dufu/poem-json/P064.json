    {
      "诗行编号": "P064_L01",
      "原文": "守岁阿戎家，椒盘已颂花。"
    },
    {
      "诗行编号": "P064_L02",
      "原文": "盍簪喧枥马，列炬散林鸦。"
    },
    {
      "诗行编号": "P064_L03",
      "原文": "四十明朝过，飞腾暮景斜。"
    },
    {
      "诗行编号": "P064_L04",
      "原文": "谁能更拘束，烂醉是生涯。"
    }
