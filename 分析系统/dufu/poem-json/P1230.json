  "诗行": [
    {
      "诗行编号": "P1230_L01",
      "原文": "巫山小摇落，碧色见松林。"
    },
    {
      "诗行编号": "P1230_L02",
      "原文": "百鸟各相命，孤云无自心。"
    },
    {
      "诗行编号": "P1230_L03",
      "原文": "百鳥各相命，孤雲無自心。"
    },
    {
      "诗行编号": "P1230_L04",
      "原文": "层轩俯江壁，要路亦高深。"
    },
    {
      "诗行编号": "P1230_L05",
      "原文": "朱绂犹纱帽，新诗近玉琴。"
    },
    {
      "诗行编号": "P1230_L06",
      "原文": "功名不早立，衰病谢知音。"
    },
    {
      "诗行编号": "P1230_L07",
      "原文": "哀世非王粲，终然学越吟。"
    }
  ],
