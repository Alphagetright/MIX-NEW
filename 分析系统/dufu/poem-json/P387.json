  "诗行": [
    {
      "诗行编号": "P387_L01",
      "原文": "群橘少生意，虽多亦奚为。"
    },
    {
      "诗行编号": "P387_L02",
      "原文": "惜哉结实小，酸涩如棠梨。"
    },
    {
      "诗行编号": "P387_L03",
      "原文": "剖之尽蠹虫，采掇爽其宜。"
    },
    {
      "诗行编号": "P387_L04",
      "原文": "纷然不适口，岂只存其皮。"
    },
    {
      "诗行编号": "P387_L05",
      "原文": "萧萧半死叶，未忍别故枝。"
    },
    {
      "诗行编号": "P387_L06",
      "原文": "玄冬霜雪积，况乃回风吹。"
    },
    {
      "诗行编号": "P387_L07",
      "原文": "尝闻蓬莱殿，罗列潇湘姿。"
    },
    {
      "诗行编号": "P387_L08",
      "原文": "此物岁不稔，玉食失光辉。"
    },
    {
      "诗行编号": "P387_L09",
      "原文": "寇盗尚凭陵，当君减膳时。"
    },
    {
      "诗行编号": "P387_L10",
      "原文": "汝病是天意，吾谂罪有司。"
    },
    {
      "诗行编号": "P387_L11",
      "原文": "忆昔南海使，奔腾献荔支。"
    },
    {
      "诗行编号": "P387_L12",
      "原文": "百马死山谷，到今耆旧悲。"
    }
  ],
