  "诗行": [
    {
      "诗行编号": "P1344_L01",
      "原文": "秋风歘吸吹南国，天地惨惨无颜色。"
    },
    {
      "诗行编号": "P1344_L02",
      "原文": "洞庭扬波江汉回，虎牙铜柱皆倾侧。"
    },
    {
      "诗行编号": "P1344_L03",
      "原文": "巫峡阴岑朔漠气，峰峦窈窕溪谷黑。"
    },
    {
      "诗行编号": "P1344_L04",
      "原文": "杜鹃不来猿狖寒，山鬼幽忧雪霜逼。"
    },
    {
      "诗行编号": "P1344_L05",
      "原文": "楚老长嗟忆炎瘴，三尺角弓两斛力。"
    },
    {
      "诗行编号": "P1344_L06",
      "原文": "壁立石城横塞起，金错旌竿满云直。"
    },
    {
      "诗行编号": "P1344_L07",
      "原文": "渔阳突骑猎青丘，犬戎锁甲闻丹极。"
    },
    {
      "诗行编号": "P1344_L08",
      "原文": "八荒十年防盗贼，征戍诛求寡妻哭，远客中宵泪沾臆。"
    }
  ],
