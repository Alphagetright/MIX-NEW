    {
      "诗行编号": "P927_L01",
      "原文": "易识浮生理，难教一物违。"
    },
    {
      "诗行编号": "P927_L02",
      "原文": "水深鱼极乐，林茂鸟知归。"
    },
    {
      "诗行编号": "P927_L03",
      "原文": "吾老甘贫病，荣华有是非。"
    },
    {
      "诗行编号": "P927_L04",
      "原文": "秋风吹几杖，不厌此山薇。"
    }
