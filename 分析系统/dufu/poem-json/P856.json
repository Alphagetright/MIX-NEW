      "诗行编号": "P856_L01",
      "原文": "欲陈济世策，已老尚书郎。"
    },
    {
      "诗行编号": "P856_L02",
      "原文": "未息豺虎斗，空惭鸳鹭行。"
    },
    {
      "诗行编号": "P856_L03",
      "原文": "时危人事急，风逆羽毛伤。"
    },
    {
      "诗行编号": "P856_L04",
      "原文": "落日悲江汉，中宵泪满床。"
    }
