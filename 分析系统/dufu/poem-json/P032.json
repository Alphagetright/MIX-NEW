      "原文": "误疑茅堂过江麓"
    },
    {
      "诗行编号": "P032_L06",
      "原文": "已入风磴霾云端"
    },
    {
      "诗行编号": "P032_L07",
      "原文": "自是秦楼压郑谷"
    },
    {
      "诗行编号": "P032_L08",
      "原文": "时闻杂佩声珊珊"
    }
