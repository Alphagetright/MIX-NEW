  "诗行": [
    {
      "诗行编号": "P323_L01",
      "原文": "苍生未苏息，"
    },
    {
      "诗行编号": "P323_L02",
      "原文": "胡马半乾坤。"
    },
    {
      "诗行编号": "P323_L03",
      "原文": "议在云台上，"
    },
    {
      "诗行编号": "P323_L04",
      "原文": "谁扶黄屋尊。"
    },
    {
      "诗行编号": "P323_L05",
      "原文": "建都分魏阙，"
    },
    {
      "诗行编号": "P323_L06",
      "原文": "下诏辟荆门。"
    },
    {
      "诗行编号": "P323_L07",
      "原文": "恐失东人望，"
    },
    {
      "诗行编号": "P323_L08",
      "原文": "其如西极存。"
    },
    {
      "诗行编号": "P323_L09",
      "原文": "时危当雪耻，"
    },
    {
      "诗行编号": "P323_L10",
      "原文": "计大岂轻论。"
    },
    {
      "诗行编号": "P323_L11",
      "原文": "虽倚三阶正，"
    },
    {
      "诗行编号": "P323_L12",
      "原文": "终愁万国翻。"
    },
    {
      "诗行编号": "P323_L13",
      "原文": "牵裾恨不死，"
    },
    {
      "诗行编号": "P323_L14",
      "原文": "漏网荷殊恩。"
    },
    {
      "诗行编号": "P323_L15",
      "原文": "永负汉庭哭，"
    },
    {
      "诗行编号": "P323_L16",
      "原文": "遥怜湘水魂。"
    },
    {
      "诗行编号": "P323_L17",
      "原文": "穷冬客江剑，"
    },
    {
      "诗行编号": "P323_L18",
      "原文": "随事有田园。"
    },
    {
      "诗行编号": "P323_L19",
      "原文": "风断青蒲节，"
    },
    {
      "诗行编号": "P323_L20",
      "原文": "霜埋翠竹根。"
    },
    {
      "诗行编号": "P323_L21",
      "原文": "衣冠空穰穰，"
    },
    {
      "诗行编号": "P323_L22",
      "原文": "关辅久昏昏。"
    },
    {
      "诗行编号": "P323_L23",
      "原文": "愿枉长安日，"
    },
    {
      "诗行编号": "P323_L24",
      "原文": "光辉照北原。"
    }
  ],
