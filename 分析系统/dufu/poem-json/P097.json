  "诗行": [
    {
      "诗行编号": "P097_L01",
      "原文": "今秋乃淫雨，仲月来寒风。"
    },
    {
      "诗行编号": "P097_L02",
      "原文": "群木水光下，万象云气中。"
    },
    {
      "诗行编号": "P097_L03",
      "原文": "所思碍行潦，九里信不通。"
    },
    {
      "诗行编号": "P097_L04",
      "原文": "悄悄素浐路，迢迢天汉东。"
    },
    {
      "诗行编号": "P097_L05",
      "原文": "愿腾六尺马，背若孤征鸿。"
    },
    {
      "诗行编号": "P097_L06",
      "原文": "划见公子面，超然欢笑同。"
    },
    {
      "诗行编号": "P097_L07",
      "原文": "奋飞既胡越，局促伤樊笼。"
    },
    {
      "诗行编号": "P097_L08",
      "原文": "一饭四五起，凭轩心力穷。"
    },
    {
      "诗行编号": "P097_L09",
      "原文": "嘉蔬没混浊，时菊碎榛丛。"
    },
    {
      "诗行编号": "P097_L10",
      "原文": "鹰隼亦屈猛，乌鸢何所蒙。"
    }
  ],
