      "原文": "江月光于水，高楼思杀人。"
    },
    {
      "诗行编号": "P1247_L02",
      "原文": "天边长作客，老去一沾巾。"
    },
    {
      "诗行编号": "P1247_L03",
      "原文": "玉露团清影，银河没半轮。"
    },
    {
      "诗行编号": "P1247_L04",
      "原文": "谁家挑锦字，灭烛翠眉嚬。"
    }
