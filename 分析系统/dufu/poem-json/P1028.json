    {
      "诗行编号": "P1028_L01",
      "原文": "汉时长安雪一丈，牛马毛寒缩如猬。"
    },
    {
      "诗行编号": "P1028_L02",
      "原文": "楚江巫峡冰入怀，虎豹哀号又堪记。"
    },
    {
      "诗行编号": "P1028_L03",
      "原文": "秦城老翁荆扬客，惯习炎蒸岁絺绤。"
    },
    {
      "诗行编号": "P1028_L04",
      "原文": "玄冥祝融气或交，手持白羽未敢释。"
    }
