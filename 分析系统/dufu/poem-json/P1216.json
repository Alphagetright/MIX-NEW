  "诗行": [
    {
      "诗行编号": "P1216_L01",
      "原文": "我今日夜忧，诸弟各异方。"
    },
    {
      "诗行编号": "P1216_L02",
      "原文": "不知死与生，何况道路长。"
    },
    {
      "诗行编号": "P1216_L03",
      "原文": "避寇一分散，饥寒永相望。"
    },
    {
      "诗行编号": "P1216_L04",
      "原文": "岂无柴门归？欲出畏虎狼。"
    },
    {
      "诗行编号": "P1216_L05",
      "原文": "仰看云中雁，禽鸟亦有行。"
    }
