  "诗行": [
    {
      "诗行编号": "P1097_L01",
      "原文": "漳滨与蒿里，逝水竟同年。"
    },
    {
      "诗行编号": "P1097_L02",
      "原文": "欲挂留徐剑，犹回忆戴船。"
    },
    {
      "诗行编号": "P1097_L03",
      "原文": "相知成白首，此别间黄泉。"
    },
    {
      "诗行编号": "P1097_L04",
      "原文": "风雨嗟何及，江湖涕泫然。"
    },
    {
      "诗行编号": "P1097_L05",
      "原文": "修文将管辂，奉使失张骞。"
    },
    {
      "诗行编号": "P1097_L06",
      "原文": "史阁行人在，诗家秀句传。"
    },
    {
      "诗行编号": "P1097_L07",
      "原文": "客亭鞍马绝，旅榇网虫悬。"
    },
    {
      "诗行编号": "P1097_L08",
      "原文": "复魄昭丘远，归魂素浐偏。"
    },
    {
      "诗行编号": "P1097_L09",
      "原文": "樵苏封葬地，喉舌罢朝天。"
    },
    {
      "诗行编号": "P1097_L10",
      "原文": "秋色凋春草，王孙若个边。"
    }
  ],
