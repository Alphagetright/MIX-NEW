  "诗行": [
    {
      "诗行编号": "P217_L01",
      "原文": "客行新安道，喧呼闻点兵。"
    },
    {
      "诗行编号": "P217_L02",
      "原文": "借问新安吏，县小更无丁。"
    },
    {
      "诗行编号": "P217_L03",
      "原文": "府帖昨夜下，次选中男行。"
    },
    {
      "诗行编号": "P217_L04",
      "原文": "中男绝短小，何以守王城。"
    },
    {
      "诗行编号": "P217_L05",
      "原文": "肥男有母送，瘦男独伶俜。"
    },
    {
      "诗行编号": "P217_L06",
      "原文": "白水暮东流，青山犹哭声。"
    },
    {
      "诗行编号": "P217_L07",
      "原文": "莫自使眼枯，收汝泪纵横。"
    },
    {
      "诗行编号": "P217_L08",
      "原文": "眼枯即见骨，天地终无情。"
    },
    {
      "诗行编号": "P217_L09",
      "原文": "我军取相州，日夕望其平。"
    },
    {
      "诗行编号": "P217_L10",
      "原文": "岂意贼难料，归军星散营。"
    },
    {
      "诗行编号": "P217_L11",
      "原文": "就粮近故垒，练卒依旧京。"
    },
    {
      "诗行编号": "P217_L12",
      "原文": "掘壕不到水，牧马役亦轻。"
    },
    {
      "诗行编号": "P217_L13",
      "原文": "况乃王师顺，抚养甚分明。"
    },
    {
      "诗行编号": "P217_L14",
      "原文": "送行勿泣血，仆射如父兄。"
    }
  ],
