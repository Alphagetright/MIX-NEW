  "诗行": [
    {
      "诗行编号": "P634_L01",
      "原文": "平生江海心，宿昔具扁舟。"
    },
    {
      "诗行编号": "P634_L02",
      "原文": "平生江海心，宿昔具扁舟。"
    },
    {
      "诗行编号": "P634_L03",
      "原文": "岂惟青溪上，日傍柴门游。"
    },
    {
      "诗行编号": "P634_L04",
      "原文": "苍皇避乱兵，缅邈怀旧丘。"
    },
    {
      "诗行编号": "P634_L05",
      "原文": "邻人亦已非，野竹独修修。"
    },
    {
      "诗行编号": "P634_L06",
      "原文": "船舷不重扣，埋没已经秋。"
    },
    {
      "诗行编号": "P634_L07",
      "原文": "仰看西飞翼，下愧东逝流。"
    },
    {
      "诗行编号": "P634_L08",
      "原文": "故者或可掘，新者亦易求。"
    },
    {
      "诗行编号": "P634_L09",
      "原文": "所悲数奔窜，白屋难久留。"
    }
  ],
