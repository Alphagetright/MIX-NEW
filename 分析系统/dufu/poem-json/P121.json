  "诗行": [
    {
      "诗行编号": "P121_L01",
      "原文": "男儿生世间，及壮当封侯。"
    },
    {
      "诗行编号": "P121_L02",
      "原文": "战伐有功业，焉能守旧丘。"
    },
    {
      "诗行编号": "P121_L03",
      "原文": "召募赴蓟门，军动不可留。"
    },
    {
      "诗行编号": "P121_L04",
      "原文": "千金买马鞭，百金装刀头。"
    },
    {
      "诗行编号": "P121_L05",
      "原文": "闾里送我行，亲戚拥道周。"
    },
    {
      "诗行编号": "P121_L06",
      "原文": "斑白居上列，酒酣进庶羞。"
    },
    {
      "诗行编号": "P121_L07",
      "原文": "少年别有赠，含笑看吴钩。"
    }
  ],
