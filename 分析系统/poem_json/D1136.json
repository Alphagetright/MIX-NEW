  "诗行": [
    {
      "诗行编号": "D1136_L01",
      "原文": "朝来新火起新烟"
    },
    {
      "诗行编号": "D1136_L02",
      "原文": "湖色春光净客船"
    },
    {
      "诗行编号": "D1136_L03",
      "原文": "绣羽衔花他自得"
    },
    {
      "诗行编号": "D1136_L04",
      "原文": "红颜骑竹我无缘"
    },
    {
      "诗行编号": "D1136_L05",
      "原文": "胡童结束还难有"
    },
    {
      "诗行编号": "D1136_L06",
      "原文": "楚女腰肢亦可怜"
    },
    {
      "诗行编号": "D1136_L07",
      "原文": "不见定王城旧处"
    },
    {
      "诗行编号": "D1136_L08",
      "原文": "长怀贾傅井依然"
    },
    {
      "诗行编号": "D1136_L09",
      "原文": "虚沾焦举为寒食"
    },
    {
      "诗行编号": "D1136_L10",
      "原文": "实藉严君卖卜钱"
    },
    {
      "诗行编号": "D1136_L11",
      "原文": "钟鼎山林各天性"
    },
    {
      "诗行编号": "D1136_L12",
      "原文": "浊醪粗饭任吾年"
    }
  ],
