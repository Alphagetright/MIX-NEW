    {
      "诗行编号": "D1229_L01",
      "原文": "楼雨沾云幔，山寒著水城。"
    },
    {
      "诗行编号": "D1229_L02",
      "原文": "径添沙面出，湍减石棱生。"
    },
    {
      "诗行编号": "D1229_L03",
      "原文": "菊蕊凄疏放，松林驻远情。"
    },
    {
      "诗行编号": "D1229_L04",
      "原文": "滂沱朱槛湿，万虑傍檐楹。"
    }
