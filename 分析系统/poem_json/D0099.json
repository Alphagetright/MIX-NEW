  "诗行": [
    {
      "诗行编号": "D0099_L01",
      "原文": "出门复入门，雨脚但如旧。"
    },
    {
      "诗行编号": "D0099_L02",
      "原文": "所向泥活活，思君令人瘦。"
    },
    {
      "诗行编号": "D0099_L03",
      "原文": "沈吟坐西轩，饮食错昏昼。"
    },
    {
      "诗行编号": "D0099_L04",
      "原文": "寸步曲江头，难为一相就。"
    },
    {
      "诗行编号": "D0099_L05",
      "原文": "吁嗟呼苍生，稼穑不可救。"
    },
    {
      "诗行编号": "D0099_L06",
      "原文": "安得诛云师，畴能补天漏。"
    },
    {
      "诗行编号": "D0099_L07",
      "原文": "大明韬日月，旷野号禽兽。"
    },
    {
      "诗行编号": "D0099_L08",
      "原文": "君子强逶迤，小人困驰骤。"
    },
    {
      "诗行编号": "D0099_L09",
      "原文": "维南有崇山，恐与川浸溜。"
    },
    {
      "诗行编号": "D0099_L10",
      "原文": "是节东篱菊，纷披为谁秀。"
    },
    {
      "诗行编号": "D0099_L11",
      "原文": "岑生多新诗，性亦嗜醇酎。"
    },
    {
      "诗行编号": "D0099_L12",
      "原文": "采采黄金花，何由满衣袖。"
    }
  ],
