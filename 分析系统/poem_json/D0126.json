    {
      "诗行编号": "D0126_L01",
      "原文": "国破山河在，城春草木深。"
    },
    {
      "诗行编号": "D0126_L02",
      "原文": "感时花溅泪，恨别鸟惊心。"
    },
    {
      "诗行编号": "D0126_L03",
      "原文": "烽火连三月，家书抵万金。"
    },
    {
      "诗行编号": "D0126_L04",
      "原文": "白头搔更短，浑欲不胜簪。"
    }
