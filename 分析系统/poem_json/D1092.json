  "诗行": [
    {
      "诗行编号": "D1092_L01",
      "原文": "先帝弓剑远，小臣馀此生。"
    },
    {
      "诗行编号": "D1092_L02",
      "原文": "蹉跎病江汉，不复谒承明。"
    },
    {
      "诗行编号": "D1092_L03",
      "原文": "饯尔白头日，永怀丹凤城。"
    },
    {
      "诗行编号": "D1092_L04",
      "原文": "迟迟恋屈宋，渺渺卧荆衡。"
    },
    {
      "诗行编号": "D1092_L05",
      "原文": "魂断航舸失，天寒沙水清。"
    },
    {
      "诗行编号": "D1092_L06",
      "原文": "肺肝若稍愈，亦上赤霄行。"
    }
  ],
