  "诗行": [
    {
      "诗行编号": "D1039_L01",
      "原文": "阳翟空知处，荆南近得书。"
    },
    {
      "诗行编号": "D1039_L02",
      "原文": "积年仍远别，多难不安居。"
    },
    {
      "诗行编号": "D1039_L03",
      "原文": "多难不安居，多难不安居。"
    },
    {
      "诗行编号": "D1039_L04",
      "原文": "江汉春风起，冰霜昨夜除。"
    },
    {
      "诗行编号": "D1039_L05",
      "原文": "云天犹错莫，花萼尚萧疏。"
    },
    {
      "诗行编号": "D1039_L06",
      "原文": "对酒都疑梦，吟诗正忆渠。"
    },
    {
      "诗行编号": "D1039_L07",
      "原文": "旧时元日会，乡党羡吾庐。"
    }
  ],
