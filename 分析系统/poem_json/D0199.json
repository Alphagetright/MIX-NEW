  "诗行": [
    {
      "诗行编号": "D0199_L01",
      "原文": "爱汝玉山草堂静，高秋爽气相鲜新。"
    },
    {
      "诗行编号": "D0199_L02",
      "原文": "有时自发钟磬响，落日更见渔樵人。"
    },
    {
      "诗行编号": "D0199_L03",
      "原文": "盘剥白鸦谷口栗，饭煮青泥坊底芹。"
    },
    {
      "诗行编号": "D0199_L04",
      "原文": "何为西庄王给事，柴门空闭锁松筠。"
    }
  ],
