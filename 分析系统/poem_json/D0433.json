    {
      "诗行编号": "D0433_L01",
      "原文": "绵州州府何磊落，显庆年中越王作。"
    },
    {
      "诗行编号": "D0433_L02",
      "原文": "孤城西北起高楼，碧瓦朱甍照城郭。"
    },
    {
      "诗行编号": "D0433_L03",
      "原文": "楼下长江百丈清，山头落日半轮明。"
    },
    {
      "诗行编号": "D0433_L04",
      "原文": "君王旧迹今人赏，转见千秋万古情。"
    }
  ],
