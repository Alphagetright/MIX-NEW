    {
      "诗行编号": "D0477_L01",
      "原文": "凭高送所亲，久坐惜芳辰。"
    },
    {
      "诗行编号": "D0477_L02",
      "原文": "远水非无浪，他山自有春。"
    },
    {
      "诗行编号": "D0477_L03",
      "原文": "野花随处发，官柳著行新。"
    },
    {
      "诗行编号": "D0477_L04",
      "原文": "天际伤愁别，离筵何太频。"
    }
