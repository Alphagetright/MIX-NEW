  "诗行": [
    {
      "诗行编号": "D0065_L01",
      "原文": "故人昔隐东蒙峰，已佩含景苍精龙。"
    },
    {
      "诗行编号": "D0065_L02",
      "原文": "故人今居子午谷，独在阴崖结茅屋。"
    },
    {
      "诗行编号": "D0065_L03",
      "原文": "屋前太古玄都坛，青石漠漠常风寒。"
    },
    {
      "诗行编号": "D0065_L04",
      "原文": "子规夜啼山竹裂，王母昼下云旗翻。"
    },
    {
      "诗行编号": "D0065_L05",
      "原文": "知君此计成长往，芝草琅玕日应长。"
    },
    {
      "诗行编号": "D0065_L06",
      "原文": "铁锁高垂不可攀，致身福地何萧爽。"
    }
  ],
