  "诗行": [
    {
      "诗行编号": "D0454_L01",
      "原文": "少保有古风，得之陕郊篇。"
    },
    {
      "诗行编号": "D0454_L02",
      "原文": "惜哉功名忤，但见书画传。"
    },
    {
      "诗行编号": "D0454_L03",
      "原文": "我游梓州东，遗迹涪江边。"
    },
    {
      "诗行编号": "D0454_L04",
      "原文": "画藏青莲界，书入金榜悬。"
    },
    {
      "诗行编号": "D0454_L05",
      "原文": "仰看垂露姿，不崩亦不骞。"
    },
    {
      "诗行编号": "D0454_L06",
      "原文": "郁郁三大字，蛟龙岌相缠。"
    },
    {
      "诗行编号": "D0454_L07",
      "原文": "又挥西方变，发地扶屋椽。"
    },
    {
      "诗行编号": "D0454_L08",
      "原文": "惨澹壁飞动，到今色未填。"
    },
    {
      "诗行编号": "D0454_L09",
      "原文": "此行叠壮观，郭薛俱才贤。"
    },
    {
      "诗行编号": "D0454_L10",
      "原文": "不知百载后，谁复来通泉。"
    }
  ],
