  "诗行": [
    {
      "诗行编号": "D0171_L01",
      "原文": "晚岁迫偷生，还家少欢趣。"
    },
    {
      "诗行编号": "D0171_L02",
      "原文": "娇儿不离膝，畏我复却去。"
    },
    {
      "诗行编号": "D0171_L03",
      "原文": "忆昔好追凉，故绕池边树。"
    },
    {
      "诗行编号": "D0171_L04",
      "原文": "萧萧北风劲，抚事煎百虑。"
    },
    {
      "诗行编号": "D0171_L05",
      "原文": "赖知禾黍收，已觉糟床注。"
    },
    {
      "诗行编号": "D0171_L06",
      "原文": "如今足斟酌，且用慰迟暮。"
    }
  ],
