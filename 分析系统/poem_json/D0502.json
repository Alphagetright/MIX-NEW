  "诗行": [
    {
      "诗行编号": "D0502_L01",
      "原文": "双峰寂寂对春台，万竹青青照客杯。"
    },
    {
      "诗行编号": "D0502_L02",
      "原文": "细草留连侵坐软，残花怅望近人开。"
    },
    {
      "诗行编号": "D0502_L03",
      "原文": "同舟昨日何由得，并马今朝未拟回。"
    },
    {
      "诗行编号": "D0502_L04",
      "原文": "直到绵州始分首，江边树里共谁来。"
    }
  ],
