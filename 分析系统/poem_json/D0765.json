  "诗行": [
    {
      "诗行编号": "D0765_L01",
      "原文": "夔州处女发半华，四十五十无夫家。"
    },
    {
      "诗行编号": "D0765_L02",
      "原文": "更遭丧乱嫁不售，一生抱恨堪咨嗟。"
    },
    {
      "诗行编号": "D0765_L03",
      "原文": "土风坐男使女立，应当门户女出入。"
    },
    {
      "诗行编号": "D0765_L04",
      "原文": "十犹八九负薪归，卖薪得钱应供给。"
    },
    {
      "诗行编号": "D0765_L05",
      "原文": "至老双鬟只垂颈，野花山叶银钗并。"
    },
    {
      "诗行编号": "D0765_L06",
      "原文": "筋力登危集市门，死生射利兼盐井。"
    },
    {
      "诗行编号": "D0765_L07",
      "原文": "面妆首饰杂啼痕，地褊衣寒困石根。"
    },
    {
      "诗行编号": "D0765_L08",
      "原文": "若道巫山女粗丑，何得此有昭君村。"
    }
  ],
