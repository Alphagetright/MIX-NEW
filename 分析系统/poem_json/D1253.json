      "原文": "谁家巧作断肠声"
    },
    {
      "诗行编号": "D1253_L03",
      "原文": "风飘律吕相和切"
    },
    {
      "诗行编号": "D1253_L04",
      "原文": "月傍关山几处明"
    },
    {
      "诗行编号": "D1253_L05",
      "原文": "胡骑中宵堪北走"
    },
    {
      "诗行编号": "D1253_L06",
      "原文": "武陵一曲想南征"
    },
    {
      "诗行编号": "D1253_L07",
      "原文": "故园杨柳今摇落"
    },
    {
