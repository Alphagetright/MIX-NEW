  "诗行": [
    {
      "诗行编号": "D1141_L01",
      "原文": "早宿宾从劳，仲春江山丽。"
    },
    {
      "诗行编号": "D1141_L02",
      "原文": "飘风过无时，舟楫敢不系。"
    },
    {
      "诗行编号": "D1141_L03",
      "原文": "回塘澹暮色，日没众星嘒。"
    },
    {
      "诗行编号": "D1141_L04",
      "原文": "缺月殊未生，青灯死分翳。"
    },
    {
      "诗行编号": "D1141_L05",
      "原文": "穷途多俊异，乱世少恩惠。"
    },
    {
      "诗行编号": "D1141_L06",
      "原文": "鄙夫亦放荡，草草频卒岁。"
    },
    {
      "诗行编号": "D1141_L07",
      "原文": "斯文忧患馀，圣哲垂彖系。"
    }
  ],
