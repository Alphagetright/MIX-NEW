  "诗行": [
    {
      "诗行编号": "D0857_L01",
      "原文": "春雨闇闇塞峡中，早晚来自楚王宫。"
    },
    {
      "诗行编号": "D0857_L02",
      "原文": "乱波分披已打岸，弱云狼籍不禁风。"
    },
    {
      "诗行编号": "D0857_L03",
      "原文": "宠光蕙叶与多碧，点注桃花舒小红。"
    },
    {
      "诗行编号": "D0857_L04",
      "原文": "谷口子真正忆汝，岸高瀼滑限西东。"
    }
  ],
