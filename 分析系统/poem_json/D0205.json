  "诗行": [
    {
      "诗行编号": "D0205_L01",
      "原文": "疾风吹尘暗河县"
    },
    {
      "诗行编号": "D0205_L02",
      "原文": "行子隔手不相见"
    },
    {
      "诗行编号": "D0205_L03",
      "原文": "湖城城南一开眼"
    },
    {
      "诗行编号": "D0205_L04",
      "原文": "驻马偶识云卿面"
    },
    {
      "诗行编号": "D0205_L05",
      "原文": "向非刘颢为地主"
    },
    {
      "诗行编号": "D0205_L06",
      "原文": "懒回鞭辔成高宴"
    },
    {
      "诗行编号": "D0205_L07",
      "原文": "刘侯叹我携客来"
    },
    {
      "诗行编号": "D0205_L08",
      "原文": "置酒张灯促华馔"
    },
    {
      "诗行编号": "D0205_L09",
      "原文": "且将款曲终今夕"
    },
    {
      "诗行编号": "D0205_L10",
      "原文": "休语艰难尚酣战"
    },
    {
      "诗行编号": "D0205_L11",
      "原文": "照室红炉促曙光"
    },
    {
      "诗行编号": "D0205_L12",
      "原文": "萦窗素月垂文练"
    },
    {
      "诗行编号": "D0205_L13",
      "原文": "天开地裂长安陌"
    },
    {
      "诗行编号": "D0205_L14",
      "原文": "寒尽春生洛阳殿"
    },
    {
      "诗行编号": "D0205_L15",
      "原文": "岂知驱车复同轨"
    },
    {
      "诗行编号": "D0205_L16",
      "原文": "可惜刻漏随更箭"
    },
    {
      "诗行编号": "D0205_L17",
      "原文": "人生会合不可常"
    },
    {
      "诗行编号": "D0205_L18",
      "原文": "庭树鸡鸣泪如线"
    }
  ],
