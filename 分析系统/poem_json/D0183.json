  "诗行": [
    {
      "诗行编号": "D0183_L01",
      "原文": "雀啄江头黄柳花，鵁鶄鸂鶒满晴沙。"
    },
    {
      "诗行编号": "D0183_L02",
      "原文": "自知白发非春事，且尽芳尊恋物华。"
    },
    {
      "诗行编号": "D0183_L03",
      "原文": "近侍即今难浪迹，此身那得更无家。"
    },
    {
      "诗行编号": "D0183_L04",
      "原文": "丈人文力犹强健，岂傍青门学种瓜。"
    }
  ],
