  "诗行": [
    {
      "诗行编号": "D0633_L01",
      "原文": "苍江多风飙，云雨昼夜飞。"
    },
    {
      "诗行编号": "D0633_L02",
      "原文": "茅轩驾巨浪，焉得不低垂。"
    },
    {
      "诗行编号": "D0633_L03",
      "原文": "游子久在外，门户无人持。"
    },
    {
      "诗行编号": "D0633_L04",
      "原文": "高岸尚如谷，何伤浮柱攲。"
    },
    {
      "诗行编号": "D0633_L05",
      "原文": "扶颠有劝诫，恐贻识者嗤。"
    },
    {
      "诗行编号": "D0633_L06",
      "原文": "既殊大厦倾，可以一木支。"
    },
    {
      "诗行编号": "D0633_L07",
      "原文": "既殊大厦倾，可以一木支。"
    },
    {
      "诗行编号": "D0633_L08",
      "原文": "临川视万里，何必阑槛为。"
    },
    {
      "诗行编号": "D0633_L09",
      "原文": "人生感故物，慷慨有馀悲。"
    }
  ],
