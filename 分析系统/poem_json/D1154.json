  "诗行": [
    {
      "诗行编号": "D1154_L01",
      "原文": "白日照舟师，朱旗散广川。"
    },
    {
      "诗行编号": "D1154_L02",
      "原文": "群公饯南伯，肃肃秩初筵。"
    },
    {
      "诗行编号": "D1154_L03",
      "原文": "鄙人奉末眷，佩服自早年。"
    },
    {
      "诗行编号": "D1154_L04",
      "原文": "义均骨肉地，怀抱罄所宣。"
    },
    {
      "诗行编号": "D1154_L05",
      "原文": "盛名富事业，无取愧高贤。"
    },
    {
      "诗行编号": "D1154_L06",
      "原文": "不以丧乱婴，保爱金石坚。"
    },
    {
      "诗行编号": "D1154_L07",
      "原文": "计拙百僚下，气苏君子前。"
    },
    {
      "诗行编号": "D1154_L08",
      "原文": "会合苦不久，哀乐本相缠。"
    },
    {
      "诗行编号": "D1154_L09",
      "原文": "交游飒向尽，宿昔浩茫然。"
    },
    {
      "诗行编号": "D1154_L10",
      "原文": "促觞激百虑，掩抑泪潺湲。"
    },
    {
      "诗行编号": "D1154_L11",
      "原文": "热云集曛黑，缺月未生天。"
    },
    {
      "诗行编号": "D1154_L12",
      "原文": "白团为我破，华烛蟠长烟。"
    },
    {
      "诗行编号": "D1154_L13",
      "原文": "鸹鹖催明星，解袂从此旋。"
    },
    {
      "诗行编号": "D1154_L14",
      "原文": "上请减兵甲，下请安井田。"
    },
    {
      "诗行编号": "D1154_L15",
      "原文": "永念病渴老，附书远山巅。"
    }
  ],
