  "诗行": [
    {
      "诗行编号": "D0614_L01",
      "原文": "君王台榭枕巴山，万丈丹梯尚可攀。"
    },
    {
      "诗行编号": "D0614_L02",
      "原文": "春日莺啼脩竹里，仙家犬吠白云间。"
    },
    {
      "诗行编号": "D0614_L03",
      "原文": "清江锦石伤心丽，嫩蕊浓花满目班。"
    },
    {
      "诗行编号": "D0614_L04",
      "原文": "人到于今歌出牧，来游此地不知还。"
    }
  ],
