  "诗行": [
    {
      "诗行编号": "D0073_L01",
      "原文": "缫丝须长不须白，越罗蜀锦金粟尺。"
    },
    {
      "诗行编号": "D0073_L02",
      "原文": "缫丝须长不須白，越罗蜀锦金粟尺。"
    },
    {
      "诗行编号": "D0073_L03",
      "原文": "象床玉手乱殷红，万草千花动凝碧。"
    },
    {
      "诗行编号": "D0073_L04",
      "原文": "已悲素质随时染，裂下鸣机色相射。"
    },
    {
      "诗行编号": "D0073_L05",
      "原文": "美人细意熨帖平，裁缝灭尽针线迹。"
    },
    {
      "诗行编号": "D0073_L06",
      "原文": "春天衣著为君舞，蛱蝶飞来黄鹂语。"
    },
    {
      "诗行编号": "D0073_L07",
      "原文": "落絮游丝亦有情，随风照日宜轻举。"
    },
    {
      "诗行编号": "D0073_L08",
      "原文": "香汗轻尘污颜色，开新合故置何许。"
    },
    {
      "诗行编号": "D0073_L09",
      "原文": "君不见才士汲引难，恐惧弃捐忍羁旅。"
    }
  ],
