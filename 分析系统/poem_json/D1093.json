  "诗行": [
    {
      "诗行编号": "D1093_L01",
      "原文": "羁旅知交态，淹留见俗情。"
    },
    {
      "诗行编号": "D1093_L02",
      "原文": "衰颜聊自哂，小吏最相轻。"
    },
    {
      "诗行编号": "D1093_L03",
      "原文": "去国哀王粲，伤时哭贾生。"
    },
    {
      "诗行编号": "D1093_L04",
      "原文": "狐狸何足道，豺虎正纵横。"
    }
  ],
