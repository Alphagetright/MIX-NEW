  "诗行": [
    {
      "诗行编号": "D0203_L01",
      "原文": "下马古战场，四顾但茫然。"
    },
    {
      "诗行编号": "D0203_L02",
      "原文": "风悲浮云去，黄叶坠我前。"
    },
    {
      "诗行编号": "D0203_L03",
      "原文": "朽骨穴蝼蚁，又为蔓草缠。"
    },
    {
      "诗行编号": "D0203_L04",
      "原文": "故老行叹息，今人尚开边。"
    },
    {
      "诗行编号": "D0203_L05",
      "原文": "汉虏互胜负，封疆不常全。"
    },
    {
      "诗行编号": "D0203_L06",
      "原文": "安得廉耻将，三军同晏眠。"
    }
  ],
