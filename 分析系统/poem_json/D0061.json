  "诗行": [
    {
      "诗行编号": "D0061_L01",
      "原文": "赤县官曹拥材杰"
    },
    {
      "诗行编号": "D0061_L02",
      "原文": "软裘快马当冰雪"
    },
    {
      "诗行编号": "D0061_L03",
      "原文": "长安苦寒谁独悲"
    },
    {
      "诗行编号": "D0061_L04",
      "原文": "杜陵野老骨欲折"
    },
    {
      "诗行编号": "D0061_L05",
      "原文": "南山豆苗早荒秽"
    },
    {
      "诗行编号": "D0061_L06",
      "原文": "青门瓜地新冻裂"
    },
    {
      "诗行编号": "D0061_L07",
      "原文": "乡里儿童项领成"
    },
    {
      "诗行编号": "D0061_L08",
      "原文": "朝廷故旧礼数绝"
    },
    {
      "诗行编号": "D0061_L09",
      "原文": "自然弃掷与时异"
    },
    {
      "诗行编号": "D0061_L10",
      "原文": "况乃疏顽临事拙"
    },
    {
      "诗行编号": "D0061_L11",
      "原文": "自然棄掷与时异"
    },
    {
      "诗行编号": "D0061_L12",
      "原文": "况乃疏顽临事拙"
    },
    {
      "诗行编号": "D0061_L13",
      "原文": "饥卧动即向一旬"
    },
    {
      "诗行编号": "D0061_L14",
      "原文": "敝裘何啻联百结"
    },
    {
      "诗行编号": "D0061_L15",
      "原文": "君不见空墙日色晚"
    },
    {
      "诗行编号": "D0061_L16",
      "原文": "此老无声泪垂血"
    }
