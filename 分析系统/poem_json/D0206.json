  "诗行": [
    {
      "诗行编号": "D0206_L01",
      "原文": "丈人骏马名胡骝，前年避胡过金牛。"
    },
    {
      "诗行编号": "D0206_L02",
      "原文": "回鞭却走见天子，朝饮汉水暮灵州。"
    },
    {
      "诗行编号": "D0206_L03",
      "原文": "自矜胡骝奇绝代，乘出千人万人爱。"
    },
    {
      "诗行编号": "D0206_L04",
      "原文": "一闻说尽急难材，转益愁向驽骀辈。"
    },
    {
      "诗行编号": "D0206_L05",
      "原文": "头上锐耳批秋竹，脚下高蹄削寒玉。"
    },
    {
      "诗行编号": "D0206_L06",
      "原文": "始知神龙别有种，不比俗马空多肉。"
    },
    {
      "诗行编号": "D0206_L07",
      "原文": "洛阳大道时再清，累日喜得俱东行。"
    },
    {
      "诗行编号": "D0206_L08",
      "原文": "凤臆龙鬐未易识，侧身注目长风生。"
    }
  ],
