  "诗行": [
    {
      "诗行编号": "D1121_L01",
      "原文": "洪波忽争道，岸转异江湖。"
    },
    {
      "诗行编号": "D1121_L02",
      "原文": "鄂渚分云树，衡山引舳舻。"
    },
    {
      "诗行编号": "D1121_L03",
      "原文": "翠牙穿裛桨，碧节上寒蒲。"
    },
    {
      "诗行编号": "D1121_L04",
      "原文": "病渴身何去，春生力更无。"
    },
    {
      "诗行编号": "D1121_L05",
      "原文": "壤童犁雨雪，渔屋架泥涂。"
    },
    {
      "诗行编号": "D1121_L06",
      "原文": "欹侧风帆满，微冥水驿孤。"
    },
    {
      "诗行编号": "D1121_L07",
      "原文": "悠悠回赤壁，浩浩略苍梧。"
    },
    {
      "诗行编号": "D1121_L08",
      "原文": "帝子留遗恨，曹公屈壮图。"
    },
    {
      "诗行编号": "D1121_L09",
      "原文": "圣朝光御极，残孽驻艰虞。"
    },
    {
      "诗行编号": "D1121_L10",
      "原文": "才淑随厮养，名贤隐锻炉。"
    },
    {
      "诗行编号": "D1121_L11",
      "原文": "邵平元入汉，张翰后归吴。"
    },
    {
      "诗行编号": "D1121_L12",
      "原文": "莫怪啼痕数，危樯逐夜乌。"
    }
  ],
