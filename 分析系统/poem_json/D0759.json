  "诗行": [
    {
      "诗行编号": "D0759_L01",
      "原文": "白帝空祠庙，孤云自往来。"
    },
    {
      "诗行编号": "D0759_L02",
      "原文": "江山城宛转，栋宇客裴回。"
    },
    {
      "诗行编号": "D0759_L03",
      "原文": "勇略今何在，当年亦壮哉。"
    },
    {
      "诗行编号": "D0759_L04",
      "原文": "后人将酒肉，虚殿日尘埃。"
    },
    {
      "诗行编号": "D0759_L05",
      "原文": "谷鸟鸣还过，林花落又开。"
    },
    {
      "诗行编号": "D0759_L06",
      "原文": "多惭病无力，骑马入青苔。"
    }
  ],
