  "诗行": [
    {
      "诗行编号": "D0384_L01",
      "原文": "忆年十五心尚孩，健如黄犊走复来。"
    },
    {
      "诗行编号": "D0384_L02",
      "原文": "庭前八月梨枣熟，一日上树能千回。"
    },
    {
      "诗行编号": "D0384_L03",
      "原文": "即今倏忽已五十，坐卧只多少行立。"
    },
    {
      "诗行编号": "D0384_L04",
      "原文": "强将笑语供主人，悲见生涯百忧集。"
    },
    {
      "诗行编号": "D0384_L05",
      "原文": "入门依旧四壁空，老妻睹我颜色同。"
    },
    {
      "诗行编号": "D0384_L06",
      "原文": "痴儿未知父子礼，叫怒索饭啼门东。"
    }
  ],
