  "诗行": [
    {
      "诗行编号": "D0028_L01",
      "原文": "李侯有佳句，往往似阴铿。"
    },
    {
      "诗行编号": "D0028_L02",
      "原文": "余亦东蒙客，怜君如弟兄。"
    },
    {
      "诗行编号": "D0028_L03",
      "原文": "醉眠秋共被，携手日同行。"
    },
    {
      "诗行编号": "D0028_L04",
      "原文": "更想幽期处，还寻北郭生。"
    },
    {
      "诗行编号": "D0028_L05",
      "原文": "入门高兴发，侍立小童清。"
    },
    {
      "诗行编号": "D0028_L06",
      "原文": "落景闻寒杵，屯云对古城。"
    },
    {
      "诗行编号": "D0028_L07",
      "原文": "向来吟橘颂，谁欲讨莼羹。"
    },
    {
      "诗行编号": "D0028_L08",
      "原文": "向来吟橘颂，谁欲討莼羹。"
    },
    {
      "诗行编号": "D0028_L09",
      "原文": "不愿论簪笏，悠悠沧海情。"
    }
  ],
