  "诗行": [
    {
      "诗行编号": "D0903_L01",
      "原文": "久游巴子国，屡入武侯祠。"
    },
    {
      "诗行编号": "D0903_L02",
      "原文": "竹日斜虚寝，溪风满薄帷。"
    },
    {
      "诗行编号": "D0903_L03",
      "原文": "君臣当共济，贤圣亦同时。"
    },
