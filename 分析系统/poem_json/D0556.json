    {
      "诗行编号": "D0556_L01",
      "原文": "前有毒蛇后猛虎，溪行尽日无村坞。"
    },
    {
      "诗行编号": "D0556_L02",
      "原文": "江风萧萧云拂地，山木惨惨天欲雨。"
    },
    {
      "诗行编号": "D0556_L03",
      "原文": "女病妻忧归意速，秋花锦石谁复数。"
    },
    {
      "诗行编号": "D0556_L04",
      "原文": "别家三月一得书，避地何时免愁苦。"
    }
  ],
