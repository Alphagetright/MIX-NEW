  "诗行": [
    {
      "诗行编号": "D0158_L01",
      "原文": "送远秋风落，西征海气寒。"
    },
    {
      "诗行编号": "D0158_L02",
      "原文": "帝京氛祲满，人世别离难。"
    },
    {
      "诗行编号": "D0158_L03",
      "原文": "绝域遥怀怒，和亲愿结欢。"
    },
    {
      "诗行编号": "D0158_L04",
      "原文": "敕书怜赞普，兵甲望长安。"
    },
    {
      "诗行编号": "D0158_L05",
      "原文": "宣命前程急，惟良待士宽。"
    },
    {
      "诗行编号": "D0158_L06",
      "原文": "子云清自守，今日起为官。"
    },
    {
      "诗行编号": "D0158_L07",
      "原文": "垂泪方投笔，伤时即据鞍。"
    },
    {
      "诗行编号": "D0158_L08",
      "原文": "儒衣山鸟怪，汉节野童看。"
    },
    {
      "诗行编号": "D0158_L09",
      "原文": "儒衣山鳥怪，汉节野童看。"
    },
    {
      "诗行编号": "D0158_L10",
      "原文": "边酒排金盏，夷歌捧玉盘。"
    },
    {
      "诗行编号": "D0158_L11",
      "原文": "草轻蕃马健，雪重拂庐乾。"
    },
    {
      "诗行编号": "D0158_L12",
      "原文": "慎尔参筹画，从兹正羽翰。"
    },
    {
      "诗行编号": "D0158_L13",
      "原文": "归来权可取，九万一朝抟。"
    }
  ],
