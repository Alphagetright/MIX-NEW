  "诗行": [
    {
      "诗行编号": "D1091_L01",
      "原文": "病鹘孤飞俗眼丑"
    },
    {
      "诗行编号": "D1091_L02",
      "原文": "每夜江边宿衰柳"
    },
    {
      "诗行编号": "D1091_L03",
      "原文": "清秋落日已侧身"
    },
    {
      "诗行编号": "D1091_L04",
      "原文": "过雁归鸦错回首"
    },
    {
      "诗行编号": "D1091_L05",
      "原文": "紧脑雄姿迷所向"
    },
    {
      "诗行编号": "D1091_L06",
      "原文": "疏翮稀毛不可状"
    },
    {
      "诗行编号": "D1091_L07",
      "原文": "强神迷复皂雕前"
    },
    {
      "诗行编号": "D1091_L08",
      "原文": "俊才早在苍鹰上"
    },
    {
      "诗行编号": "D1091_L09",
      "原文": "风涛飒飒寒山阴"
    },
    {
      "诗行编号": "D1091_L10",
      "原文": "熊罴欲蛰龙蛇深"
    },
    {
      "诗行编号": "D1091_L11",
      "原文": "念尔此时有一掷"
    },
    {
      "诗行编号": "D1091_L12",
      "原文": "失声溅血非其心"
    }
  ],
