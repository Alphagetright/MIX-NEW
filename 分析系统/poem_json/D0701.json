  "诗行": [
    {
      "诗行编号": "D0701_L01",
      "原文": "肃肃花絮晚，菲菲红素轻。"
    },
    {
      "诗行编号": "D0701_L02",
      "原文": "日长唯鸟雀，春远独柴荆。"
    },
    {
      "诗行编号": "D0701_L03",
      "原文": "数有关中乱，何曾剑外清。"
    },
    {
      "诗行编号": "D0701_L04",
      "原文": "故乡归不得，地入亚夫营。"
    }
