  "诗行": [
    {
      "诗行编号": "D1192_L01",
      "原文": "炼金欧冶子，喷玉大宛儿。"
    },
    {
      "诗行编号": "D1192_L02",
      "原文": "符彩高无敌，聪明达所为。"
    },
    {
      "诗行编号": "D1192_L03",
      "原文": "梦兰他日应，折桂早年知。"
    },
    {
      "诗行编号": "D1192_L04",
      "原文": "烂漫通经术，光芒刷羽仪。"
    },
    {
      "诗行编号": "D1192_L05",
      "原文": "谢庭瞻不远，潘省会于斯。"
    },
    {
      "诗行编号": "D1192_L06",
      "原文": "倡和将雏曲，田翁号鹿皮。"
    }
  ],
