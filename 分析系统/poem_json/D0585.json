  "诗行": [
    {
      "诗行编号": "D0585_L01",
      "原文": "闻说初东幸，孤儿却走多。"
    },
    {
      "诗行编号": "D0585_L02",
      "原文": "难分太仓粟，竞弃鲁阳戈。"
    },
    {
      "诗行编号": "D0585_L03",
      "原文": "难分太仓粟，竞棄鲁阳戈。"
    },
    {
      "诗行编号": "D0585_L04",
      "原文": "胡虏登前殿，王公出御河。"
    },
    {
      "诗行编号": "D0585_L05",
      "原文": "得无中夜舞，谁忆大风歌。"
    },
    {
      "诗行编号": "D0585_L06",
      "原文": "春色生烽燧，幽人泣薜萝。"
    },
    {
      "诗行编号": "D0585_L07",
      "原文": "君臣重修德，犹足见时和。"
    }
  ],
