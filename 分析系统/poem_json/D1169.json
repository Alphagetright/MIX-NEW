  "诗行": [
    {
      "诗行编号": "D1169_L01",
      "原文": "庞公不浪出，苏氏今有之。"
    },
    {
      "诗行编号": "D1169_L02",
      "原文": "再闻诵新作，突过黄初诗。"
    },
    {
      "诗行编号": "D1169_L03",
      "原文": "乾坤几反覆，扬马宣同时。"
    },
    {
      "诗行编号": "D1169_L04",
      "原文": "今晨清镜中，胜食斋房芝。"
    },
    {
      "诗行编号": "D1169_L05",
      "原文": "余发喜却变，白间生黑丝。"
    },
    {
      "诗行编号": "D1169_L06",
      "原文": "昨夜舟火灭，湘娥帘外悲。"
    },
    {
      "诗行编号": "D1169_L07",
      "原文": "百灵未敢散，风破寒江迟。"
    }
  ],
