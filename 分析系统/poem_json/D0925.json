  "诗行": [
    {
      "诗行编号": "D0925_L01",
      "原文": "天池马不到，岚壁鸟才通。"
    },
    {
      "诗行编号": "D0925_L02",
      "原文": "百顷青云杪，层波白石中。"
    },
    {
      "诗行编号": "D0925_L03",
      "原文": "郁纡腾秀气，萧瑟浸寒空。"
    },
    {
      "诗行编号": "D0925_L04",
      "原文": "直对巫山出，兼疑夏禹功。"
    },
    {
      "诗行编号": "D0925_L05",
      "原文": "鱼龙开辟有，菱芡古今同。"
    },
    {
      "诗行编号": "D0925_L06",
      "原文": "闻道奔雷黑，初看浴日红。"
    },
    {
      "诗行编号": "D0925_L07",
      "原文": "飘零神女雨，断续楚王风。"
    },
    {
      "诗行编号": "D0925_L08",
      "原文": "欲问支机石，如临献宝宫。"
    },
    {
      "诗行编号": "D0925_L09",
      "原文": "九秋惊雁序，万里狎渔翁。"
    },
    {
      "诗行编号": "D0925_L10",
      "原文": "更是无人处，诛茅任薄躬。"
    }
  ],
