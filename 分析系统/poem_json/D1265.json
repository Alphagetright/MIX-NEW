  "诗行": [
    {
      "诗行编号": "D1265_L01",
      "原文": "长啸宇宙间，高才日陵替。"
    },
    {
      "诗行编号": "D1265_L02",
      "原文": "古人不可见，前辈复谁继。"
    },
    {
      "诗行编号": "D1265_L03",
      "原文": "忆昔李公存，词林有根柢。"
    },
    {
      "诗行编号": "D1265_L04",
      "原文": "声华当健笔，洒落富清制。"
    },
    {
      "诗行编号": "D1265_L05",
      "原文": "风流散金石，追琢山岳锐。"
    },
    {
      "诗行编号": "D1265_L06",
      "原文": "情穷造化理，学贯天人际。"
    },
    {
      "诗行编号": "D1265_L07",
      "原文": "干谒走其门，碑版照四裔。"
    },
    {
      "诗行编号": "D1265_L08",
      "原文": "各满深望还，森然起凡例。"
    },
    {
      "诗行编号": "D1265_L09",
      "原文": "萧萧白杨路，洞彻宝珠惠。"
    },
    {
      "诗行编号": "D1265_L10",
      "原文": "龙宫塔庙涌，浩劫浮云卫。"
    },
    {
      "诗行编号": "D1265_L11",
      "原文": "慷慨嗣真作，咨嗟玉山桂。"
    },
    {
      "诗行编号": "D1265_L12",
      "原文": "郎吟六公篇，忧来豁蒙蔽。"
    }
  ],
