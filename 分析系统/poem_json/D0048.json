  "诗行": [
    {
      "诗行编号": "D0048_L01",
      "原文": "左辖频虚位，今年得旧儒。"
    },
    {
      "诗行编号": "D0048_L02",
      "原文": "相门韦氏在，经术汉臣须。"
    },
    {
      "诗行编号": "D0048_L03",
      "原文": "时议归前烈，天伦恨莫俱。"
    },
    {
      "诗行编号": "D0048_L04",
      "原文": "鸰原荒宿草，凤沼接亨衢。"
    },
    {
      "诗行编号": "D0048_L05",
      "原文": "有客虽安命，衰容岂壮夫。"
    },
    {
      "诗行编号": "D0048_L06",
      "原文": "有客虽安命，衰容豈壮夫。"
    },
    {
      "诗行编号": "D0048_L07",
      "原文": "家人忧几杖，甲子混泥途。"
    },
    {
      "诗行编号": "D0048_L08",
      "原文": "不谓矜馀力，还来谒大巫。"
    },
    {
      "诗行编号": "D0048_L09",
      "原文": "岁寒仍顾遇，日暮且踟蹰。"
    },
    {
      "诗行编号": "D0048_L10",
      "原文": "老骥思千里，饥鹰待一呼。"
    },
    {
      "诗行编号": "D0048_L11",
      "原文": "君能微感激，亦足慰榛芜。"
    }
  ],
