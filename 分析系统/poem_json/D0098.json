      "诗行编号": "D0098_L02",
      "原文": "故人官就此，绝境兴谁同。"
    },
    {
      "诗行编号": "D0098_L03",
      "原文": "隐吏逢梅福，游山忆谢公。"
    },
    {
      "诗行编号": "D0098_L04",
      "原文": "扁舟吾已就，把钓待秋风。"
