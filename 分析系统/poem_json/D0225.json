  "诗行": [
    {
      "诗行编号": "D0225_L01",
      "原文": "寂寞天宝后，园庐但蒿藜。"
    },
    {
      "诗行编号": "D0225_L02",
      "原文": "我里百馀家，世乱各东西。"
    },
    {
      "诗行编号": "D0225_L03",
      "原文": "存者无消息，死者为尘泥。"
    },
    {
      "诗行编号": "D0225_L04",
      "原文": "贱子因阵败，归来寻旧蹊。"
    },
    {
      "诗行编号": "D0225_L05",
      "原文": "人行见空巷，日瘦气惨悽。"
    },
    {
      "诗行编号": "D0225_L06",
      "原文": "但对狐与狸，竖毛怒我啼。"
    },
    {
      "诗行编号": "D0225_L07",
      "原文": "四邻何所有，一二老寡妻。"
    },
    {
      "诗行编号": "D0225_L08",
      "原文": "宿鸟恋本枝，安辞且穷栖。"
    },
    {
      "诗行编号": "D0225_L09",
      "原文": "方春独荷锄，日暮还灌畦。"
    },
    {
      "诗行编号": "D0225_L10",
      "原文": "县吏知我至，召令习鼓鞞。"
    },
    {
      "诗行编号": "D0225_L11",
      "原文": "虽从本州役，内顾无所携。"
    },
    {
      "诗行编号": "D0225_L12",
      "原文": "近行止一身，远去终转迷。"
    },
    {
      "诗行编号": "D0225_L13",
      "原文": "家乡既荡尽，远近理亦齐。"
    },
    {
      "诗行编号": "D0225_L14",
      "原文": "永痛长病母，五年委沟溪。"
    },
    {
      "诗行编号": "D0225_L15",
      "原文": "生我不得力，终身两酸嘶。"
    },
    {
      "诗行编号": "D0225_L16",
      "原文": "人生无家别，何以为烝黎。"
    }
  ],
