    {
      "诗行编号": "D0676_L01",
      "原文": "绿竹半含箨，新梢才出墙。"
    },
    {
      "诗行编号": "D0676_L02",
      "原文": "色侵书帙晚，阴过酒樽凉。"
    },
    {
      "诗行编号": "D0676_L03",
      "原文": "雨洗娟娟净，风吹细细香。"
    },
    {
      "诗行编号": "D0676_L04",
      "原文": "但令无剪伐，会见拂云长。"
    }
