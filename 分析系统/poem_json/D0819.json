    {
      "诗行编号": "D0819_L01",
      "原文": "客下荆南尽，君今复入舟。"
    },
    {
      "诗行编号": "D0819_L02",
      "原文": "买薪犹白帝，鸣橹少沙头。"
    },
    {
      "诗行编号": "D0819_L03",
      "原文": "衡霍生春早，潇湘共海浮。"
    },
    {
      "诗行编号": "D0819_L04",
      "原文": "荒林庾信宅，为仗主人留。"
    }
