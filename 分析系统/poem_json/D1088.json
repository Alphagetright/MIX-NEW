      "诗行编号": "D1088_L01",
      "原文": "江汉思归客，乾坤一腐儒。"
    },
    {
      "诗行编号": "D1088_L02",
      "原文": "片云天共远，永夜月同孤。"
    },
    {
      "诗行编号": "D1088_L03",
      "原文": "落日心犹壮，秋风病欲疏。"
    },
    {
      "诗行编号": "D1088_L04",
      "原文": "古来存老马，不必取长途。"
    }
