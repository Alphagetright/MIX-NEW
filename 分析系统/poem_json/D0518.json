      "诗行编号": "D0518_L01",
      "原文": "前者途中一相见，人事经年记君面。"
    },
    {
      "诗行编号": "D0518_L02",
      "原文": "后生相动何寂寥，君有长才不贫贱。"
    },
    {
      "诗行编号": "D0518_L03",
      "原文": "后生相动何寂寥，君有长才不贫賤。"
    },
    {
      "诗行编号": "D0518_L04",
      "原文": "君今起柁春江流，余亦沙边具小舟。"
    },
    {
      "诗行编号": "D0518_L05",
      "原文": "幸为达书贤府主，江花未尽会江楼。"
    }
