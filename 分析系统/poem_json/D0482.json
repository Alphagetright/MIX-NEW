  "诗行": [
    {
      "诗行编号": "D0482_L01",
      "原文": "童稚情亲四十年，中间消息两茫然。"
    },
    {
      "诗行编号": "D0482_L02",
      "原文": "更为后会知何地，忽漫相逢是别筵。"
    },
    {
      "诗行编号": "D0482_L03",
      "原文": "不分桃花红胜锦，生憎柳絮白于绵。"
    },
    {
      "诗行编号": "D0482_L04",
      "原文": "不分桃花红勝锦，生憎柳絮白于绵。"
    },
    {
      "诗行编号": "D0482_L05",
      "原文": "剑南春色还无赖，触忤愁人到酒边。"
    }
