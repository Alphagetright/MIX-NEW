      "原文": "自怪一日声辉赫"
    },
    {
      "诗行编号": "D0707_L05",
      "原文": "集贤学士如堵墙"
    },
    {
      "诗行编号": "D0707_L06",
      "原文": "观我落笔中书堂"
    },
    {
      "诗行编号": "D0707_L07",
      "原文": "往时文彩动人主"
    },
    {
      "诗行编号": "D0707_L08",
      "原文": "此日饥寒趋路旁"
    },
    {
      "诗行编号": "D0707_L09",
      "原文": "晚将末契托年少"
    },
    {
      "诗行编号": "D0707_L10",
      "原文": "当面输心背面笑"
    },
    {
      "诗行编号": "D0707_L11",
      "原文": "寄谢悠悠世上儿"
    },
    {
      "诗行编号": "D0707_L12",
      "原文": "不争好恶莫相疑"
    }
