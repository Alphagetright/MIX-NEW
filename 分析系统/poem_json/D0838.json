  "诗行": [
    {
      "诗行编号": "D0838_L01",
      "原文": "江阁要宾许马迎，午时起坐自天明。"
    },
    {
      "诗行编号": "D0838_L02",
      "原文": "浮云不负青春色，细雨何孤白帝城。"
    },
    {
      "诗行编号": "D0838_L03",
      "原文": "身过花间沾湿好，醉于马上往来轻。"
    },
    {
      "诗行编号": "D0838_L04",
      "原文": "虚疑皓首冲泥怯，实少银鞍傍险行。"
    }
  ],
