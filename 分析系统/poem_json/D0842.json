    {
      "诗行编号": "D0842_L01",
      "原文": "久雨巫山暗，新晴锦绣文。"
    },
    {
      "诗行编号": "D0842_L02",
      "原文": "碧知湖外草，红见海东云。"
    },
    {
      "诗行编号": "D0842_L03",
      "原文": "竟日莺相和，摩霄鹤数群。"
    },
    {
      "诗行编号": "D0842_L04",
      "原文": "野花乾更落，风处急纷纷。"
    }
  ],
