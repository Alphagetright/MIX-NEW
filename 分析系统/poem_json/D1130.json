  "诗行": [
    {
      "诗行编号": "D1130_L01",
      "原文": "减米散同舟，路难恩共济。"
    },
    {
      "诗行编号": "D1130_L02",
      "原文": "向来云涛盘，众力亦不细。"
    },
    {
      "诗行编号": "D1130_L03",
      "原文": "呀坑瞥眼过，飞橹本无蒂。"
    },
    {
      "诗行编号": "D1130_L04",
      "原文": "得失瞬息间，致远宜恐泥。"
    },
    {
      "诗行编号": "D1130_L05",
      "原文": "百虑视安危，分明曩贤计。"
    },
    {
      "诗行编号": "D1130_L06",
      "原文": "百虑视安危，分明曩賢计。"
    },
    {
      "诗行编号": "D1130_L07",
      "原文": "兹理庶可广，拳拳期勿替。"
    }
  ],
