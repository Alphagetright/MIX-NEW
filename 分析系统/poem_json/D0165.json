  "诗行": [
    {
      "诗行编号": "D0165_L01",
      "原文": "明公壮年值时危"
    },
    {
      "诗行编号": "D0165_L02",
      "原文": "经济实藉英雄姿"
    },
    {
      "诗行编号": "D0165_L03",
      "原文": "国之社稷今若是"
    },
    {
      "诗行编号": "D0165_L04",
      "原文": "武定祸乱非公谁"
    },
    {
      "诗行编号": "D0165_L05",
      "原文": "凤翔千官且饱饭"
    },
    {
      "诗行编号": "D0165_L06",
      "原文": "衣马不复能轻肥"
    },
    {
      "诗行编号": "D0165_L07",
      "原文": "青袍朝士最困者"
    },
    {
      "诗行编号": "D0165_L08",
      "原文": "白头拾遗徒步归"
    },
    {
      "诗行编号": "D0165_L09",
      "原文": "人生交契无老少"
    },
    {
      "诗行编号": "D0165_L10",
      "原文": "论交何必先同调"
    },
    {
      "诗行编号": "D0165_L11",
      "原文": "妻子山中哭向天"
    },
    {
      "诗行编号": "D0165_L12",
      "原文": "须公枥上追风骠"
    }
  ],
