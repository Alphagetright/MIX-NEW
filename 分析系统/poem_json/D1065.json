  "诗行": [
    {
      "诗行编号": "D1065_L01",
      "原文": "自古求忠孝，名家信有之。"
    },
    {
      "诗行编号": "D1065_L02",
      "原文": "吾贤富才术，此道未磷缁。"
    },
    {
      "诗行编号": "D1065_L03",
      "原文": "玉府标孤映，霜蹄去不疑。"
    },
    {
      "诗行编号": "D1065_L04",
      "原文": "激扬音韵彻，籍甚众多推。"
    },
    {
      "诗行编号": "D1065_L05",
      "原文": "潘陆应同调，孙吴亦异时。"
    },
    {
      "诗行编号": "D1065_L06",
      "原文": "北辰徵事业，南纪赴恩私。"
    },
    {
      "诗行编号": "D1065_L07",
      "原文": "卿月升金掌，王春度玉墀。"
    },
    {
      "诗行编号": "D1065_L08",
      "原文": "熏风行应律，湛露即歌诗。"
    },
    {
      "诗行编号": "D1065_L09",
      "原文": "天意高难问，人情老易悲。"
    },
    {
      "诗行编号": "D1065_L10",
      "原文": "尊前江汉阔，后会且深期。"
    }
  ],
