  "诗行": [
    {
      "诗行编号": "D0025_L01",
      "原文": "野亭逼湖水，歇马高林间。"
    },
    {
      "诗行编号": "D0025_L02",
      "原文": "鼍吼风奔浪，鱼跳日映山。"
    },
    {
      "诗行编号": "D0025_L03",
      "原文": "暂游阻词伯，却望怀青关。"
    },
    {
      "诗行编号": "D0025_L04",
      "原文": "霭霭生云雾，唯应促驾还。"
    }
