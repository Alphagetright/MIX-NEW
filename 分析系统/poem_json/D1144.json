  "诗行": [
    {
      "诗行编号": "D1144_L01",
      "原文": "南岳自兹近，湘流东逝深。"
    },
    {
      "诗行编号": "D1144_L02",
      "原文": "和风引桂楫，春日涨云岑。"
    },
    {
      "诗行编号": "D1144_L03",
      "原文": "回首过津口，而多枫树林。"
    },
    {
      "诗行编号": "D1144_L04",
      "原文": "白鱼困密网，黄鸟喧嘉音。"
    },
    {
      "诗行编号": "D1144_L05",
      "原文": "物微限通塞，恻隐仁者心。"
    },
    {
      "诗行编号": "D1144_L06",
      "原文": "瓮馀不尽酒，膝有无声琴。"
    },
    {
      "诗行编号": "D1144_L07",
      "原文": "圣贤两寂寞，眇眇独开襟。"
    }
  ],
