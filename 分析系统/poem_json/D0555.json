  "诗行": [
    {
      "诗行编号": "D0555_L01",
      "原文": "雄都元壮丽，望幸歘威神。"
    },
    {
      "诗行编号": "D0555_L02",
      "原文": "地利西通蜀，天文北照秦。"
    },
    {
      "诗行编号": "D0555_L03",
      "原文": "风烟含越鸟，舟楫控吴人。"
    },
    {
      "诗行编号": "D0555_L04",
      "原文": "未枉周王驾，终期汉武巡。"
    },
    {
      "诗行编号": "D0555_L05",
      "原文": "甲兵分圣旨，居守付宗臣。"
    },
    {
      "诗行编号": "D0555_L06",
      "原文": "早发云台杖，恩波起涸鳞。"
    }
  ],
