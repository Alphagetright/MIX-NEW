  "诗行": [
    {
      "诗行编号": "D0378_L01",
      "原文": "君不见徐卿二子生绝奇，感应吉梦相追随。"
    },
    {
      "诗行编号": "D0378_L02",
      "原文": "孔子释氏亲抱送，并是天上麒麟儿。"
    },
    {
      "诗行编号": "D0378_L03",
      "原文": "大儿九龄色清澈，秋水为神玉为骨。"
    },
    {
      "诗行编号": "D0378_L04",
      "原文": "小儿五岁气食牛，满堂宾客皆回头。"
    },
    {
      "诗行编号": "D0378_L05",
      "原文": "吾知徐公百不忧，积善衮衮生公侯。"
    },
    {
      "诗行编号": "D0378_L06",
      "原文": "丈夫生儿有如此二雏者，名位岂肯悲微休。"
    }
  ],
