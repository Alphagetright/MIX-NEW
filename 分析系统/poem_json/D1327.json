  "诗行": [
    {
      "诗行编号": "D1327_L01",
      "原文": "林僻来人少，山长去鸟微。"
    },
    {
      "诗行编号": "D1327_L02",
      "原文": "高秋收画扇，久客掩荆扉。"
    },
    {
      "诗行编号": "D1327_L03",
      "原文": "懒慢头时栉，艰难带减围。"
    },
    {
      "诗行编号": "D1327_L04",
      "原文": "将军犹汗马，天子尚戎衣。"
    },
    {
      "诗行编号": "D1327_L05",
      "原文": "白蒋风飙脆，殷柽晓夜稀。"
    },
    {
      "诗行编号": "D1327_L06",
      "原文": "何年减豺虎，似有故园归。"
    }
  ],
