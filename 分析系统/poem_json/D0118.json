  "诗行": [
    {
      "诗行编号": "D0118_L01",
      "原文": "将军昔著从事衫，铁马驰突重两衔。"
    },
    {
      "诗行编号": "D0118_L02",
      "原文": "披坚执锐略西极，昆崙月窟东崭岩。"
    },
    {
      "诗行编号": "D0118_L03",
      "原文": "君门羽林万猛士，恶若哮虎子所监。"
    },
    {
      "诗行编号": "D0118_L04",
      "原文": "五年起家列霜戟，一日过海收风帆。"
    },
    {
      "诗行编号": "D0118_L05",
      "原文": "平生流辈徒蠢蠢，长安少年气欲尽。"
    },
    {
      "诗行编号": "D0118_L06",
      "原文": "魏侯骨耸精爽紧，华岳峰尖见秋隼。"
    },
    {
      "诗行编号": "D0118_L07",
      "原文": "星躔宝校金盘陀，夜骑天驷超天河。"
    },
    {
      "诗行编号": "D0118_L08",
      "原文": "欃枪荧惑不敢动，翠蕤云旓相荡摩。"
    },
    {
      "诗行编号": "D0118_L09",
      "原文": "吾为子起歌都护，酒阑插剑肝胆露。"
    },
    {
      "诗行编号": "D0118_L10",
      "原文": "钩陈苍苍风玄武，万岁千秋奉明主。"
    },
    {
      "诗行编号": "D0118_L11",
      "原文": "临江节士安足数。"
    }
  ],
