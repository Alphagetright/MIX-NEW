  "诗行": [
    {
      "诗行编号": "D1132_L01",
      "原文": "春生南国瘴，气待北风苏。"
    },
    {
      "诗行编号": "D1132_L02",
      "原文": "向晚霾残日，初宵鼓大炉。"
    },
    {
      "诗行编号": "D1132_L03",
      "原文": "爽携卑湿地，声拔洞庭湖。"
    },
    {
      "诗行编号": "D1132_L04",
      "原文": "万里鱼龙伏，三更鸟兽呼。"
    },
    {
      "诗行编号": "D1132_L05",
      "原文": "涤除贪破浪，愁绝付摧枯。"
    },
    {
      "诗行编号": "D1132_L06",
      "原文": "执热沈沈在，凌寒往往须。"
    },
    {
      "诗行编号": "D1132_L07",
      "原文": "且知宽疾肺，不敢恨危途。"
    },
    {
      "诗行编号": "D1132_L08",
      "原文": "再宿烦舟子，衰容问仆夫。"
    },
    {
      "诗行编号": "D1132_L09",
      "原文": "今晨非盛怒，便道即长驱。"
    },
    {
      "诗行编号": "D1132_L10",
      "原文": "隐几看帆席，云山涌坐隅。"
    }
  ],
