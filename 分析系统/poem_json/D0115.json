  "诗行": [
    {
      "诗行编号": "D0115_L01",
      "原文": "陆机二十作文赋，汝更小年能缀文。"
    },
    {
      "诗行编号": "D0115_L02",
      "原文": "总角草书又神速，世上儿子徒纷纷。"
    },
    {
      "诗行编号": "D0115_L03",
      "原文": "骅骝作驹已汗血，鸷鸟举翮连青云。"
    },
    {
      "诗行编号": "D0115_L04",
      "原文": "词源倒流三峡水，笔阵独扫千人军。"
    },
    {
      "诗行编号": "D0115_L05",
      "原文": "只今年才十六七，射策君门期第一。"
    },
    {
      "诗行编号": "D0115_L06",
      "原文": "旧穿杨叶真自知，暂蹶霜蹄未为失。"
    },
    {
      "诗行编号": "D0115_L07",
      "原文": "偶然擢秀非难取，会是排风有毛质。"
    },
    {
      "诗行编号": "D0115_L08",
      "原文": "汝身已见唾成珠，汝伯何由发如漆。"
    },
    {
      "诗行编号": "D0115_L09",
      "原文": "春光澹荡秦东亭，渚蒲牙白水荇青。"
    },
    {
      "诗行编号": "D0115_L10",
      "原文": "风吹客衣日杲杲，树搅离思花冥冥。"
    },
    {
      "诗行编号": "D0115_L11",
      "原文": "酒尽沙头双玉瓶，众宾皆醉我独醒。"
    },
    {
      "诗行编号": "D0115_L12",
      "原文": "乃知贫贱别更苦，吞声踯躅涕泪零。"
    }
  ],
