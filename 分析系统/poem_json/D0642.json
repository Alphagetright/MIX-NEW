  "诗行": [
    {
      "诗行编号": "D0642_L01",
      "原文": "关内昔分袂，天边今转蓬。"
    },
    {
      "诗行编号": "D0642_L02",
      "原文": "驱驰不可说，谈笑偶然同。"
    },
    {
      "诗行编号": "D0642_L03",
      "原文": "长啸峨嵋北，潜行玉垒东。"
    },
    {
      "诗行编号": "D0642_L04",
      "原文": "有时骑猛虎，虚室使仙童。"
    },
    {
      "诗行编号": "D0642_L05",
      "原文": "发少何劳白，颜衰肯更红。"
    },
    {
      "诗行编号": "D0642_L06",
      "原文": "望云悲轗轲，毕景羡冲融。"
    },
    {
      "诗行编号": "D0642_L07",
      "原文": "望云悲轗軻，毕景羡冲融。"
    },
    {
      "诗行编号": "D0642_L08",
      "原文": "永作殊方客，残生一老翁。"
    },
    {
      "诗行编号": "D0642_L09",
      "原文": "相哀骨可换，亦遣驭清风。"
    }
  ],
