  "诗行": [
    {
      "诗行编号": "D0631_L01",
      "原文": "小径升堂旧不斜，五株桃树亦从遮。"
    },
    {
      "诗行编号": "D0631_L02",
      "原文": "高秋总喂贫人实，来岁还舒满眼花。"
    },
    {
      "诗行编号": "D0631_L03",
      "原文": "帘户每宜通乳燕，儿童莫信打慈鸦。"
    },
    {
      "诗行编号": "D0631_L04",
      "原文": "寡妻群盗非今日，天下车书正一家。"
    }
  ],
