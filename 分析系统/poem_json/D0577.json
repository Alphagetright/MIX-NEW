  "诗行": [
    {
      "诗行编号": "D0577_L01",
      "原文": "天下兵虽满，春光日自浓。"
    },
    {
      "诗行编号": "D0577_L02",
      "原文": "西京疲百战，北阙任群凶。"
    },
    {
      "诗行编号": "D0577_L03",
      "原文": "关塞三千里，烟花一万重。"
    },
    {
      "诗行编号": "D0577_L04",
      "原文": "蒙尘清路急，御宿且谁供。"
    },
    {
      "诗行编号": "D0577_L05",
      "原文": "殷复前王道，周迁旧国容。"
    },
    {
      "诗行编号": "D0577_L06",
      "原文": "蓬莱足云气，应合总从龙。"
    }
  ],
