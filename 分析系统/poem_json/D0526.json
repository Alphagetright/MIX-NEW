      "原文": "汉光得天下，祚永固有开。"
    },
    {
      "诗行编号": "D0526_L02",
      "原文": "岂惟高祖圣，功自萧曹来。"
    },
    {
      "诗行编号": "D0526_L03",
      "原文": "经纶中兴业，何代无长才。"
    },
    {
      "诗行编号": "D0526_L04",
      "原文": "吾慕寇邓勋，济时信良哉。"
    },
    {
      "诗行编号": "D0526_L05",
      "原文": "耿贾亦宗臣，羽翼共裴回。"
    },
    {
      "诗行编号": "D0526_L06",
      "原文": "休运终四百，图画在云台。"
    }
