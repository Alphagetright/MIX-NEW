  "诗行": [
    {
      "诗行编号": "D0137_L01",
      "原文": "不谓生戎马，何知共酒杯。"
    },
    {
      "诗行编号": "D0137_L02",
      "原文": "然脐郿坞败，握节汉臣回。"
    },
    {
      "诗行编号": "D0137_L03",
      "原文": "白发千茎雪，丹心一寸灰。"
    },
    {
      "诗行编号": "D0137_L04",
      "原文": "别离经死地，披写忽登台。"
    },
    {
      "诗行编号": "D0137_L05",
      "原文": "重对秦箫发，俱过阮宅来。"
    },
    {
      "诗行编号": "D0137_L06",
      "原文": "留连春夜舞，泪落强裴回。"
    }
  ],
