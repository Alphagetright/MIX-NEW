  "诗行": [
    {
      "诗行编号": "D0561_L01",
      "原文": "江心蟠石生桃竹，苍波喷浸尺度足。"
    },
    {
      "诗行编号": "D0561_L02",
      "原文": "斩根削皮如紫玉，江妃水仙惜不得。"
    },
    {
      "诗行编号": "D0561_L03",
      "原文": "梓潼使君开一束，满堂宾客皆叹息。"
    },
    {
      "诗行编号": "D0561_L04",
      "原文": "怜我老病赠两茎，出入爪甲铿有声。"
    },
    {
      "诗行编号": "D0561_L05",
      "原文": "老夫复欲东南征，乘涛鼓枻白帝城。"
    },
    {
      "诗行编号": "D0561_L06",
      "原文": "路幽必为鬼神夺，拔剑或与蛟龙争。"
    },
    {
      "诗行编号": "D0561_L07",
      "原文": "重为告曰，杖兮！尔之生也甚正直。"
    },
    {
      "诗行编号": "D0561_L08",
      "原文": "慎勿见水踊跃学变化为龙，使我不得尔之扶持。"
    },
    {
      "诗行编号": "D0561_L09",
      "原文": "灭迹于君山湖上之青峰，噫！风尘澒洞兮豺虎咬人。"
    },
    {
      "诗行编号": "D0561_L10",
      "原文": "忽失双杖兮吾将曷从。"
    }
  ],
