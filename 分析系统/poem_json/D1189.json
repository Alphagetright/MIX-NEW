  "诗行": [
    {
      "诗行编号": "D1189_L01",
      "原文": "贤良归盛族，吾舅尽知名。"
    },
    {
      "诗行编号": "D1189_L02",
      "原文": "徐庶高交友，刘牢出外甥。"
    },
    {
      "诗行编号": "D1189_L03",
      "原文": "泥涂岂珠玉，环堵但柴荆。"
    },
    {
      "诗行编号": "D1189_L04",
      "原文": "衰老悲人世，驱驰厌甲兵。"
    },
    {
      "诗行编号": "D1189_L05",
      "原文": "气春江上别，泪血渭阳情。"
    },
    {
      "诗行编号": "D1189_L06",
      "原文": "舟鹢排风影，林乌反哺声。"
    },
    {
      "诗行编号": "D1189_L07",
      "原文": "永嘉多北至，句漏且南征。"
    },
    {
      "诗行编号": "D1189_L08",
      "原文": "必见公侯复，终闻盗贼平。"
    },
    {
      "诗行编号": "D1189_L09",
      "原文": "郴州颇凉冷，橘井尚凄清。"
    },
    {
      "诗行编号": "D1189_L10",
      "原文": "从役何蛮貊，居官志在行。"
    }
  ],
