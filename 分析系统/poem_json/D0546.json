  "诗行": [
    {
      "诗行编号": "D0546_L01",
      "原文": "尘满莱芜甑，"
    },
    {
      "诗行编号": "D0546_L02",
      "原文": "堂横单父琴。"
    },
    {
      "诗行编号": "D0546_L03",
      "原文": "人皆知饮水，"
    },
    {
      "诗行编号": "D0546_L04",
      "原文": "公辈不偷金。"
    },
    {
      "诗行编号": "D0546_L05",
      "原文": "梁狱书因上，"
    },
    {
      "诗行编号": "D0546_L06",
      "原文": "秦台镜欲临。"
    },
    {
      "诗行编号": "D0546_L07",
      "原文": "独醒时所嫉，"
    },
    {
      "诗行编号": "D0546_L08",
      "原文": "群小谤能深。"
    },
    {
      "诗行编号": "D0546_L09",
      "原文": "即出黄沙在，"
    },
    {
      "诗行编号": "D0546_L10",
      "原文": "何须白发侵。"
    },
    {
      "诗行编号": "D0546_L11",
      "原文": "使君传旧德，"
    },
    {
      "诗行编号": "D0546_L12",
      "原文": "已见直绳心。"
    }
  ],
