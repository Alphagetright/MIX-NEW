  "诗行": [
    {
      "诗行编号": "D0241_L01",
      "原文": "天台隔三江，风浪无晨暮。"
    },
    {
      "诗行编号": "D0241_L02",
      "原文": "郑公纵得归，老病不识路。"
    },
    {
      "诗行编号": "D0241_L03",
      "原文": "昔如水上鸥，今如罝中兔。"
    },
    {
      "诗行编号": "D0241_L04",
      "原文": "性命由他人，悲辛但狂顾。"
    },
    {
      "诗行编号": "D0241_L05",
      "原文": "山鬼独一脚，蝮蛇长如树。"
    },
    {
      "诗行编号": "D0241_L06",
      "原文": "呼号傍孤城，岁月谁与度。"
    },
    {
      "诗行编号": "D0241_L07",
      "原文": "从来御魑魅，多为才名误。"
    },
    {
      "诗行编号": "D0241_L08",
      "原文": "夫子嵇阮流，更被时俗恶。"
    },
    {
      "诗行编号": "D0241_L09",
      "原文": "海隅微小吏，眼暗发垂素。"
    },
    {
      "诗行编号": "D0241_L10",
      "原文": "黄帽映青袍，非供折腰具。"
    },
    {
      "诗行编号": "D0241_L11",
      "原文": "平生一杯酒，见我故人遇。"
    },
    {
      "诗行编号": "D0241_L12",
      "原文": "相望无所成，乾坤莽回互。"
    }
  ],
