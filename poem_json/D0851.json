  "诗行": [
    {
      "诗行编号": "D0851_L01",
      "原文": "卧病拥塞在峡中，潇湘洞庭虚映空。"
    },
    {
      "诗行编号": "D0851_L02",
      "原文": "楚天不断四时雨，巫峡常吹千里风。"
    },
    {
      "诗行编号": "D0851_L03",
      "原文": "沙上草阁柳新闇，城边野池莲欲红。"
    },
    {
      "诗行编号": "D0851_L04",
      "原文": "暮春鸳鹭立洲渚，挟子翻飞还一丛。"
    }
  ],
