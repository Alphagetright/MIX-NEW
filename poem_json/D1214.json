  "诗行": [
    {
      "诗行编号": "D1214_L01",
      "原文": "轩辕休制律，虞舜罢弹琴。"
    },
    {
      "诗行编号": "D1214_L02",
      "原文": "尚错雄鸣管，犹伤半死心。"
    },
    {
      "诗行编号": "D1214_L03",
      "原文": "圣贤名古邈，羁旅病年侵。"
    },
    {
      "诗行编号": "D1214_L04",
      "原文": "舟泊常依震，湖平早见参。"
    },
    {
      "诗行编号": "D1214_L05",
      "原文": "如闻马融笛，若倚仲宣襟。"
    },
    {
      "诗行编号": "D1214_L06",
      "原文": "故国悲寒望，群云惨岁阴。"
    },
    {
      "诗行编号": "D1214_L07",
      "原文": "水乡霾白屋，枫岸叠青岑。"
    },
    {
      "诗行编号": "D1214_L08",
      "原文": "郁郁冬炎瘴，濛濛雨滞淫。"
    },
    {
      "诗行编号": "D1214_L09",
      "原文": "鼓迎非祭鬼，弹落似鸮禽。"
    },
    {
      "诗行编号": "D1214_L10",
      "原文": "兴尽才无闷，愁来遽不禁。"
    }
  ],
