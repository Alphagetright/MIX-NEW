  "诗行": [
    {
      "诗行编号": "D0024_L01",
      "原文": "新亭结搆罢，隐见清湖阴。"
    },
    {
      "诗行编号": "D0024_L02",
      "原文": "迹籍台观旧，气溟海岳深。"
    },
    {
      "诗行编号": "D0024_L03",
      "原文": "圆荷想自昔，遗堞感至今。"
    },
    {
      "诗行编号": "D0024_L04",
      "原文": "芳宴此时具，哀丝千古心。"
    },
    {
      "诗行编号": "D0024_L05",
      "原文": "主称寿尊客，筵秩宴北林。"
    },
    {
      "诗行编号": "D0024_L06",
      "原文": "不阻蓬荜兴，得兼梁甫吟。"
    }
  ],
