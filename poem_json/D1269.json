    {
      "诗行编号": "D1269_L01",
      "原文": "洛阳昔陷没，胡马犯潼关。"
    },
    {
      "诗行编号": "D1269_L02",
      "原文": "天子初愁思，都人惨别颜。"
    },
    {
      "诗行编号": "D1269_L03",
      "原文": "清笳去宫阙，翠盖出关山。"
    },
    {
      "诗行编号": "D1269_L04",
      "原文": "故老仍流涕，龙髯幸再攀。"
    }
