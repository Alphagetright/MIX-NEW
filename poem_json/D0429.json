    {
      "诗行编号": "D0429_L01",
      "原文": "远送从此别，青山空复情。"
    },
    {
      "诗行编号": "D0429_L02",
      "原文": "几时杯重把，昨夜月同行。"
    },
    {
      "诗行编号": "D0429_L03",
      "原文": "列郡讴歌惜，三朝出入荣。"
    },
    {
      "诗行编号": "D0429_L04",
      "原文": "江村独归处，寂寞养残生。"
    }
