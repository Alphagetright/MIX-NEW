  "诗行": [
    {
      "诗行编号": "D0452_L01",
      "原文": "豪俊初未遇，其迹或脱略。"
    },
    {
      "诗行编号": "D0452_L02",
      "原文": "代公尉通泉，放意何自若。"
    },
    {
      "诗行编号": "D0452_L03",
      "原文": "及夫登衮冕，直气森喷薄。"
    },
    {
      "诗行编号": "D0452_L04",
      "原文": "磊落见异人，岂伊常情度。"
    },
    {
      "诗行编号": "D0452_L05",
      "原文": "定策神龙后，宫中翕清廓。"
    },
    {
      "诗行编号": "D0452_L06",
      "原文": "俄顷辨尊亲，指挥存顾托。"
    },
    {
      "诗行编号": "D0452_L07",
      "原文": "群公有惭色，王室无削弱。"
    },
    {
      "诗行编号": "D0452_L08",
      "原文": "迥出名臣上，丹青照台阁。"
    },
    {
      "诗行编号": "D0452_L09",
      "原文": "我行得遗迹，池馆皆疏凿。"
    },
    {
      "诗行编号": "D0452_L10",
      "原文": "壮公临事断，顾步涕横落。"
    },
    {
      "诗行编号": "D0452_L11",
      "原文": "高咏宝剑篇，神交付冥漠。"
    }
  ],
