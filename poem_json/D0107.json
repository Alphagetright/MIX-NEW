  "诗行": [
    {
      "诗行编号": "D0107_L01",
      "原文": "献纳司存雨露边，"
    },
    {
      "诗行编号": "D0107_L02",
      "原文": "地分清切任才贤。"
    },
    {
      "诗行编号": "D0107_L03",
      "原文": "舍人退食收封事，"
    },
    {
      "诗行编号": "D0107_L04",
      "原文": "宫女开函近御筵。"
    },
    {
      "诗行编号": "D0107_L05",
      "原文": "晓漏追飞青琐闼，"
    },
    {
      "诗行编号": "D0107_L06",
      "原文": "晴窗点检白云篇。"
    },
    {
      "诗行编号": "D0107_L07",
      "原文": "扬雄更有河东赋，"
    },
    {
      "诗行编号": "D0107_L08",
      "原文": "唯待吹嘘送上天。"
    }
  ],
