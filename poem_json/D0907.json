    {
      "诗行编号": "D0907_L01",
      "原文": "闻汝依山寺，杭州定越州。"
    },
    {
      "诗行编号": "D0907_L02",
      "原文": "风尘淹别日，江汉失清秋。"
    },
    {
      "诗行编号": "D0907_L03",
      "原文": "影著啼猿树，魂飘结蜃楼。"
    },
    {
      "诗行编号": "D0907_L04",
      "原文": "明年下春水，东尽白云求。"
    }
