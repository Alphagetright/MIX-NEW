  "诗行": [
    {
      "诗行编号": "D1228_L01",
      "原文": "暝色延山径，高斋次水门。"
    },
    {
      "诗行编号": "D1228_L02",
      "原文": "薄云岩际宿，孤月浪中翻。"
    },
    {
      "诗行编号": "D1228_L03",
      "原文": "鹳鹤追飞静，豺狼得食喧。"
    },
    {
      "诗行编号": "D1228_L04",
      "原文": "不眠忧战伐，无力正乾坤。"
    }
  ],
