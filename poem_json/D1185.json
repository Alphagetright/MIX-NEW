  "诗行": [
    {
      "诗行编号": "D1185_L01",
      "原文": "君不见潇湘之山衡山高，山巅朱凤声嗷嗷。"
    },
    {
      "诗行编号": "D1185_L02",
      "原文": "侧身长顾求其群，翅垂口噤心甚劳。"
    },
