  "诗行": [
    {
      "诗行编号": "D0693_L01",
      "原文": "野水平桥路，春沙映竹村。"
    },
    {
      "诗行编号": "D0693_L02",
      "原文": "风轻粉蝶喜，花暖蜜蜂喧。"
    },
    {
      "诗行编号": "D0693_L03",
      "原文": "把酒宜深酌，题诗好细论。"
    },
    {
      "诗行编号": "D0693_L04",
      "原文": "府中瞻暇日，江上忆词源。"
    },
    {
      "诗行编号": "D0693_L05",
      "原文": "迹忝朝廷旧，情依节制尊。"
    },
    {
      "诗行编号": "D0693_L06",
      "原文": "还思长者辙，恐避席为门。"
    }
  ],
