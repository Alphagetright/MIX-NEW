  "诗行": [
    {
      "诗行编号": "D1129_L01",
      "原文": "磬折辞主人，开帆驾洪涛。"
    },
    {
      "诗行编号": "D1129_L02",
      "原文": "春水满南国，朱崖云日高。"
    },
    {
      "诗行编号": "D1129_L03",
      "原文": "舟子废寝食，飘风争所操。"
    },
    {
      "诗行编号": "D1129_L04",
      "原文": "我行匪利涉，谢尔从者劳。"
    },
    {
      "诗行编号": "D1129_L05",
      "原文": "石间采蕨女，鬻菜输官曹。"
    },
    {
      "诗行编号": "D1129_L06",
      "原文": "丈夫死百役，暮返空村号。"
    },
    {
      "诗行编号": "D1129_L07",
      "原文": "闻见事略同，刻剥及锥刀。"
    },
    {
      "诗行编号": "D1129_L08",
      "原文": "贵人岂不仁，视汝如莠蒿。"
    },
    {
      "诗行编号": "D1129_L09",
      "原文": "索钱多门户，丧乱纷嗷嗷。"
    },
    {
      "诗行编号": "D1129_L10",
      "原文": "奈何黠吏徒，渔夺成逋逃。"
    },
    {
      "诗行编号": "D1129_L11",
      "原文": "自喜遂生理，花时甘缊袍。"
    }
  ],
