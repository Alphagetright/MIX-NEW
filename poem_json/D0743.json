    {
      "诗行编号": "D0743_L01",
      "原文": "冥冥甲子雨，已度立春时。"
    },
    {
      "诗行编号": "D0743_L02",
      "原文": "轻箑烦相向，纤絺恐自疑。"
    },
    {
      "诗行编号": "D0743_L03",
      "原文": "烟添才有色，风引更如丝。"
    },
    {
      "诗行编号": "D0743_L04",
      "原文": "直觉巫山暮，兼催宋玉悲。"
    }
