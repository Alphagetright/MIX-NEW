  "诗行": [
    {
      "诗行编号": "D0015_L01",
      "原文": "二仪积风雨，百谷漏波涛。"
    },
    {
      "诗行编号": "D0015_L02",
      "原文": "闻道洪河坼，遥连沧海高。"
    },
    {
      "诗行编号": "D0015_L03",
      "原文": "职司忧悄悄，郡国诉嗷嗷。"
    },
    {
      "诗行编号": "D0015_L04",
      "原文": "舍弟卑栖邑，防川领簿曹。"
    },
    {
      "诗行编号": "D0015_L05",
      "原文": "尺书前日至，版筑不时操。"
    },
    {
      "诗行编号": "D0015_L06",
      "原文": "难假鼋鼍力，空瞻乌鹊毛。"
    },
    {
      "诗行编号": "D0015_L07",
      "原文": "燕南吹畎亩，济上没蓬蒿。"
    },
    {
      "诗行编号": "D0015_L08",
      "原文": "螺蚌满近郭，蛟螭乘九皋。"
    },
    {
      "诗行编号": "D0015_L09",
      "原文": "徐关深水府，碣石小秋毫。"
    },
    {
      "诗行编号": "D0015_L10",
      "原文": "白屋留孤树，青天矢万艘。"
    },
    {
      "诗行编号": "D0015_L11",
      "原文": "吾衰同泛梗，利涉想蟠桃。"
    },
    {
      "诗行编号": "D0015_L12",
      "原文": "倚赖天涯钓，犹能掣巨鳌。"
    }
  ],
