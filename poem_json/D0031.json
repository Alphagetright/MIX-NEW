  "诗行": [
    {
      "诗行编号": "D0031_L01",
      "原文": "巢父掉头不肯住"
    },
    {
      "诗行编号": "D0031_L02",
      "原文": "东将入海随烟雾"
    },
    {
      "诗行编号": "D0031_L03",
      "原文": "诗卷长留天地间"
    },
    {
      "诗行编号": "D0031_L04",
      "原文": "钓竿欲拂珊瑚树"
    },
    {
      "诗行编号": "D0031_L05",
      "原文": "深山大泽龙蛇远"
    },
    {
      "诗行编号": "D0031_L06",
      "原文": "春寒野阴风景暮"
    },
    {
      "诗行编号": "D0031_L07",
      "原文": "蓬莱织女回云车"
    },
    {
      "诗行编号": "D0031_L08",
      "原文": "指点虚无是征路"
    },
    {
      "诗行编号": "D0031_L09",
      "原文": "自是君身有仙骨"
    },
    {
      "诗行编号": "D0031_L10",
      "原文": "世人那得知其故"
    },
    {
      "诗行编号": "D0031_L11",
      "原文": "惜君只欲苦死留"
    },
    {
      "诗行编号": "D0031_L12",
      "原文": "富贵何如草头露"
    },
    {
      "诗行编号": "D0031_L13",
      "原文": "蔡侯静者意有馀"
    },
    {
      "诗行编号": "D0031_L14",
      "原文": "清夜置酒临前除"
    },
    {
      "诗行编号": "D0031_L15",
      "原文": "罢琴惆怅月照席"
    },
    {
      "诗行编号": "D0031_L16",
      "原文": "几岁寄我空中书"
    },
    {
      "诗行编号": "D0031_L17",
      "原文": "南寻禹穴见李白"
    },
    {
      "诗行编号": "D0031_L18",
      "原文": "道甫问信今何如"
    }
  ],
