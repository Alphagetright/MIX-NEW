  "诗行": [
    {
      "诗行编号": "D0450_L01",
      "原文": "将老忧贫窭，筋力岂能及。"
    },
    {
      "诗行编号": "D0450_L02",
      "原文": "征途乃侵星，得使诸病入。"
    },
    {
      "诗行编号": "D0450_L03",
      "原文": "鄙人寡道气，在困无独立。"
    },
    {
      "诗行编号": "D0450_L04",
      "原文": "俶装逐徒旅，达曙凌险涩。"
    },
    {
      "诗行编号": "D0450_L05",
      "原文": "寒日出雾迟，清江转山急。"
    },
    {
      "诗行编号": "D0450_L06",
      "原文": "仆夫行不进，驽马若维絷。"
    },
    {
      "诗行编号": "D0450_L07",
      "原文": "汀洲稍疏散，风景开怏悒。"
    },
    {
      "诗行编号": "D0450_L08",
      "原文": "空慰所尚怀，终非曩游集。"
    },
    {
      "诗行编号": "D0450_L09",
      "原文": "衰颜偶一破，胜事难屡挹。"
    },
    {
      "诗行编号": "D0450_L10",
      "原文": "茫然阮籍途，更洒杨朱泣。"
    }
  ],
