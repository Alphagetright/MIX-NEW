  "诗行": [
    {
      "诗行编号": "D0751_L01",
      "原文": "温温士君子，令我怀抱尽。"
    },
    {
      "诗行编号": "D0751_L02",
      "原文": "灵芝冠众芳，安得阙亲近。"
    },
    {
      "诗行编号": "D0751_L03",
      "原文": "遭乱意不归，窜身迹非隐。"
    },
    {
      "诗行编号": "D0751_L04",
      "原文": "细人尚姑息，吾子色愈谨。"
    },
    {
      "诗行编号": "D0751_L05",
      "原文": "高怀见物理，识者安肯哂。"
    },
    {
      "诗行编号": "D0751_L06",
      "原文": "卑飞欲何待，捷径应未忍。"
    },
    {
      "诗行编号": "D0751_L07",
      "原文": "示我百篇文，诗家一标准。"
    },
    {
      "诗行编号": "D0751_L08",
      "原文": "羁离交屈宋，牢落值颜闵。"
    },
    {
      "诗行编号": "D0751_L09",
      "原文": "水路迷畏途，药饵驻修轸。"
    },
    {
      "诗行编号": "D0751_L10",
      "原文": "古人日以远，青史字不泯。"
    },
    {
      "诗行编号": "D0751_L11",
      "原文": "步趾咏唐虞，追随饭葵堇。"
    },
    {
      "诗行编号": "D0751_L12",
      "原文": "数杯资好事，异味烦县尹。"
    },
    {
      "诗行编号": "D0751_L13",
      "原文": "心虽在朝谒，力与愿矛盾。"
    },
    {
      "诗行编号": "D0751_L14",
      "原文": "抱病排金门，衰容岂为敏。"
    }
  ],
