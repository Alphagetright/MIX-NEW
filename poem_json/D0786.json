    {
      "诗行编号": "D0786_L01",
      "原文": "白帝城中云出门，白帝城下雨翻盆。"
    },
    {
      "诗行编号": "D0786_L02",
      "原文": "高江急峡雷霆斗，翠木苍藤日月昏。"
    },
    {
      "诗行编号": "D0786_L03",
      "原文": "戎马不如归马逸，千家今有百家存。"
    },
    {
      "诗行编号": "D0786_L04",
      "原文": "哀哀寡妇诛求尽，恸哭秋原何处村。"
    }
