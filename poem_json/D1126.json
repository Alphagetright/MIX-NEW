    {
      "诗行编号": "D1126_L01",
      "原文": "百丈牵江色，孤舟泛日斜。"
    },
    {
      "诗行编号": "D1126_L02",
      "原文": "兴来犹杖屦，目断更云沙。"
    },
    {
      "诗行编号": "D1126_L03",
      "原文": "山鬼迷春竹，湘娥倚暮花。"
    },
    {
      "诗行编号": "D1126_L04",
      "原文": "湖南清绝地，万古一长嗟。"
    }
  ],
