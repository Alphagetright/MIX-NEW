    },
    {
      "诗行编号": "D0695_L02",
      "原文": "乾坤万里眼，时序百年心。"
    },
    {
      "诗行编号": "D0695_L03",
      "原文": "茅屋还堪赋，桃源自可寻。"
    },
    {
      "诗行编号": "D0695_L04",
      "原文": "艰难贱生理，飘泊到如今。"
    }
  ],
