  "诗行": [
    {
      "诗行编号": "D0068_L01",
      "原文": "高标跨苍天，烈风无时休。"
    },
    {
      "诗行编号": "D0068_L02",
      "原文": "自非吾辈怀，登兹翻百忧。"
    },
    {
      "诗行编号": "D0068_L03",
      "原文": "方知象教力，足可追冥搜。"
    },
    {
      "诗行编号": "D0068_L04",
      "原文": "仰穿龙蛇窟，始出枝撑幽。"
    },
    {
      "诗行编号": "D0068_L05",
      "原文": "七星在北户，河汉声西流。"
    },
    {
      "诗行编号": "D0068_L06",
      "原文": "羲和鞭白日，少昊行清秋。"
    },
    {
      "诗行编号": "D0068_L07",
      "原文": "秦山忽破碎，泾渭不可求。"
    },
    {
      "诗行编号": "D0068_L08",
      "原文": "俯视但一气，焉能辨皇州。"
    },
    {
      "诗行编号": "D0068_L09",
      "原文": "回首叫虞舜，苍梧云正愁。"
    },
    {
      "诗行编号": "D0068_L10",
      "原文": "惜哉瑶池饮，日宴昆仑丘。"
    },
    {
      "诗行编号": "D0068_L11",
      "原文": "黄鹄去不息，哀鸣何所投。"
    },
    {
      "诗行编号": "D0068_L12",
      "原文": "君看随阳雁，各有稻粱谋。"
    }
  ],
