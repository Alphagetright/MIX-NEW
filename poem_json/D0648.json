  "诗行": [
    {
      "诗行编号": "D0648_L01",
      "原文": "国步犹艰难，兵革未衰息。"
    },
    {
      "诗行编号": "D0648_L02",
      "原文": "万方哀嗷嗷，十载供军食。"
    },
    {
      "诗行编号": "D0648_L03",
      "原文": "庶官务割剥，不暇忧反侧。"
    },
    {
      "诗行编号": "D0648_L04",
      "原文": "操持纪纲地，喜见朱丝直。"
    },
    {
      "诗行编号": "D0648_L05",
      "原文": "必若救疮痍，先应去蟊贼。"
    },
    {
      "诗行编号": "D0648_L06",
      "原文": "挥泪临大江，高天意悽恻。"
    },
    {
      "诗行编号": "D0648_L07",
      "原文": "行行树佳政，慰我深相忆。"
    }
  ],
