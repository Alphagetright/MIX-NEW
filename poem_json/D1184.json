  "诗行": [
    {
      "诗行编号": "D1184_L01",
      "原文": "君不见黄鹄高于五尺童，化为白凫似老翁。"
    },
    {
      "诗行编号": "D1184_L02",
      "原文": "君不见黄鵠高于五尺童，化为白凫似老翁。"
    },
    {
      "诗行编号": "D1184_L03",
      "原文": "故畦遗穗已荡尽，天寒岁暮波涛中。"
    },
    {
      "诗行编号": "D1184_L04",
      "原文": "鳞介腥膻素不食，终日忍饥西复东。"
    },
    {
      "诗行编号": "D1184_L05",
      "原文": "鲁门鶢鶋亦蹭蹬，闻道如今犹避风。"
    }
  ],
