  "诗行": [
    {
      "诗行编号": "D0430_L01",
      "原文": "籍甚黄丞相，能名自颍川。"
    },
    {
      "诗行编号": "D0430_L02",
      "原文": "近看除刺史，还喜得吾贤。"
    },
    {
      "诗行编号": "D0430_L03",
      "原文": "五马何时到，双鱼会早传。"
    },
    {
      "诗行编号": "D0430_L04",
      "原文": "老思筇竹杖，冬要锦衾眠。"
    },
    {
      "诗行编号": "D0430_L05",
      "原文": "不作临岐恨，惟听举最先。"
    },
    {
      "诗行编号": "D0430_L06",
      "原文": "火云挥汗日，山驿醒心泉。"
    },
    {
      "诗行编号": "D0430_L07",
      "原文": "遇害陈公殒，于今蜀道怜。"
    },
    {
      "诗行编号": "D0430_L08",
      "原文": "君行射洪县，为我一潸然。"
    },
    {
      "诗行编号": "D0430_L09",
      "原文": "送梓州李使君之任"
    }
  ],
