  "诗行": [
    {
      "诗行编号": "D0554_L01",
      "原文": "巴山遇中使，云自峡城来。"
    },
    {
      "诗行编号": "D0554_L02",
      "原文": "盗贼还奔突，乘舆恐未回。"
    },
    {
      "诗行编号": "D0554_L03",
      "原文": "天寒邵伯树，地阔望仙台。"
    },
    {
      "诗行编号": "D0554_L04",
      "原文": "狼狈风尘里，群臣安在哉。"
    }
  ],
