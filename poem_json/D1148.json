  "诗行": [
    {
      "诗行编号": "D1148_L01",
      "原文": "参错云石稠，坡陀风涛壮。"
    },
    {
      "诗行编号": "D1148_L02",
      "原文": "晚洲适知名，秀色固异状。"
    },
    {
      "诗行编号": "D1148_L03",
      "原文": "棹经垂猿把，身在度鸟上。"
    },
    {
      "诗行编号": "D1148_L04",
      "原文": "摆浪散帙妨，危沙折花当。"
    },
    {
      "诗行编号": "D1148_L05",
      "原文": "羁离暂愉悦，羸老反惆怅。"
    },
    {
      "诗行编号": "D1148_L06",
      "原文": "中原未解兵，吾得终疏放。"
    }
  ],
