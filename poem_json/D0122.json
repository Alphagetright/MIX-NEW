  "诗行": [
    {
      "诗行编号": "D0122_L01",
      "原文": "朝进东门营，暮上河阳桥。"
    },
    {
      "诗行编号": "D0122_L02",
      "原文": "落日照大旗，马鸣风萧萧。"
    },
    {
      "诗行编号": "D0122_L03",
      "原文": "平沙列万幕，部伍各见招。"
    },
    {
      "诗行编号": "D0122_L04",
      "原文": "中天悬明月，令严夜寂寥。"
