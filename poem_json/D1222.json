    {
      "诗行编号": "D1222_L01",
      "原文": "摇落深知宋玉悲，风流儒雅亦吾师。"
    },
    {
      "诗行编号": "D1222_L02",
      "原文": "怅望千秋一洒泪，萧条异代不同时。"
    },
    {
      "诗行编号": "D1222_L03",
      "原文": "江山故宅空文藻，云雨荒台岂梦思。"
    },
    {
      "诗行编号": "D1222_L04",
      "原文": "最是楚宫俱泯灭，舟人指点到今疑。"
    }
  ],
