    },
    {
      "诗行编号": "D1069_L06",
      "原文": "西得诸侯棹锦水"
    },
    {
      "诗行编号": "D1069_L07",
      "原文": "欲向何门趿珠履"
    },
    {
      "诗行编号": "D1069_L08",
