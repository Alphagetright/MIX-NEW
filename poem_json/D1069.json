    {
      "诗行编号": "D1069_L02",
      "原文": "我能拔尔抑塞磊落之奇才"
    },
    {
      "诗行编号": "D1069_L03",
      "原文": "豫章翻风白日动"
    },
    {
      "诗行编号": "D1069_L04",
      "原文": "鲸鱼跋浪沧溟开"
    },
    {
      "诗行编号": "D1069_L05",
