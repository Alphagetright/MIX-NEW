  "诗行": [
    {
      "诗行编号": "D0119_L01",
      "原文": "蔡子勇成癖，弯弓西射胡。"
    },
    {
      "诗行编号": "D0119_L02",
      "原文": "健儿宁斗死，壮士耻为儒。"
    },
    {
      "诗行编号": "D0119_L03",
      "原文": "官是先锋得，材缘挑战须。"
    },
    {
      "诗行编号": "D0119_L04",
      "原文": "身轻一鸟过，枪急万人呼。"
    },
    {
      "诗行编号": "D0119_L05",
      "原文": "云幕随开府，春城赴上都。"
    },
    {
      "诗行编号": "D0119_L06",
      "原文": "马头金狎帢，驼背锦模糊。"
    },
    {
      "诗行编号": "D0119_L07",
      "原文": "咫尺云山路，归飞青海隅。"
    },
    {
      "诗行编号": "D0119_L08",
      "原文": "上公犹宠锡，突将且前驱。"
    },
    {
      "诗行编号": "D0119_L09",
      "原文": "汉使黄河远，凉州白麦枯。"
    },
    {
      "诗行编号": "D0119_L10",
      "原文": "因君问消息，好在阮元瑜。"
    }
  ],
