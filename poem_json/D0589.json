  "诗行": [
    {
      "诗行编号": "D0589_L01",
      "原文": "四海十年不解兵，犬戎也复临咸京。"
    },
    {
      "诗行编号": "D0589_L02",
      "原文": "失道非关出襄野，扬鞭忽是过胡城。"
    },
    {
      "诗行编号": "D0589_L03",
      "原文": "豺狼塞路人断绝，烽火照夜尸纵横。"
    },
    {
      "诗行编号": "D0589_L04",
      "原文": "天子亦应厌奔走，群公固合思升平。"
    },
    {
      "诗行编号": "D0589_L05",
      "原文": "天子亦应厭奔走，群公固合思升平。"
    },
    {
      "诗行编号": "D0589_L06",
      "原文": "但恐诛求不改辙，闻道嬖孽能全生。"
    },
    {
      "诗行编号": "D0589_L07",
      "原文": "江边老翁错料事，眼暗不见风尘清。"
    }
  ],
