    {
      "诗行编号": "D0302_L01",
      "原文": "丞相祠堂何处寻，锦官城外柏森森。"
    },
    {
      "诗行编号": "D0302_L02",
      "原文": "映阶碧草自春色，隔叶黄鹂空好音。"
    },
    {
      "诗行编号": "D0302_L03",
      "原文": "三顾频烦天下计，两朝开济老臣心。"
    },
    {
      "诗行编号": "D0302_L04",
      "原文": "出师未捷身先死，长使英雄泪满襟。"
    }
