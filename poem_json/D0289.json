  "诗行": [
    {
      "诗行编号": "D0289_L01",
      "原文": "畏途随长江，渡口下绝岸。"
    },
    {
      "诗行编号": "D0289_L02",
      "原文": "差池上舟楫，杳窕入云汉。"
    },
    {
      "诗行编号": "D0289_L03",
      "原文": "天寒荒野外，日暮中流半。"
    },
    {
      "诗行编号": "D0289_L04",
      "原文": "我马向北嘶，山猿饮相唤。"
    },
    {
      "诗行编号": "D0289_L05",
      "原文": "水清石礧礧，沙白滩漫漫。"
    },
    {
      "诗行编号": "D0289_L06",
      "原文": "迥然洗愁辛，多病一疏散。"
    },
    {
      "诗行编号": "D0289_L07",
      "原文": "高壁抵嵚崟，洪涛越凌乱。"
    },
    {
      "诗行编号": "D0289_L08",
      "原文": "临风独回首，揽辔复三叹。"
    }
  ],
