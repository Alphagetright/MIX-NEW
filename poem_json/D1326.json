  "诗行": [
    {
      "诗行编号": "D1326_L01",
      "原文": "柴门杂树向千株，丹橘黄甘此地无。"
    },
    {
      "诗行编号": "D1326_L02",
      "原文": "江上今朝寒雨歇，篱中秀色画屏纡。"
    },
    {
      "诗行编号": "D1326_L03",
      "原文": "桃蹊李径年虽故，栀子红椒艳复殊。"
    },
    {
      "诗行编号": "D1326_L04",
      "原文": "锁石藤稍元自落，倚天松骨见来枯。"
    },
    {
      "诗行编号": "D1326_L05",
      "原文": "林香出实垂将尽，叶蒂辞枝不重苏。"
    },
    {
      "诗行编号": "D1326_L06",
      "原文": "爱日恩光蒙借贷，清霜杀气得忧虞。"
    },
    {
      "诗行编号": "D1326_L07",
      "原文": "衰颜更觅藜床坐，缓步仍须竹杖扶。"
    },
    {
      "诗行编号": "D1326_L08",
      "原文": "散骑未知云阁处，啼猿僻在楚山隅。"
    }
  ],
