  "诗行": [
    {
      "诗行编号": "D0047_L01",
      "原文": "翰林逼华盖，鲸力破沧溟。"
    },
    {
      "诗行编号": "D0047_L02",
      "原文": "天上张公子，宫中汉客星。"
    },
    {
      "诗行编号": "D0047_L03",
      "原文": "赋诗拾翠殿，佐酒望云亭。"
    },
    {
      "诗行编号": "D0047_L04",
      "原文": "紫诰仍兼绾，黄麻似六经。"
    },
    {
      "诗行编号": "D0047_L05",
      "原文": "内分金带赤，恩与荔枝青。"
    },
    {
      "诗行编号": "D0047_L06",
      "原文": "无复随高凤，空馀泣聚萤。"
    },
    {
      "诗行编号": "D0047_L07",
      "原文": "此生任春草，垂老独漂萍。"
    },
    {
      "诗行编号": "D0047_L08",
      "原文": "傥忆山阳会，悲歌在一听。"
    }
  ],
