  "诗行": [
    {
      "诗行编号": "D0103_L01",
      "原文": "平明跨驴出"
    },
    {
      "诗行编号": "D0103_L02",
      "原文": "未知适谁门"
    },
    {
      "诗行编号": "D0103_L03",
      "原文": "诸孙贫无事"
    },
    {
      "诗行编号": "D0103_L04",
      "原文": "宅舍如荒村"
    },
    {
      "诗行编号": "D0103_L05",
      "原文": "堂前自生竹"
    },
    {
      "诗行编号": "D0103_L06",
      "原文": "堂后自生萱"
    },
    {
      "诗行编号": "D0103_L07",
      "原文": "萱草秋已死"
    },
    {
      "诗行编号": "D0103_L08",
      "原文": "竹枝霜不蕃"
    },
    {
      "诗行编号": "D0103_L09",
      "原文": "淘米少汲水"
    },
    {
      "诗行编号": "D0103_L10",
      "原文": "汲多井水浑"
    },
    {
      "诗行编号": "D0103_L11",
      "原文": "刈葵莫放手"
    },
    {
      "诗行编号": "D0103_L12",
      "原文": "放手伤葵根"
    },
    {
      "诗行编号": "D0103_L13",
      "原文": "阿翁懒惰久"
    },
    {
      "诗行编号": "D0103_L14",
      "原文": "觉儿行步奔"
    },
    {
      "诗行编号": "D0103_L15",
      "原文": "所来为宗族"
    },
    {
      "诗行编号": "D0103_L16",
      "原文": "亦不为盘飧"
    },
    {
      "诗行编号": "D0103_L17",
      "原文": "小人利口实"
    },
    {
      "诗行编号": "D0103_L18",
      "原文": "薄俗难可论"
    },
    {
      "诗行编号": "D0103_L19",
      "原文": "勿受外嫌猜"
    },
    {
      "诗行编号": "D0103_L20",
      "原文": "同姓古所敦"
    }
  ],
