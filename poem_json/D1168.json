  "诗行": [
    {
      "诗行编号": "D1168_L01",
      "原文": "相见各头白，其如离别何。"
    },
    {
      "诗行编号": "D1168_L02",
      "原文": "几年一会面，今日复悲歌。"
    },
    {
      "诗行编号": "D1168_L03",
      "原文": "少壮乐难得，岁寒心匪他。"
    },
    {
      "诗行编号": "D1168_L04",
      "原文": "气缠霜匣满，冰置玉壶多。"
    },
    {
      "诗行编号": "D1168_L05",
      "原文": "遭乱实漂泊，济时曾琢磨。"
    },
    {
      "诗行编号": "D1168_L06",
      "原文": "形容吾校老，胆力尔谁过。"
    },
    {
      "诗行编号": "D1168_L07",
      "原文": "秋晚岳增翠，风高湖涌波。"
    },
    {
      "诗行编号": "D1168_L08",
      "原文": "鶱腾访知己，淮海莫蹉跎。"
    }
  ],
