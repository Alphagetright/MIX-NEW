    {
      "诗行编号": "D0674_L01",
      "原文": "弱质岂自负，移根方尔瞻。"
    },
    {
      "诗行编号": "D0674_L02",
      "原文": "细声闻玉帐，疏翠近珠帘。"
    },
    {
      "诗行编号": "D0674_L03",
      "原文": "未见紫烟集，虚蒙清露沾。"
    },
    {
      "诗行编号": "D0674_L04",
      "原文": "何当一百丈，欹盖拥高檐。"
    }
