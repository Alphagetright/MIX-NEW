  "诗行": [
    {
      "诗行编号": "D0022_L01",
      "原文": "东藩驻皂盖，北渚凌青荷。"
    },
    {
      "诗行编号": "D0022_L02",
      "原文": "海右此亭古，济南名士多。"
    },
    {
      "诗行编号": "D0022_L03",
      "原文": "云山已发兴，玉佩仍当歌。"
    },
    {
      "诗行编号": "D0022_L04",
      "原文": "修竹不受暑，交流空涌波。"
    },
    {
      "诗行编号": "D0022_L05",
      "原文": "蕴真惬所遇，落日将如何。"
    },
    {
      "诗行编号": "D0022_L06",
      "原文": "贵贱俱物役，从公难重过。"
    }
  ],
