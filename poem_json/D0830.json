  "诗行": [
    {
      "诗行编号": "D0830_L01",
      "原文": "中丞问俗画熊频，"
    },
    {
      "诗行编号": "D0830_L02",
      "原文": "爱弟传书彩鹢新。"
    },
    {
      "诗行编号": "D0830_L03",
      "原文": "迁转五州防御使，"
    },
    {
      "诗行编号": "D0830_L04",
      "原文": "起居八座太夫人。"
    },
    {
      "诗行编号": "D0830_L05",
      "原文": "楚宫腊送荆门水，"
    },
    {
      "诗行编号": "D0830_L06",
      "原文": "白帝云偷碧海春。"
    },
    {
      "诗行编号": "D0830_L07",
      "原文": "报与惠连诗不惜，"
    },
    {
      "诗行编号": "D0830_L08",
      "原文": "知吾斑鬓总如银。"
    }
  ],
