  "诗行": [
    {
      "诗行编号": "D0470_L01",
      "原文": "使君意气凌青霄，忆昨欢娱常见招。"
    },
    {
      "诗行编号": "D0470_L02",
      "原文": "细马时鸣金騕袅，佳人屡出董骄饶。"
    },
    {
      "诗行编号": "D0470_L03",
      "原文": "东流江水西飞燕，可惜春光不相见。"
    },
    {
      "诗行编号": "D0470_L04",
      "原文": "愿携王赵两红颜，再骋肌肤如素练。"
    },
    {
      "诗行编号": "D0470_L05",
      "原文": "通泉百里近梓州，请公一来开我愁。"
    },
    {
      "诗行编号": "D0470_L06",
      "原文": "舞处重看花满面，尊前还有锦缠头。"
    }
  ],
