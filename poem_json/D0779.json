    {
      "诗行编号": "D0779_L01",
      "原文": "返照斜初彻，浮云薄未归。"
    },
    {
      "诗行编号": "D0779_L02",
      "原文": "江虹明远饮，峡雨落馀飞。"
    },
    {
      "诗行编号": "D0779_L03",
      "原文": "凫雁终高去，熊罴觉自肥。"
    },
    {
      "诗行编号": "D0779_L04",
      "原文": "秋分客尚在，竹露夕微微。"
    }
  ],
