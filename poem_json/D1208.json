  "诗行": [
    {
      "诗行编号": "D1208_L01",
      "原文": "宿昔试安命，自私犹畏天。"
    },
    {
      "诗行编号": "D1208_L02",
      "原文": "劳生系一物，为客费多年。"
    },
    {
      "诗行编号": "D1208_L03",
      "原文": "衡岳江湖大，蒸池疫疠偏。"
    },
    {
      "诗行编号": "D1208_L04",
      "原文": "散才婴薄俗，有迹负前贤。"
    },
    {
      "诗行编号": "D1208_L05",
      "原文": "散才婴薄俗巾拂那关眼，瓶罍易满船。"
    },
    {
      "诗行编号": "D1208_L06",
      "原文": "火云滋垢腻，冻雨裛沈绵。"
    },
    {
      "诗行编号": "D1208_L07",
      "原文": "强饭莼添滑，端居茗续煎。"
    },
    {
      "诗行编号": "D1208_L08",
      "原文": "清思汉水上，凉忆岘山巅。"
    },
    {
      "诗行编号": "D1208_L09",
      "原文": "顺浪翻堪倚，回帆又省牵。"
    },
    {
      "诗行编号": "D1208_L10",
      "原文": "吾家碑不昧，王氏井依然。"
    },
    {
      "诗行编号": "D1208_L11",
      "原文": "几杖将衰齿，茅茨寄短椽。"
    },
    {
      "诗行编号": "D1208_L12",
      "原文": "灌园曾取适，游寺可终焉。"
    },
    {
      "诗行编号": "D1208_L13",
      "原文": "遂性同渔父，成名异鲁连。"
    },
    {
      "诗行编号": "D1208_L14",
      "原文": "篙师烦尔送，朱夏及寒泉。"
    }
  ],
