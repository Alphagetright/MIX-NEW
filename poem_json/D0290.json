  "诗行": [
    {
      "诗行编号": "D0290_L01",
      "原文": "山行有常程，中夜尚未安。"
    },
    {
      "诗行编号": "D0290_L02",
      "原文": "微月没已久，崖倾路何难。"
    },
    {
      "诗行编号": "D0290_L03",
      "原文": "大江动我前，汹若溟渤宽。"
    },
    {
      "诗行编号": "D0290_L04",
      "原文": "篙师暗理楫，歌笑轻波澜。"
    },
    {
      "诗行编号": "D0290_L05",
      "原文": "霜浓木石滑，风急手足寒。"
    },
    {
      "诗行编号": "D0290_L06",
      "原文": "入舟已千忧，陟巘仍万盘。"
    },
    {
      "诗行编号": "D0290_L07",
      "原文": "迥眺积水外，始知众星乾。"
    },
    {
      "诗行编号": "D0290_L08",
      "原文": "远游令人瘦，衰疾惭加餐。"
    }
  ],
