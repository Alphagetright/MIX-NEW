  "诗行": [
    {
      "诗行编号": "D1292_L01",
      "原文": "堂前扑枣任西邻"
    },
    {
      "诗行编号": "D1292_L02",
      "原文": "无食无儿一妇人"
    },
    {
      "诗行编号": "D1292_L03",
      "原文": "不为困穷宁有此"
    },
    {
      "诗行编号": "D1292_L04",
      "原文": "祗缘恐惧转须亲"
    },
    {
      "诗行编号": "D1292_L05",
      "原文": "不为困窮宁有此"
    },
    {
      "诗行编号": "D1292_L06",
      "原文": "祗缘恐惧转须亲"
    },
    {
      "诗行编号": "D1292_L07",
      "原文": "即防远客虽多事"
