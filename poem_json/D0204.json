  "诗行": [
    {
      "诗行编号": "D0204_L01",
      "原文": "高秋登塞山，南望马邑州。"
    },
    {
      "诗行编号": "D0204_L02",
      "原文": "降虏东击胡，壮健尽不留。"
    },
    {
      "诗行编号": "D0204_L03",
      "原文": "穹庐莽牢落，上有行云愁。"
    },
    {
      "诗行编号": "D0204_L04",
      "原文": "老弱哭道路，愿闻甲兵休。"
    },
    {
      "诗行编号": "D0204_L05",
      "原文": "邺中事反覆，死人积如丘。"
    },
    {
      "诗行编号": "D0204_L06",
      "原文": "诸将已茅土，载驱谁与谋。"
    }
  ],
