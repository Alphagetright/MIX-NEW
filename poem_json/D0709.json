  "诗行": [
    {
      "诗行编号": "D0709_L01",
      "原文": "孔雀未知牛有角，渴饮寒泉逢抵触。"
    },
    {
      "诗行编号": "D0709_L02",
      "原文": "赤霄悬圃须往来，翠尾金花不辞辱。"
    },
    {
      "诗行编号": "D0709_L03",
      "原文": "江中淘河吓飞燕，衔泥却落羞华屋。"
