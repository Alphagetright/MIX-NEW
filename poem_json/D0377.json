  "诗行": [
    {
      "诗行编号": "D0377_L01",
      "原文": "远师虞秘监，今喜识玄孙。"
    },
    {
      "诗行编号": "D0377_L02",
      "原文": "形像丹青逼，家声器宇存。"
    },
    {
      "诗行编号": "D0377_L03",
      "原文": "凄凉怜笔势，浩荡问词源。"
    },
    {
      "诗行编号": "D0377_L04",
      "原文": "爽气金天豁，清谈玉露繁。"
    },
    {
      "诗行编号": "D0377_L05",
      "原文": "伫鸣南岳凤，欲化北溟鲲。"
    },
    {
      "诗行编号": "D0377_L06",
      "原文": "交态知浮俗，儒流不异门。"
    },
    {
      "诗行编号": "D0377_L07",
      "原文": "过逢联客位，日夜倒芳尊。"
    },
    {
      "诗行编号": "D0377_L08",
      "原文": "沙岸风吹叶，云江月上轩。"
    },
    {
      "诗行编号": "D0377_L09",
      "原文": "百年嗟已半，四座敢辞喧。"
    },
    {
      "诗行编号": "D0377_L10",
      "原文": "书籍终相与，青山隔故园。"
    }
  ],
