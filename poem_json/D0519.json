  "诗行": [
    {
      "诗行编号": "D0519_L01",
      "原文": "窜身来蜀地，同病得韦郎。"
    },
    {
      "诗行编号": "D0519_L02",
      "原文": "天下干戈满，江边岁月长。"
    },
    {
      "诗行编号": "D0519_L03",
      "原文": "别筵花欲暮，春日鬓俱苍。"
    },
    {
      "诗行编号": "D0519_L04",
      "原文": "为问南溪竹，抽梢合过墙。"
    }
  ],
