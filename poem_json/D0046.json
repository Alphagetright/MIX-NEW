  "诗行": [
    {
      "诗行编号": "D0046_L01",
      "原文": "草昧英雄起，讴歌历数归。"
    },
    {
      "诗行编号": "D0046_L02",
      "原文": "风尘三尺剑，社稷一戎衣。"
    },
    {
      "诗行编号": "D0046_L03",
      "原文": "翼亮贞文德，丕承戢武威。"
    },
    {
      "诗行编号": "D0046_L04",
      "原文": "圣图天广大，宗祀日光辉。"
    },
    {
      "诗行编号": "D0046_L05",
      "原文": "陵寝盘空曲，熊罴守翠微。"
    },
    {
      "诗行编号": "D0046_L06",
      "原文": "再窥松柏路，还见五云飞。"
    }
  ],
