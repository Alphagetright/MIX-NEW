  "诗行": [
    {
      "诗行编号": "D0760_L01",
      "原文": "此堂存古制，城上俯江郊。"
    },
    {
      "诗行编号": "D0760_L02",
      "原文": "落构垂云雨，荒阶蔓草茅。"
    },
    {
      "诗行编号": "D0760_L03",
      "原文": "柱穿蜂溜蜜，栈缺燕添巢。"
    },
    {
      "诗行编号": "D0760_L04",
      "原文": "坐接春杯气，心伤艳蕊梢。"
    },
    {
      "诗行编号": "D0760_L05",
      "原文": "英灵如过隙，宴衎愿投胶。"
    },
    {
      "诗行编号": "D0760_L06",
      "原文": "莫问东流水，生涯未即抛。"
    }
  ],
